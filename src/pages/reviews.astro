---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/sections/Header.astro";
import Footer from "@/components/sections/Footer.astro";
import ReviewsSection from "@/components/sections/ReviewsSection.astro";
import AppDownloadCtaSection from "@/components/sections/AppDownloadCtaSection.astro";
import bgPattern from "@/assets/images/background-pattern.png";
import heroGlow from "@/assets/images/hero-glow-line.svg";
import { navItems, footerColumns } from "@/lib/navigation";
---

<BaseLayout title="Webinar — Contractors Love Handoff">
  <Header navItems={navItems} />

  <!-- Hero Section -->
  <section class="relative overflow-hidden pt-20 bg-brand-800">
    <!-- Background grid pattern -->
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[1920px] h-[1440px] pointer-events-none z-0 opacity-30">
      <img src={bgPattern.src} alt="" class="w-full h-full block object-contain object-top" />
    </div>

    <!-- Glow line -->
    <div class="absolute -top-[24%] -left-[14%] -right-[14%] -bottom-[24%] pointer-events-none z-[1]">
      <img src={heroGlow.src} alt="" class="w-full h-full block" />
    </div>

    <!-- Content -->
    <div class="relative z-[2] max-w-[1280px] mx-auto px-8 pt-24 pb-0 flex flex-col items-center text-center">
      <!-- Eyebrow -->
      <p class="font-mono text-sm font-semibold leading-6 tracking-[0.56px] uppercase text-text-on-brand-tertiary mb-4" data-animate="fade-up">
        Reviews
      </p>

      <!-- Heading -->
      <h1 class="font-display text-5xl sm:text-6xl lg:text-[72px] font-medium leading-[1.1] lg:leading-[90px] tracking-[-1.44px] text-white mb-6 max-w-[960px]" data-animate="fade-up">
        Contractors love Handoff
      </h1>

      <!-- Supporting text -->
      <p class="text-xl font-medium leading-[30px] text-white max-w-[768px] mb-10" data-animate="fade-up">
        But don&rsquo;t take our word for it, see for yourself. Check out real testimonials from actual contractors using Handoff to scale their construction businesses.
      </p>

      <!-- CTA -->
      <div class="flex items-center justify-center mb-16" data-animate="fade-up">
        <a
          href="/"
          class="inline-flex items-center justify-center gap-1.5 px-5 py-3 text-base font-medium leading-6 rounded-xl transition-all duration-150 whitespace-nowrap bg-white/10 backdrop-blur-md text-white hover:bg-white/20 shadow-xs"
        >
          See how it works
        </a>
      </div>

      <!-- Video / content placeholder -->
      <div class="relative w-full rounded-t-2xl overflow-hidden bg-white/[0.12] h-[292px]" data-animate="fade-up">
        <!-- Play button overlay -->
        <div class="absolute inset-0 flex items-center justify-center">
          <button
            type="button"
            class="flex items-center justify-center w-16 h-16 rounded-full bg-white/20 backdrop-blur-md hover:bg-white/30 transition-colors duration-200"
            aria-label="Play webinar"
          >
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" class="translate-x-0.5">
              <path d="M6 4.5L19.5 12L6 19.5V4.5Z" fill="white" />
            </svg>
          </button>
        </div>
      </div>
    </div>
  </section>

  <ReviewsSection />
  <AppDownloadCtaSection />
  <Footer columns={footerColumns} />
</BaseLayout>
