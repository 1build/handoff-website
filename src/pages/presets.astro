---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/sections/Header.astro";
import Footer from "@/components/sections/Footer.astro";
import FaqSection from "@/components/sections/FaqSection.astro";
import PresetsCta from "@/components/sections/PresetsCta.astro";
import PresetsHero from "@/components/sections/PresetsHero.astro";
import PresetsValueProps from "@/components/sections/PresetsValueProps.astro";
import DetailRow from "@/components/sections/DetailRow.astro";

import { navItems, footerColumns } from "@/lib/navigation";

const faqItems = [
  {
    question: "How does Handoff's trained AI handle change orders?",
    answer: "Change orders are created directly in the platform, tracked automatically, and connected to the original estimate. You can see how changes affect the budget and timeline in real-time.",
  },
  {
    question: "Can my whole team use it?",
    answer: "Yes. You control who sees what through role-based permissions. Crew members see their schedules, project managers see project details, and you see everything.",
  },
  {
    question: "Will this work when I'm running multiple projects?",
    answer: "Yes. Handoff is built to help you scale. The more projects you run, the more valuable the automated coordination becomes. You can manage 3x more projects when you delegate admin work to your AI teammate.",
  },
  {
    question: 'How does "Crew Scheduling" work?',
    answer: "You set crew availability and project phases. Handoff's trained AI coordinates schedules, sends notifications, and alerts you to conflicts automatically.",
  },
  {
    question: "Can I customize it for how my business works?",
    answer: "You can set up approval rules, authorization levels, and workflows that match how you actually run projects.",
  },
];

const features = [
  {
    eyebrow: "AI-Powered Contract & Documentation",
    title: "No more chasing signed contracts",
    description: "Proposals, invoices, and payments integrate without question. Get signatures faster so you're ready to build.",
    bullets: [
      "Takeoffs, estimates, contracts, schedules, and invoices all connected",
      "Change orders tracked from request to payment",
      "Every project document in one place",
    ],
    placeholder: "TBD",
  },
  {
    eyebrow: "Intelligent Crew Scheduling",
    title: "Everyone knows where to be and when",
    description: "No more coordinating crews through texts. Have your AI Teammate set up schedules once, so everyone stays in the loop.",
    bullets: [
      "Everyone's schedule in one calendar",
      "Crew schedules and walkthroughs are coordinated automatically",
      "Everyone gets notified when schedules change",
      "Your phone stops buzzing with scheduling questions",
    ],
    placeholder: "TBD",
  },
  {
    eyebrow: "Real-Time Project Alerts",
    title: "Catch problems before they cost you",
    description: "While your competition is still figuring out their pricing, you're already in the client's inbox.",
    bullets: [
      "Know when approvals are stuck before clients ask",
      "Payment reminders so you stop chasing money",
      "Handle change orders before they cause delays",
      "Spot crew conflicts and timeline risks while you can still fix them",
    ],
    placeholder: "TBD",
  },
  {
    eyebrow: "Role-Based Permissions",
    title: "Keep your business information safe",
    description: "Keep control of your business as your team grows. You decide who can see what, so the right people have access to the right information without oversight.",
    bullets: [
      "Crews see their schedules, not your markup",
      "Project managers see what they need to manage project",
      "Only authorized team members see markup and margin data",
      "Set it once, never worry about information leaks",
    ],
    placeholder: "TBD",
  },
];
---

<BaseLayout title="Presets — Train an AI Teammate | Handoff">
  <Header navItems={navItems} />
  <PresetsHero />
<PresetsValueProps />

<!-- Detailed feature rows -->
  <section class="relative z-[2] px-4 pt-4">
    <div class="max-w-[1920px] mx-auto bg-white rounded-3xl border border-black/[0.04] py-16 lg:py-24 overflow-hidden flex flex-col gap-20 lg:gap-40">
      {features.map((f, i) => (
        <DetailRow
          eyebrow={f.eyebrow}
          title={f.title}
          description={f.description}
          bullets={f.bullets}
          reverse={i % 2 !== 0}
          visualType="desktop"
          placeholder={f.placeholder}
        />
      ))}
    </div>
  </section>
  <!-- FAQ -->
  <FaqSection items={faqItems} />

  <!-- CTA -->
  <PresetsCta />

  <Footer columns={footerColumns} />
</BaseLayout>
