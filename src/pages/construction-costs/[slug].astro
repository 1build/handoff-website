---

import Logo from "@/components/ui/Logo.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/sections/Header.astro";
import Footer from "@/components/sections/Footer.astro";
import { navItems, footerColumns } from "@/lib/navigation";
import { getPageSeo } from "@/lib/seo-pages";
import { calculators } from "@/lib/construction-costs-data";
import heroGlow from "@/assets/images/hero-glow-line.svg";
import contractorPhoto from "@/assets/images/cont-img.png";

export function getStaticPaths() {
  return calculators.map((calc) => ({
    params: { slug: calc.slug },
    props: { slug: calc.slug },
  }));
}

const { slug } = Astro.props;
const calculator = calculators.find((c) => c.slug === slug);

if (!calculator) {
  return Astro.redirect("/construction-costs");
}

const baseSeo = getPageSeo("/construction-costs");
const seo = {
  ...baseSeo,
  title: `${calculator.title} | Construction Cost Guide`,
  description:
    baseSeo.description ??
    `Get an estimated cost for ${calculator.title.toLowerCase()} using Handoff's construction cost tools.`,
};
---

<BaseLayout {...seo}>
  <Header navItems={navItems} />

  

 <section class="relative md:pt-0 pt-20">
    <!-- Glow line -->
    <div class="absolute -top-[24%] -left-[5%] -right-[54%] max-w-full -bottom-[24%] pointer-events-none z-[1]">
      <img src={heroGlow.src} alt="" class="w-full h-full block" />
    </div>
    <div class="relative mx-auto flex max-w-[1440px] flex-col items-center gap-10 md: pt-10 px-8 py-20 z-[12]">
      <!-- Badge -->
      <div
        class="rounded-full border border-brand-700 bg-white/8 px-3 py-1 backdrop-blur-lg"
      >
        <span class="font-mono text-sm font-semibold text-[#ABEFC6]"
          >Updated 2026</span
        >
      </div>

      <!-- Breadcrumb + Title -->
      <div class="flex max-w-3xl flex-col items-center gap-4 text-center">
        <div
          class="flex flex-col md:flex-row items-center gap-2 font-mono text-xs font-semibold uppercase tracking-widest text-text-on-brand-tertiary"
        >
          <a
            href="/construction-costs"
            class="transition-colors hover:text-white">Construction Costs</a
          >
          <span>/</span>
          <span>Average Cost to install electric cooktop in the US</span>
        </div>
        <h1
          class="font-display text-4xl md:text-5xl font-medium leading-tight tracking-tight text-white"
          style="font-variation-settings: 'opsz' 14, 'wdth' 100"
        >
          Average cost to install electric cooktop in the US
        </h1>
      </div>

      <!-- Search bar -->
      <div class="flex w-full max-w-[896px] flex-col sm:flex-row items-stretch gap-3 sm:gap-4">
        <div
          class="flex flex-col md:flex-row flex-1 overflow-visible rounded-xl border border-border-primary bg-white"
        >
          <!-- Project Type -->
          <div
            class="relative flex flex-1 flex-col border-r border-border-primary px-6 py-4"
            id="detail-project-wrap"
          >
            <label
              class="mb-1 flex items-center gap-1 text-xs font-medium text-text-quaternary"
            >
              Project Type
              <svg class="h-4 w-4" viewBox="0 0 16 16" fill="none">
                <circle cx="8" cy="8" r="6.5" stroke="currentColor"></circle>
                <path
                  d="M8 7v4"
                  stroke="currentColor"
                  stroke-linecap="round"></path>
                <circle cx="8" cy="5.5" r=".5" fill="currentColor"></circle>
              </svg>
            </label>
            <button
              type="button"
              id="detail-project-trigger"
              class="flex items-center justify-between bg-white py-2 text-left w-full"
              aria-label="Change project type"
              aria-expanded="false"
              aria-haspopup="listbox"
            >
              <span id="detail-project-display" class="text-base sm:text-lg font-medium text-text-primary">
                Install Vinyl Siding
              </span>
              <svg
                class="h-5 w-5 text-text-quaternary"
                viewBox="0 0 24 24"
                fill="none"
              >
                <path
                  d="M6 9l6 6 6-6"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"></path>
              </svg>
            </button>
            <div
              id="detail-project-panel"
              class="absolute left-6 top-full mt-1 w-[260px] max-h-[260px] overflow-y-auto bg-white border border-border-primary rounded-xl shadow-lg py-2 z-20 hidden"
              role="listbox"
              aria-label="Select project type"
            >
              {[
                "Install Vinyl Siding",
                "Install Fiber Cement Siding",
                "Replace Wood Siding",
                "Install Asphalt Shingles",
                "Replace Roof",
                "Install Metal Roofing",
              ].map((label) => (
                <button
                  type="button"
                  class="detail-project-option w-full text-left px-4 py-2 text-sm text-text-secondary hover:bg-neutral-50"
                  data-label={label}
                  role="option"
                >
                  {label}
                </button>
              ))}
            </div>
          </div>
          <!-- Location -->
          <div class="relative flex flex-1 flex-col px-6 py-4" id="detail-location-wrap">
            <label
              class="mb-1 flex items-center gap-1 text-xs font-medium text-text-quaternary"
            >
              Location
              <svg class="h-4 w-4" viewBox="0 0 16 16" fill="none">
                <circle cx="8" cy="8" r="6.5" stroke="currentColor"></circle>
                <path
                  d="M8 7v4"
                  stroke="currentColor"
                  stroke-linecap="round"></path>
                <circle cx="8" cy="5.5" r=".5" fill="currentColor"></circle>
              </svg>
            </label>
            <button
              type="button"
              id="detail-location-trigger"
              class="flex items-center justify-between bg-white py-2 text-left"
              aria-label="Change location"
              aria-expanded="false"
              aria-haspopup="listbox"
            >
              <span id="detail-location-display" class="text-base sm:text-lg font-medium text-text-primary">
                Orlando, FL
              </span>
              <svg
                class="h-5 w-5 text-text-quaternary"
                viewBox="0 0 24 24"
                fill="none"
              >
                <path
                  d="M6 9l6 6 6-6"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"></path>
              </svg>
            </button>
            <div
              id="detail-location-panel"
              class="absolute right-6 top-full mt-1 w-[220px] max-h-[260px] overflow-y-auto bg-white border border-border-primary rounded-xl shadow-lg py-2 z-20 hidden"
              role="listbox"
              aria-label="Select location"
            >
              {["Orlando, FL", "Oregon City, OR", "Orange, CA", "Orlinda, CA", "Oroville, CA"].map((loc) => (
                <button
                  type="button"
                  class="detail-location-option w-full text-left px-4 py-2 text-sm text-text-secondary hover:bg-neutral-50"
                  data-location={loc}
                  role="option"
                >
                  {loc}
                </button>
              ))}
            </div>
          </div>
        </div>
        <!-- Arrow button -->
        <button
          class="flex h-12 sm:h-20 w-full sm:w-20 shrink-0 items-center justify-center rounded-xl bg-brand-accent transition-colors hover:bg-brand-500"
          aria-label="Search"
        >
          <svg class="h-8 w-8 text-white" viewBox="0 0 24 24" fill="none">
            <path
              d="M5 12h14M12 5l7 7-7 7"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </button>
      </div>
    </div>
  </section>

  <div class="max-w-[1920px] mx-auto bg-white">
    <div class="mx-auto max-w-[1440px] px-4 sm:px-8 py-12 sm:py-16">
      <div class="mx-auto flex max-w-[768px] flex-col gap-8 sm:gap-10">

        <!-- ─── CALCULATOR CARD ─── -->
        <div class="overflow-hidden rounded-xl border border-border-primary">

          <!-- Estimate breakdown table -->
          <div class="flex flex-col gap-6 sm:gap-8 px-4 sm:px-10 pb-6 sm:pb-8 pt-6 sm:pt-10">

            <!-- Title + info alert -->
            <div class="flex flex-col gap-2">
              <h2 class="font-display text-3xl font-semibold text-text-primary">
                Estimate breakdown
              </h2>
              <div class="flex items-center gap-2 py-1">
                <svg
                  class="h-5 w-5 shrink-0 text-text-tertiary"
                  viewBox="0 0 20 20"
                  fill="currentColor"
                >
                  <path
                    fill-rule="evenodd"
                    d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a.75.75 0 000 1.5h.253a.25.25 0 01.244.304l-.459 2.066A1.75 1.75 0 0010.747 15H11a.75.75 0 000-1.5h-.253a.25.25 0 01-.244-.304l.459-2.066A1.75 1.75 0 009.253 9H9z"
                    clip-rule="evenodd"></path>
                </svg>
                <p class="text-sm font-medium text-text-primary">
                  Add all required items to calculate the estimated cost for the
                  completed work.
                </p>
              </div>
            </div>

            <!-- MATERIALS GROUP -->
            <div class="flex flex-col">
              <!-- Group header row -->
              <div
                class="flex items-center flex-col md:flex-row gap-2 border-b border-border-primary py-4"
                id="materials-header"
              >
                <span
                  class="flex h-5 w-5 shrink-0 items-center justify-center rounded bg-brand-accent cursor-pointer"
                  id="materials-checkbox"
                >
                  <svg
                    class="h-3 w-3 text-white"
                    viewBox="0 0 12 12"
                    fill="none"
                  >
                    <path
                      d="M2 6l3 3 5-5"
                      stroke="currentColor"
                      stroke-width="1.5"
                      stroke-linecap="round"
                      stroke-linejoin="round"></path>
                  </svg>
                </span>
                <span class="flex-1 text-xl font-semibold text-text-primary"
                  >Materials</span
                >
                <span
                  class="text-lg font-semibold text-text-primary"
                  id="materials-total">$250.00</span
                >
              </div>
              <!-- Sheet Vinyl Material row -->
              <div
                class="flex items-center flex-col md:flex-row gap-2 border-b border-border-primary py-4"
                id="mat1-row"
              >
                <div class="flex flex-1 items-center gap-2">
                  <span
                    class="flex h-5 w-5 shrink-0 items-center justify-center rounded bg-brand-accent cursor-pointer"
                    id="mat1-checkbox"
                  >
                    <svg
                      class="h-3 w-3 text-white"
                      viewBox="0 0 12 12"
                      fill="none"
                    >
                      <path
                        d="M2 6l3 3 5-5"
                        stroke="currentColor"
                        stroke-width="1.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"></path>
                    </svg>
                  </span>
                  <span class="whitespace-nowrap text-base font-medium text-text-primary"
                    >Sheet Vinyl Material</span
                  >
                  <svg
                    class="h-4 w-4 shrink-0 text-text-quaternary"
                    viewBox="0 0 16 16"
                    fill="none"
                  >
                    <circle cx="8" cy="8" r="6.5" stroke="currentColor"
                    ></circle>
                    <path
                      d="M8 7v4"
                      stroke="currentColor"
                      stroke-linecap="round"></path>
                    <circle cx="8" cy="5.5" r=".5" fill="currentColor"
                    ></circle>
                  </svg>
                </div>
                <div
                  class="flex w-[150px] shrink-0 items-baseline gap-1 whitespace-nowrap text-base font-medium"
                >
                  <span class="text-text-primary">$12.00</span>
                  <span class="text-text-quaternary">×</span>
                  <span class="text-text-primary" id="size-display-1">20 SF</span>
                </div>
                <span
                  class="w-[150px] shrink-0 text-center md:text-right text-base font-medium text-text-primary"
                  id="mat1-total">$240.00</span
                >
              </div>
              <!-- Installation Supplies row -->
              <div
                class="flex items-center flex-col md:flex-row gap-2 border-b border-border-primary py-4"
                id="mat2-row"
              >
                <div class="flex flex-1 items-center gap-2">
                  <span
                    class="flex h-5 w-5 shrink-0 items-center justify-center rounded bg-brand-accent cursor-pointer"
                    id="mat2-checkbox"
                  >
                    <svg
                      class="h-3 w-3 text-white"
                      viewBox="0 0 12 12"
                      fill="none"
                    >
                      <path
                        d="M2 6l3 3 5-5"
                        stroke="currentColor"
                        stroke-width="1.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"></path>
                    </svg>
                  </span>
                  <span class="whitespace-nowrap text-base font-medium text-text-primary"
                    >Installation Supplies</span
                  >
                  <svg
                    class="h-4 w-4 shrink-0 text-text-quaternary"
                    viewBox="0 0 16 16"
                    fill="none"
                  >
                    <circle cx="8" cy="8" r="6.5" stroke="currentColor"
                    ></circle>
                    <path
                      d="M8 7v4"
                      stroke="currentColor"
                      stroke-linecap="round"></path>
                    <circle cx="8" cy="5.5" r=".5" fill="currentColor"
                    ></circle>
                  </svg>
                </div>
                <div
                  class="flex w-[150px] shrink-0 items-baseline gap-1 whitespace-nowrap text-base font-medium"
                >
                  <span class="text-text-primary">$0.50</span>
                  <span class="text-text-quaternary">×</span>
                  <span class="text-text-primary" id="size-display-2">20 SF</span>
                </div>
                <span
                  class="w-[150px] shrink-0 text-center md:text-right text-base font-medium text-text-primary"
                  id="mat2-total">$10.00</span
                >
              </div>
            </div>

            <!-- LABOR GROUP -->
            <div class="flex flex-col">
              <!-- Group header -->
              <div
                class="flex items-center flex-col md:flex-row gap-2 border-b border-border-primary py-4"
                id="labor-header"
              >
                <!-- Indeterminate checkbox (minus) -->
                <span
                  class="flex h-5 w-5 shrink-0 items-center justify-center rounded bg-brand-accent cursor-pointer"
                  id="labor-checkbox"
                >
                  <svg
                    class="h-3 w-3 text-white"
                    viewBox="0 0 12 12"
                    fill="none"
                  >
                    <path
                      d="M3 6h6"
                      stroke="currentColor"
                      stroke-width="1.5"
                      stroke-linecap="round"></path>
                  </svg>
                </span>
                <span class="flex-1 text-xl font-semibold text-text-primary"
                  >Labor</span
                >
                <span
                  class="text-lg font-semibold text-text-primary"
                  id="labor-total">$2,000.00</span
                >
              </div>
              <!-- Installation Labor row -->
              <div
                class="flex items-center flex-col md:flex-row gap-2 border-b border-border-primary py-4"
                id="labor-main-row"
              >
                <div class="flex flex-1 items-center gap-2">
                  <span
                    class="flex h-5 w-5 shrink-0 items-center justify-center rounded bg-brand-accent cursor-pointer"
                    id="labor-main-checkbox"
                  >
                    <svg
                      class="h-3 w-3 text-white"
                      viewBox="0 0 12 12"
                      fill="none"
                    >
                      <path
                        d="M2 6l3 3 5-5"
                        stroke="currentColor"
                        stroke-width="1.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"></path>
                    </svg>
                  </span>
                  <span class="whitespace-nowrap text-lg font-medium text-text-primary"
                    >Installation Labor</span
                  >
                  <svg
                    class="h-4 w-4 shrink-0 text-text-quaternary"
                    viewBox="0 0 16 16"
                    fill="none"
                  >
                    <circle cx="8" cy="8" r="6.5" stroke="currentColor"
                    ></circle>
                    <path
                      d="M8 7v4"
                      stroke="currentColor"
                      stroke-linecap="round"></path>
                    <circle cx="8" cy="5.5" r=".5" fill="currentColor"
                    ></circle>
                  </svg>
                </div>
                <div
                  class="flex w-[150px] shrink-0 items-baseline gap-1 whitespace-nowrap text-base font-medium"
                >
                  <span class="text-text-primary">$50.00</span>
                  <span class="text-text-quaternary">×</span>
                  <span class="text-text-primary">40 HR</span>
                </div>
                <span
                  class="w-[150px] shrink-0 text-center md:text-right text-base font-medium text-text-primary"
                  id="labor-main-total"
                  >$2,000.00</span
                >
              </div>
              <!-- Floor Removal row (optional) -->
              <div
                class="flex items-center flex-col md:flex-row gap-2 border-b border-border-primary py-4"
                id="floor-row"
              >
                <div class="flex flex-1 items-center gap-2">
                  <span
                    class="flex h-5 w-5 shrink-0 items-center justify-center rounded bg-brand-accent cursor-pointer"
                    id="floor-checkbox"
                  >
                    <svg
                      class="h-3 w-3 text-white opacity-0"
                      viewBox="0 0 12 12"
                      fill="none"
                    >
                      <path
                        d="M2 6l3 3 5-5"
                        stroke="currentColor"
                        stroke-width="1.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"></path>
                    </svg>
                  </span>
                  <span class="whitespace-nowrap text-base font-medium text-text-primary" id="floor-label">
                    Floor Removal
                  </span>
                  <svg
                    class="h-4 w-4 shrink-0 text-text-quaternary"
                    viewBox="0 0 16 16"
                    fill="none"
                  >
                    <circle cx="8" cy="8" r="6.5" stroke="currentColor"
                    ></circle>
                    <path
                      d="M8 7v4"
                      stroke="currentColor"
                      stroke-linecap="round"></path>
                    <circle cx="8" cy="5.5" r=".5" fill="currentColor"
                    ></circle>
                  </svg>
                </div>
                <div
                  class="flex w-[150px] shrink-0 items-baseline gap-1 whitespace-nowrap text-base font-medium text-text-primary"
                  id="floor-qty"
                >
                  <span>$50.00</span>
                  <span class="no-underline">×</span>
                  <span>10 HR</span>
                </div>
                <span
                  class="w-[150px] shrink-0 text-center md:text-right text-base font-medium text-text-primary"
                  id="labor2-total"
                  >$0.00</span
                >
              </div>
            </div>

            <!-- Summary totals -->
            <div class="flex w-full md:w-[364px] flex-col gap-4 self-end">
              <div class="flex items-center gap-3">
                <span class="flex-1 text-base font-medium text-text-quaternary"
                  >Costs:</span
                >
                <span
                  class="text-base font-medium text-text-primary"
                  id="costs-total">$2,815.00</span
                >
              </div>
              <div class="flex items-center gap-3">
                <span class="flex-1 text-base font-medium text-text-quaternary"
                  >Markup (<span id="markup-pct-display">20</span>%):</span
                >
                <span
                  class="text-base font-medium text-text-primary"
                  id="markup-amount">$563.00</span
                >
              </div>
            </div>
          </div>

          <!-- Inputs panel (gray bg) -->
          <div class="flex flex-col gap-2 md:gap-6 bg-bg-secondary p-5 md:p-10">

            <!-- Big result numbers -->
            <div class="flex gap-6 flex-col md:flex-row">
              <div class="flex-1 flex flex-col items-end gap-2">
                <p class="text-base font-medium text-text-tertiary">
                  Contractor markup:
                </p>
                <p
                  class="font-display text-4xl font-medium tracking-tight text-brand-accent"
                  id="markup-big"
                  style="font-variation-settings: 'opsz' 14, 'wdth' 100"
                >
                  $563.00
                </p>
              </div>
              <div class="flex-1 flex flex-col items-end gap-2">
                <p class="text-base font-medium text-text-tertiary">
                  Avg. cost in Orlando, FL
                </p>
                <p
                  class="font-display text-4xl font-semibold tracking-tight text-text-primary"
                  id="avg-cost-big"
                >
                  $3,378.00
                </p>
                <div class=" flex items-center gap-3">
                  <span class="text-sm font-medium text-text-quaternary"
                    >Avg. cost per SF:</span
                  >
                  <span
                    class="text-base font-medium text-text-primary"
                    id="cost-per-sf">$168.90</span
                  >
                </div>
              </div>
            </div>

            <hr class="border-border-primary" />

            <!-- Input controls row -->
            <div class="flex gap-6 flex-col md:flex-row">
              <!-- Finish level -->
              <div class="flex flex-1 flex-col gap-2">
                <label
                  class="flex items-center gap-1 text-sm font-medium text-text-primary"
                >
                  Finish level
                  <svg
                    class="h-4 w-4 text-text-quaternary"
                    viewBox="0 0 16 16"
                    fill="none"
                  >
                    <circle cx="8" cy="8" r="6.5" stroke="currentColor"
                    ></circle>
                    <path
                      d="M8 7v4"
                      stroke="currentColor"
                      stroke-linecap="round"></path>
                    <circle cx="8" cy="5.5" r=".5" fill="currentColor"
                    ></circle>
                  </svg>
                </label>
                <div class="relative">
                  <select
                    id="finish-level"
                    class="h-10 w-full appearance-none rounded-lg border border-border-primary bg-white pl-4 pr-9 text-base font-medium text-text-primary focus:outline-none focus:ring-2 focus:ring-brand-accent"
                  >
                    <option>Economy</option>
                    <option selected>Mid-grade</option>
                    <option>Premium</option>
                    <option>Luxury</option>
                  </select>
                  <svg
                    class="pointer-events-none absolute right-3 top-1/2 h-5 w-5 -translate-y-1/2 text-text-quaternary"
                    viewBox="0 0 24 24"
                    fill="none"
                  >
                    <path
                      d="M6 9l6 6 6-6"
                      stroke="currentColor"
                      stroke-width="1.5"
                      stroke-linecap="round"
                      stroke-linejoin="round"></path>
                  </svg>
                </div>
              </div>
              <!-- Project size -->
              <div class="flex flex-1 flex-col gap-2">
                <label
                  class="flex items-center gap-1 text-sm font-medium text-text-primary"
                >
                  Project size
                  <svg
                    class="h-4 w-4 text-text-quaternary"
                    viewBox="0 0 16 16"
                    fill="none"
                  >
                    <circle cx="8" cy="8" r="6.5" stroke="currentColor"
                    ></circle>
                    <path
                      d="M8 7v4"
                      stroke="currentColor"
                      stroke-linecap="round"></path>
                    <circle cx="8" cy="5.5" r=".5" fill="currentColor"
                    ></circle>
                  </svg>
                </label>
                <div class="relative flex items-center">
                  <input
                    id="project-size"
                    type="number"
                    value="20"
                    min="1"
                    class="h-10 w-full rounded-lg border border-border-primary bg-white pl-4 pr-14 text-base font-medium text-text-primary focus:outline-none focus:ring-2 focus:ring-brand-accent"
                  />
                  <span
                    class="pointer-events-none absolute right-4 border-l border-border-primary pl-3 text-sm font-medium text-text-primary"
                    >SF</span
                  >
                </div>
              </div>
              <!-- Contractor markup % -->
              <div class="flex flex-1 flex-col gap-2">
                <label
                  class="flex items-center gap-1 text-sm font-medium text-text-primary"
                >
                  Contractor markup:
                  <svg
                    class="h-4 w-4 text-text-quaternary"
                    viewBox="0 0 16 16"
                    fill="none"
                  >
                    <circle cx="8" cy="8" r="6.5" stroke="currentColor"
                    ></circle>
                    <path
                      d="M8 7v4"
                      stroke="currentColor"
                      stroke-linecap="round"></path>
                    <circle cx="8" cy="5.5" r=".5" fill="currentColor"
                    ></circle>
