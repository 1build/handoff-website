<script>
  function initDetailDropdowns() {
    // Guard against duplicate listener attachment (e.g. DOMContentLoaded + astro:page-load)
    if (document.body.dataset.costCalcDetailInit === "1") return;
    document.body.dataset.costCalcDetailInit = "1";

    // Location dropdown
    const locTrigger = document.getElementById("detail-location-trigger");
    const locPanel = document.getElementById("detail-location-panel");
    const locDisplay = document.getElementById("detail-location-display");
    const locOptions = document.querySelectorAll(".detail-location-option");

    if (locTrigger && locPanel && locDisplay) {
      locTrigger.addEventListener("click", (e) => {
        e.stopPropagation();
        locPanel.classList.toggle("hidden");
        const open = !locPanel.classList.contains("hidden");
        locTrigger.setAttribute("aria-expanded", String(open));
      });

      locOptions.forEach((btn) => {
        btn.addEventListener("click", (e) => {
          e.stopPropagation();
          const loc = (btn as HTMLElement).dataset.location ?? "";
          if (loc) {
            locDisplay.textContent = loc;
          }
          locPanel.classList.add("hidden");
          locTrigger.setAttribute("aria-expanded", "false");
        });
      });
    }

    // Project type dropdown
    const projTrigger = document.getElementById("detail-project-trigger");
    const projPanel = document.getElementById("detail-project-panel");
    const projDisplay = document.getElementById("detail-project-display");
    const projOptions = document.querySelectorAll(".detail-project-option");

    if (projTrigger && projPanel && projDisplay) {
      projTrigger.addEventListener("click", (e) => {
        e.stopPropagation();
        projPanel.classList.toggle("hidden");
        const open = !projPanel.classList.contains("hidden");
        projTrigger.setAttribute("aria-expanded", String(open));
      });

      projOptions.forEach((btn) => {
        btn.addEventListener("click", (e) => {
          e.stopPropagation();
          const label = (btn as HTMLElement).dataset.label ?? "";
          if (label) {
            projDisplay.textContent = label;
          }
          projPanel.classList.add("hidden");
          projTrigger.setAttribute("aria-expanded", "false");
        });
      });
    }

    document.addEventListener("click", () => {
      if (locPanel && locTrigger && !locPanel.classList.contains("hidden")) {
        locPanel.classList.add("hidden");
        locTrigger.setAttribute("aria-expanded", "false");
      }
      if (projPanel && projTrigger && !projPanel.classList.contains("hidden")) {
        projPanel.classList.add("hidden");
        projTrigger.setAttribute("aria-expanded", "false");
      }
    });
    locPanel?.addEventListener("click", (e) => e.stopPropagation());
    projPanel?.addEventListener("click", (e) => e.stopPropagation());
  }

  function initEstimateCalculator() {
    if (document.body.dataset.costCalcEstimateInit === "1") return;
    document.body.dataset.costCalcEstimateInit = "1";

    const sizeInput = document.getElementById("project-size");
    const markupInput = document.getElementById("markup-pct");
    const finishSelect = document.getElementById("finish-level");

    const sizeDisplay1 = document.getElementById("size-display-1");
    const sizeDisplay2 = document.getElementById("size-display-2");

    const mat1TotalEl = document.getElementById("mat1-total");
    const mat2TotalEl = document.getElementById("mat2-total");
    const materialsTotalEl = document.getElementById("materials-total");
    const laborTotalEl = document.getElementById("labor-total");
    const laborMainTotalEl = document.getElementById("labor-main-total");
    const laborFloorTotalEl = document.getElementById("labor2-total");
    const costsTotalEl = document.getElementById("costs-total");

    const markupPctDisplay = document.getElementById("markup-pct-display");
    const markupAmountEl = document.getElementById("markup-amount");
    const markupBigEl = document.getElementById("markup-big");
    const avgCostBigEl = document.getElementById("avg-cost-big");
    const costPerSfEl = document.getElementById("cost-per-sf");

    if (
      !(sizeInput instanceof HTMLInputElement) ||
      !(markupInput instanceof HTMLInputElement) ||
      !(finishSelect instanceof HTMLSelectElement) ||
      !sizeDisplay1 ||
      !sizeDisplay2 ||
      !mat1TotalEl ||
      !mat2TotalEl ||
      !materialsTotalEl ||
      !laborTotalEl ||
      !laborMainTotalEl ||
      !laborFloorTotalEl ||
      !costsTotalEl ||
      !markupPctDisplay ||
      !markupAmountEl ||
      !markupBigEl ||
      !avgCostBigEl ||
      !costPerSfEl
    ) {
      return;
    }

    const MAT1_PRICE_PER_SF = 12; // Sheet vinyl material
    const MAT2_PRICE_PER_SF = 0.5; // Installation supplies
    const LABOR_TOTAL_BASE = 2000; // From 50 × 40 HR
    const FLOOR_REMOVAL_BASE = 500; // From 50 × 10 HR
    const EXTRA_FIXED_COST = 565; // Matches initial Costs total at size=20
    const BASE_SIZE = 20;

    const currency = new Intl.NumberFormat("en-US", {
      style: "currency",
      currency: "USD",
      minimumFractionDigits: 2,
      maximumFractionDigits: 2,
    });

    function formatCurrency(value) {
      return currency.format(value);
    }

    const floorCheckbox = document.getElementById("floor-checkbox");
    const floorRow = document.getElementById("floor-row");

    const mat1Row = document.getElementById("mat1-row");
    const mat2Row = document.getElementById("mat2-row");
    const laborMainRow = document.getElementById("labor-main-row");

    const mat1Checkbox = document.getElementById("mat1-checkbox");
    const mat2Checkbox = document.getElementById("mat2-checkbox");
    const laborMainCheckbox = document.getElementById("labor-main-checkbox");

    const materialsHeader = document.getElementById("materials-header");
    const materialsCheckbox = document.getElementById("materials-checkbox");
    const laborHeader = document.getElementById("labor-header");
    const laborCheckbox = document.getElementById("labor-checkbox");

    let mat1Included = true;
    let mat2Included = true;
    let laborMainIncluded = true;
    let floorIncluded = false;

    function getFinishMultiplier() {
      const value = finishSelect.value;
      switch (value) {
        case "Economy":
          return 0.9;
        case "Premium":
          return 1.15;
        case "Luxury":
          return 1.3;
        default:
          return 1; // Mid-grade
      }
    }

    function recalc() {
      let size = parseFloat(sizeInput.value);
      if (!Number.isFinite(size) || size <= 0) size = BASE_SIZE;

      // Update size displays (e.g., "20 SF")
      const sizeLabel = `${size} SF`;
      sizeDisplay1.textContent = sizeLabel;
      sizeDisplay2.textContent = sizeLabel;

      // Base material totals, scaled by project size
      const mat1Base = MAT1_PRICE_PER_SF * size;
      const mat2Base = MAT2_PRICE_PER_SF * size;

      const finishMultiplier = getFinishMultiplier();

      // Apply finish multiplier to materials
      const mat1AdjBase = mat1Base * finishMultiplier;
      const mat2AdjBase = mat2Base * finishMultiplier;

      const mat1Adj = mat1Included ? mat1AdjBase : 0;
      const mat2Adj = mat2Included ? mat2AdjBase : 0;
      const materialsTotal = mat1Adj + mat2Adj;

      // Labor + optional floor removal + fixed extra costs
      const laborMainAdjBase = LABOR_TOTAL_BASE * finishMultiplier;
      const laborMainAdj = laborMainIncluded ? laborMainAdjBase : 0;
      const floorAdj = floorIncluded ? FLOOR_REMOVAL_BASE * finishMultiplier : 0;
      const laborTotal = laborMainAdj + floorAdj;
      const extraCost = EXTRA_FIXED_COST * finishMultiplier;

      const costsTotal = materialsTotal + laborTotal + extraCost;

      // Markup
      let markupPct = parseFloat(markupInput.value);
      if (!Number.isFinite(markupPct) || markupPct < 0) markupPct = 0;
      if (markupPct > 100) markupPct = 100;
      markupInput.value = String(markupPct);
      markupPctDisplay.textContent = String(markupPct);

      const markupAmount = (costsTotal * markupPct) / 100;
      const totalWithMarkup = costsTotal + markupAmount;
      const costPerSf = size > 0 ? totalWithMarkup / size : 0;

      // Write numbers back to the DOM
      mat1TotalEl.textContent = formatCurrency(mat1Adj);
      mat2TotalEl.textContent = formatCurrency(mat2Adj);
      materialsTotalEl.textContent = formatCurrency(materialsTotal);
      laborMainTotalEl.textContent = formatCurrency(laborMainAdj);
      laborFloorTotalEl.textContent = formatCurrency(floorAdj);
      laborTotalEl.textContent = formatCurrency(laborTotal);
      costsTotalEl.textContent = formatCurrency(costsTotal);

      markupAmountEl.textContent = formatCurrency(markupAmount);
      markupBigEl.textContent = formatCurrency(markupAmount);
      avgCostBigEl.textContent = formatCurrency(totalWithMarkup);
      costPerSfEl.textContent = formatCurrency(costPerSf);

      updateCheckboxVisuals();
    }

    function updateCheckboxVisuals() {
      function applyState(checkboxEl, included) {
        if (!checkboxEl) return;
        checkboxEl.classList.toggle("bg-brand-accent", included);
        checkboxEl.classList.toggle("border", !included);
        checkboxEl.classList.toggle("border-border-primary", !included);
        const icon = checkboxEl.querySelector("svg");
        if (icon) {
          icon.classList.toggle("opacity-0", !included);
        }
      }

      function applyRow(rowEl, included) {
        if (!rowEl) return;
        rowEl.classList.toggle("opacity-60", !included);
      }

      applyState(mat1Checkbox, mat1Included);
      applyRow(mat1Row, mat1Included);

      applyState(mat2Checkbox, mat2Included);
      applyRow(mat2Row, mat2Included);

      applyState(laborMainCheckbox, laborMainIncluded);
      applyRow(laborMainRow, laborMainIncluded);

      if (floorCheckbox) {
        applyState(floorCheckbox, floorIncluded);
      }
      applyRow(floorRow, floorIncluded);

      // Group checkbox states
      const materialsAll = mat1Included && mat2Included;
      const materialsAny = mat1Included || mat2Included;
      if (materialsCheckbox) {
        materialsCheckbox.classList.toggle("bg-brand-accent", materialsAll);
        materialsCheckbox.classList.toggle("border", !materialsAll);
        materialsCheckbox.classList.toggle("border-border-primary", !materialsAll);
        const icon = materialsCheckbox.querySelector("svg");
        if (icon) {
          icon.classList.toggle("opacity-0", !materialsAll);
        }
      }
      const laborAll = laborMainIncluded && floorIncluded;
      const laborAny = laborMainIncluded || floorIncluded;
      if (laborCheckbox) {
        laborCheckbox.classList.toggle("bg-brand-accent", laborAll);
        laborCheckbox.classList.toggle("border", !laborAll);
        laborCheckbox.classList.toggle("border-border-primary", !laborAll);
        const icon = laborCheckbox.querySelector("svg");
        if (icon) {
          // Show minus when some but not all, hide when none, show full when all
          icon.classList.toggle("opacity-0", !laborAny);
        }
      }
    }

    sizeInput.addEventListener("input", recalc);
    markupInput.addEventListener("input", recalc);
    finishSelect.addEventListener("change", recalc);

    function attachToggle(rowEl, getIncluded, setIncluded) {
      if (!rowEl) return;
      rowEl.addEventListener("click", () => {
        const next = !getIncluded();
        setIncluded(next);
        recalc();
      });
    }

    attachToggle(mat1Row, () => mat1Included, (v) => (mat1Included = v));
    attachToggle(mat2Row, () => mat2Included, (v) => (mat2Included = v));
    attachToggle(laborMainRow, () => laborMainIncluded, (v) => (laborMainIncluded = v));
    attachToggle(floorRow, () => floorIncluded, (v) => (floorIncluded = v));

    // Group header toggles: Materials (all/none), Labor (all/none)
    if (materialsHeader) {
      materialsHeader.addEventListener("click", (event) => {
        const next = !(mat1Included && mat2Included);
        mat1Included = next;
        mat2Included = next;
        recalc();
      });
    }

    if (laborHeader) {
      laborHeader.addEventListener("click", () => {
        const next = !(laborMainIncluded && floorIncluded);
        laborMainIncluded = next;
        floorIncluded = next;
        recalc();
      });
    }

    recalc();
  }

  function initCostCalcDetailPage() {
    initDetailDropdowns();
    initEstimateCalculator();
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initCostCalcDetailPage);
  } else {
    initCostCalcDetailPage();
  }
  document.addEventListener("astro:page-load", initCostCalcDetailPage);
</script>

