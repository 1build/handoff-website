---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/sections/Header.astro";
import HeroSection from "@/components/sections/HeroSectionCRM.astro";
import FeaturesSection from "@/components/sections/FeaturesSection.astro";
import DetailedFeatures from "@/components/sections/DetailedFeatures.astro";
import BuiltForContractorsSection from "@/components/sections/BuiltForContractorsSection.astro";
import OverviewSection from "@/components/sections/OverviewSection.astro";
import FaqSection from "@/components/sections/FaqSection.astro";
import SolutionsCta from "@/components/sections/SolutionsCta.astro";
import Footer from "@/components/sections/Footer.astro";
import { navItems, footerColumns, faqItems } from "@/lib/navigation";
import { getPageSeo } from "@/lib/seo-pages";

const seo = getPageSeo(Astro.url.pathname);
---

<BaseLayout {...seo}>
  <Header navItems={navItems} />
  <HeroSection />
  <FeaturesSection />
  <DetailedFeatures />
  <BuiltForContractorsSection />
  <!-- <OverviewSection /> -->
  <FaqSection items={faqItems} />
  <SolutionsCta />
  <Footer columns={footerColumns} />
</BaseLayout>

<script>
  import { initScrollAnimations } from "@/lib/animations";
  import { initHeroScroll } from "@/lib/heroScroll";
  initScrollAnimations();
  initHeroScroll();
</script>
