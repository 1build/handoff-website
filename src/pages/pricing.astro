---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/sections/Header.astro";
import PricingSection from "@/components/sections/PricingSection.astro";
import PricingFeatureStrip from "@/components/sections/PricingFeatureStrip.astro";
import PricingCompareTable from "@/components/sections/PricingCompareTable.astro";
import PricingTestimonials from "@/components/sections/PricingTestimonials.astro";
import PricingFaqSection from "@/components/sections/PricingFaqSection.astro";
import CtaSection from "@/components/sections/CtaSection.astro";
import Footer from "@/components/sections/Footer.astro";
import { navItems, footerColumns } from "@/lib/navigation";
---

<BaseLayout title="Pricing — Handoff">
  <Header navItems={navItems} />
  <PricingSection />
  <PricingFeatureStrip />
  <PricingCompareTable />
  <PricingTestimonials />
  <PricingFaqSection />
  <CtaSection />
  <Footer columns={footerColumns} />
</BaseLayout>
