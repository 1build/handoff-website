---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getPageSeo } from "@/lib/seo-pages";
import Header from "@/components/sections/Header.astro";
import Footer from "@/components/sections/Footer.astro";
import Logo from "@/components/ui/Logo.astro";
import ReviewsSection from "@/components/sections/ReviewsSection.astro";
import FaqSection from "@/components/sections/FaqSection.astro";
import markate from "@/assets/images/markate.png";

const faqItems = [
  {
    question: "How accurate are AI-generated estimates?",
    answer: "Handoff learns from your past projects and pricing rules, so estimates match how you actually build and price work. The more you use it, the smarter it gets.",
  },
  {
    question: "Can I customize proposals and templates?",
    answer: "Yes. Every proposal uses your branding, your pricing structure, and your preferred layout. You control what clients see.",
  },
  {
    question: "What if my pricing is complex?",
    answer: "Handoff handles multi-level markups, separate labor and material rates, room-by-room breakdowns, and custom pricing rules. If you can price it, Handoff can learn it.",
  },
  {
    question: 'How long does setup take?',
    answer: "Most contractors are up and running in under an hour. Import your pricing, connect your calendar, and start estimating.",
  },
  {
    question: "Does this replace my estimators?",
    answer: "No — it makes them faster. Handoff handles the repetitive work so your team can focus on accuracy, client relationships, and winning more projects.",
  },
];

const features = [
  {
    label: "AI Estimating",
    tooltip: "Whether the platform supports automated, AI-powered estimating instead of only manual estimate entry.",
    handoff: "check",
    jobtread: "Manual",
  },
  {
    label: "Made for Remodelers",
    tooltip: "How well the platform is aligned with residential remodelers versus broader home services.",
    handoff: "check",
    jobtread: "Home Services",
  },
  {
    label: "Integration with Suppliers (Lowes, etc.)",
    tooltip: "Built-in connections to major suppliers so material pricing stays accurate without manual updates.",
    handoff: "check",
    jobtread: "x",
  },
  {
    label: "AI Features",
    tooltip: "Depth of AI-native capabilities for estimating and workflows.",
    handoff: "AI-Native",
    jobtread: "Limited AI",
  },
  {
    label: "ACH Invoice Fee",
    tooltip: "Fee charged when clients pay invoices via ACH bank transfer.",
    handoff: "1% ($10 Max)",
    jobtread: "x",
  },
  {
    label: "Credit Card Invoice Fee",
    tooltip: "Fee charged when clients pay invoices via credit card.",
    handoff: "3.35%",
    jobtread: "2.9% + $0.30",
  },
  {
    label: "Premium Customer Support",
    tooltip: "Access to high-touch support for setup, training, and ongoing success.",
    handoff: "check",
    jobtread: "x",
  },
] as const;

const seo = getPageSeo(Astro.url.pathname);
---

<BaseLayout {...seo}>
  <Header />

  <main class="pt-20">
    <div class="px-4 pb-4">
      <div class="bg-white border border-black/[0.04] rounded-[20px] overflow-hidden max-w-[1920px] mx-auto">

        <!-- Heading -->
        <div class="flex flex-col items-center gap-5 text-center pt-24 pb-24 px-4 max-w-3xl mx-auto">
          <div class="flex flex-col items-center gap-3 w-full">
            <p class="font-mono font-semibold text-sm leading-6 tracking-[0.04em] uppercase text-neutral-400">
              Compare project management
            </p>
            <h1 class="font-display font-medium text-5xl leading-[1.2] tracking-[-0.02em] text-text-primary">
              See why contractors choose <span class="text-brand-accent">Handoff</span> over <span class="text-neutral-500">Markate</span>
            </h1>
          </div>
          <div class="text-xl leading-[1.5] text-text-tertiary font-body font-normal w-full space-y-5">
            <p>Markate provides manual job management features for home service businesses. Rather, Handoff was developed with AI-native features, specifically for residential contractors. 
</p>
            <p>We offer job estimates that are supported by local, real-time construction databases.</p>
          </div>
        </div>

        <!-- Comparison table -->
        <div class="w-full px-4 sm:px-6 lg:px-8 max-w-[1440px] mx-auto pb-24 -mx-4 sm:mx-auto">
          <div class="overflow-x-auto overscroll-x-contain" style="scrollbar-gutter: stable;">
            <div class="min-w-[640px] w-full">

          <!-- Logo header row -->
          <div class="flex items-stretch w-full">
            <div class="flex-1 min-w-[200px] sm:min-w-0 h-[140px] sm:h-[180px]"></div>

            <!-- Handoff logo + CTA -->
            <div class="flex-1 min-w-[160px] sm:min-w-0 flex flex-col items-center justify-center gap-3 sm:gap-6 h-[140px] sm:h-[180px] pt-4 sm:pt-6 px-3 sm:px-6">
              <div class="flex items-center w-full max-w-[170px] h-8 sm:h-10 shrink-0">
                <svg class="w-full h-auto" viewBox="0 0 186 40" fill="none" xmlns="http://www.w3.org/2000/svg">
<path d="M65.9382 27.1833H56.8141C56.4624 27.1833 56.1772 27.4685 56.1772 27.8202V36.8754C56.1772 37.2268 55.8921 37.5119 55.5408 37.5119H51.9451C51.5937 37.5119 51.3086 37.2268 51.3086 36.8754V13.8745C51.3086 13.5232 51.5937 13.238 51.9451 13.238H55.5408C55.8921 13.238 56.1772 13.5232 56.1772 13.8745V22.5819C56.1772 22.9336 56.4624 23.2187 56.8141 23.2187H65.9382C66.2899 23.2187 66.5751 22.9336 66.5751 22.5819V13.8745C66.5751 13.5232 66.8602 13.238 67.2115 13.238H70.8072C71.1586 13.238 71.4437 13.5232 71.4437 13.8745V36.8758C71.4437 37.2272 71.1586 37.5123 70.8072 37.5123H67.2115C66.8602 37.5123 66.5751 37.2272 66.5751 36.8758V27.8206C66.5751 27.4689 66.2899 27.1837 65.9382 27.1837V27.1833Z" fill="black"/>
