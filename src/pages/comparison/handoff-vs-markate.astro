<path d="M39.0122 9.01401L22.5876 0.441759C21.4589 -0.147253 20.1133 -0.147253 18.9846 0.441759L2.56081 9.01401C0.986662 9.83572 0 11.4638 0 13.2393V35.5819C0 38.0218 1.97792 39.9997 4.41778 39.9997H8.73835V14.6033C8.73835 13.8562 9.34382 13.2504 10.0913 13.2504H14.6889C15.436 13.2504 16.0415 13.8558 16.0415 14.6029V22.2364C16.0415 22.9834 16.647 23.5893 17.3944 23.5893H24.1973C24.9448 23.5893 25.5506 22.9834 25.5506 22.236V14.6033C25.5506 13.8562 26.1561 13.2504 26.9036 13.2504H31.5012C32.2483 13.2504 32.8538 13.8558 32.8538 14.6029V39.9993H37.2245C39.6268 39.9993 41.5741 38.052 41.5741 35.6497V13.2393C41.5741 11.4638 40.5871 9.83572 39.0133 9.01401H39.0122Z" fill="#02B05E"/>
</svg>

              </div>
              <a
                href="/"
                class="inline-flex items-center justify-center px-3 sm:px-4 py-2 text-sm font-medium leading-5 text-text-secondary rounded-xl border border-border-primary bg-white shadow-xs whitespace-nowrap w-full max-w-[202px] hover:bg-bg-secondary transition-colors"
              >
                7 day free trial
              </a>
            </div>

            <!-- JobTread logo -->
            <div class="flex-1 min-w-[140px] sm:min-w-0 flex items-center justify-center h-[140px] sm:h-[180px] pb-6 sm:pb-9 px-3 sm:px-6">
              <div class="flex items-center gap-2">
                <img src={markate.src} alt="Markate logo" />
                <span class="font-display font-bold text-[22px] tracking-tight text-neutral-800">Markate</span>
              </div>
            </div>
          </div>

          <!-- "Features:" label -->
          <div class="flex items-center w-full pb-6 sm:pb-8 px-4 sm:px-6">
            <div class="flex-1 min-w-0">
              <p class="font-display font-medium text-xl sm:text-2xl leading-8 text-text-brand-secondary">Features:</p>
            </div>
          </div>

          <!-- Feature comparison rows -->
          <div class="flex w-full">

            <!-- Feature labels -->
            <div class="flex-1 min-w-[200px] sm:min-w-0 flex flex-col">
              {features.map((row) => (
                <div class="flex items-center gap-1.5 min-h-20 h-20 px-4 sm:px-6 border-b border-border-primary">
                  <span class="font-body font-medium text-base sm:text-lg leading-6 sm:leading-7 text-text-primary">{row.label}</span>
                </div>
              ))}
            </div>

            <!-- Handoff values (highlighted bg) -->
            <div class="flex-1 min-w-[120px] sm:min-w-0 flex flex-col bg-bg-secondary">
              {features.map((row) => (
                <div class="flex items-center justify-center min-h-20 h-20 px-3 sm:px-6 border-b border-border-primary">
                  {row.handoff === "check" ? (
                    <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
<path fill-rule="evenodd" clip-rule="evenodd" d="M9.9987 0.833252C4.93609 0.833252 0.832031 4.93731 0.832031 9.99992C0.832031 15.0625 4.93609 19.1666 9.9987 19.1666C15.0613 19.1666 19.1654 15.0625 19.1654 9.99992C19.1654 4.93731 15.0613 0.833252 9.9987 0.833252ZM14.338 8.08917C14.6634 7.76374 14.6634 7.2361 14.338 6.91066C14.0125 6.58523 13.4849 6.58523 13.1594 6.91066L8.7487 11.3214L6.83795 9.41066C6.51252 9.08523 5.98488 9.08523 5.65944 9.41066C5.334 9.7361 5.334 10.2637 5.65944 10.5892L8.15944 13.0892C8.48488 13.4146 9.01252 13.4146 9.33795 13.0892L14.338 8.08917Z" fill="#183F2E"/>
</svg>

                  ) : (
                    <span class="font-body font-medium text-sm sm:text-lg leading-6 sm:leading-7 text-brand-accent text-center break-words px-1">{row.handoff}</span>
                  )}
                </div>
              ))}
            </div>

            <!-- JobTread values -->
            <div class="flex-1 min-w-[140px] sm:min-w-0 flex flex-col">
              {features.map((row) => (
                <div class="flex items-center justify-center min-h-20 h-20 px-3 sm:px-6 border-b border-border-primary">
                  {row.jobtread === "x" ? (
                    <svg width="19" height="19" viewBox="0 0 19 19" fill="none" xmlns="http://www.w3.org/2000/svg">
<path d="M11.6654 6.66659L6.66536 11.6666M6.66536 6.66659L11.6654 11.6666M17.4987 9.16659C17.4987 13.769 13.7677 17.4999 9.16536 17.4999C4.56299 17.4999 0.832031 13.769 0.832031 9.16659C0.832031 4.56421 4.56299 0.833252 9.16536 0.833252C13.7677 0.833252 17.4987 4.56421 17.4987 9.16659Z" stroke="#D2D6DB" stroke-width="1.66667" stroke-linecap="round" stroke-linejoin="round"/>
</svg>

                  ) : (
                    <span class="font-body font-medium text-sm sm:text-lg leading-6 sm:leading-7 text-text-tertiary text-center break-words px-1">{row.jobtread}</span>
                  )}
                </div>
              ))}
            </div>

          </div>
            </div>
          </div>
        </div>

      </div>
    </div>
    <ReviewsSection />
    <FaqSection items={faqItems} />
  </main>

  <Footer />
</BaseLayout>
