<path d="M127.232 17.9328C129.414 17.9328 131.518 18.8062 132.906 20.1997C133.135 20.4293 133.526 20.2663 133.526 19.9417V12.4151C133.526 12.0626 133.812 11.7771 134.164 11.7771H137.827C138.179 11.7771 138.465 12.0626 138.465 12.4151V36.8738C138.465 37.2263 138.179 37.5118 137.827 37.5118H134.164C133.812 37.5118 133.526 37.2263 133.526 36.8738V35.7299C133.526 35.3935 133.114 35.2404 132.888 35.4895C131.656 36.8486 129.731 37.8245 127.197 37.8245C122.293 37.8245 118.398 33.8251 118.398 27.8086C118.398 21.7922 122.293 17.9321 127.232 17.9321V17.9328ZM128.449 22.2102C125.84 22.2102 123.371 24.1578 123.371 27.8094C123.371 31.461 125.84 33.5476 128.449 33.5476C131.057 33.5476 133.561 31.5306 133.561 27.8791C133.561 24.2275 131.126 22.2105 128.449 22.2105V22.2102Z" fill="black"/>
