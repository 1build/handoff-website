---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/sections/Header.astro";
import NewHeroSection from "@/components/sections/NewHeroSection.astro";
import SocialProofSection from "@/components/sections/SocialProofSection.astro";
import G2Section from "@/components/sections/G2Section.astro";
import Footer from "@/components/sections/Footer.astro";
import HomeFeaturesSection from "@/components/sections/HomeFeaturesSection.astro";
import BuiltOnDataSection from "@/components/sections/BuiltOnDataSection.astro";
import VideoSection from "@/components/sections/VideoSection.astro";
import WhoIsHandoffSection from "@/components/sections/WhoIsHandoffSection.astro";
import TestimonialsGridSection from "@/components/sections/TestimonialsGridSection.astro";
import CtaSystemsSection from "@/components/sections/CtaSystemsSection.astro";

import { navItems, footerColumns } from "@/lib/navigation";
import { getPageSeo } from "@/lib/seo-pages";

const seo = getPageSeo(Astro.url.pathname);
---

<BaseLayout {...seo}>
  <Header navItems={navItems} />
  <NewHeroSection />
  
  <SocialProofSection />
    <HomeFeaturesSection />
    <BuiltOnDataSection />
    <VideoSection />
    <WhoIsHandoffSection />
    <TestimonialsGridSection />
     <G2Section />
     <CtaSystemsSection />
  <Footer columns={footerColumns} />
</BaseLayout>
