---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/sections/Header.astro";
import Footer from "@/components/sections/Footer.astro";
import CtaSection from "@/components/sections/CtaSection.astro";
import NewsletterSection from "@/components/sections/NewsletterSection.astro";
import CalloutBanner from "@/components/ui/CalloutBanner.astro";
import { navItems, footerColumns } from "@/lib/navigation";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id.replace(/\.md$/, "") },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const publishedDate = post.data.publishedAt.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

// Related posts: all posts except current, sorted by date, limit 3
const allPosts = await getCollection("blog");
const relatedPosts = allPosts
  .filter((p) => p.id !== post.id)
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime())
  .slice(0, 3);
---

<BaseLayout
  title={`${post.data.title} — Handoff Blog`}
  description={post.data.excerpt}
>
  <Header navItems={navItems} />

  <article class="relative z-[2] pt-32 pb-2 px-4 bg-brand-800">
    <div class="max-w-[1920px] mx-auto bg-white rounded-3xl py-16 lg:py-24 overflow-hidden">

      <!-- Article Header -->
      <header class="max-w-[1280px] mx-auto px-6 lg:px-8" data-animate="fade-up">
        <div class="max-w-[768px] mx-auto text-center flex flex-col items-center">
          {post.data.category && (
            <span class="text-base font-semibold leading-6 text-text-quaternary mb-4">
              {post.data.category}
            </span>
          )}
          <h1 class="font-display text-3xl md:text-[48px] font-medium leading-tight md:leading-[60px] tracking-[-0.96px] text-text-primary">
            {post.data.title}
          </h1>
          {post.data.excerpt && (
            <p class="mt-6 text-xl font-normal leading-[30px] text-text-secondary">
              {post.data.excerpt}
            </p>
          )}
          <div class="mt-8 flex items-center gap-3">
            {post.data.authorAvatar ? (
              <img
                src={post.data.authorAvatar}
                alt={post.data.author}
                class="w-12 h-12 rounded-full object-cover"
                loading="lazy"
                decoding="async"
              />
            ) : (
              <div class="w-12 h-12 rounded-full bg-brand-100 flex items-center justify-center">
                <span class="text-brand-700 font-medium text-lg">
                  {post.data.author?.charAt(0) || "H"}
                </span>
              </div>
            )}
            <div class="flex flex-col items-start">
              {post.data.author && (
                <span class="text-base font-medium leading-6 text-text-primary">
                  {post.data.author}
                </span>
              )}
              <time class="text-sm font-normal leading-5 text-text-tertiary">
                {publishedDate}
              </time>
            </div>
          </div>
        </div>

        {post.data.featuredImage && (
          <div class="mt-20">
            <img
              src={post.data.featuredImage}
              alt={post.data.title}
              class="w-full h-[280px] md:h-[456px] rounded-xl object-cover"
              loading="lazy"
              decoding="async"
            />
          </div>
        )}
      </header>

      <!-- Article Body -->
      <div class="max-w-[1280px] mx-auto px-6 lg:px-8 mt-16">
        <div class="max-w-[720px] mx-auto">
          <div class="article-body" data-animate="fade-up">
            <Content />
          </div>

          <!-- Callout CTA Banner -->
          {post.data.calloutAfterSection && (
            <CalloutBanner />
          )}
        </div>
      </div>

      <!-- Tags + Share Bar -->
      {post.data.tags && post.data.tags.length > 0 && (
        <div class="max-w-[1280px] mx-auto px-6 lg:px-8 mt-12">
          <div class="max-w-[720px] mx-auto border-t border-border-primary pt-8">
            <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-6">
              <div class="flex flex-wrap gap-2">
                {post.data.tags.map((tag: string) => (
                  <span class="inline-flex items-center px-3 py-1.5 rounded-full bg-neutral-50 border border-neutral-200 text-sm font-medium text-text-secondary">
                    {tag}
                  </span>
                ))}
              </div>
              <div class="flex items-center gap-3">
                <button
                  class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-neutral-50 border border-neutral-200 text-sm font-medium text-text-secondary hover:bg-neutral-100 transition-colors cursor-pointer"
                  data-copy-link
                >
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M6.66667 8.66668C6.95297 9.04943 7.31826 9.36612 7.73772 9.59529C8.15718 9.82446 8.62098 9.96074 9.09778 9.99489C9.57458 10.029 10.0531 9.96024 10.5009 9.79319C10.9487 9.62613 11.3554 9.36471 11.6933 9.02668L13.6933 7.02668C14.3005 6.39799 14.6365 5.55598 14.6289 4.68199C14.6213 3.808 14.2708 2.97196 13.6527 2.35394C13.0347 1.73591 12.1987 1.38535 11.3247 1.37775C10.4507 1.37016 9.60869 1.70614 8.98 2.31335L7.83333 3.45335" stroke="currentColor" stroke-width="1.33" stroke-linecap="round" stroke-linejoin="round"/>
                    <path d="M9.33334 7.33332C9.04704 6.95058 8.68175 6.63388 8.26229 6.40471C7.84283 6.17554 7.37903 6.03926 6.90223 6.00512C6.42543 5.97097 5.94695 6.03976 5.49911 6.20682C5.05128 6.37387 4.6446 6.6353 4.30668 6.97332L2.30668 8.97332C1.69947 9.60201 1.36348 10.444 1.37108 11.318C1.37868 12.192 1.72924 13.0281 2.34726 13.6461C2.96528 14.2641 3.80132 14.6147 4.67531 14.6223C5.54931 14.6299 6.39131 14.2939 7.02 13.6867L8.16 12.5467" stroke="currentColor" stroke-width="1.33" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  Copy link
                </button>
                <a href={`https://twitter.com/intent/tweet?url=${encodeURIComponent(Astro.url.href)}&text=${encodeURIComponent(post.data.title)}`} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center w-9 h-9 rounded-full bg-neutral-50 border border-neutral-200 text-text-secondary hover:bg-neutral-100 transition-colors" aria-label="Share on X">
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M12.6009 0.75H15.0544L9.69434 6.89167L16 15.25H11.0627L7.19566 10.1817L2.77087 15.25H0.31595L6.04904 8.685L0 0.75H5.06262L8.55811 5.3875L12.6009 0.75ZM11.7399 13.7683H13.0993L4.32392 2.145H2.86506L11.7399 13.7683Z" fill="currentColor"/>
                  </svg>
                </a>
                <a href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(Astro.url.href)}`} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center w-9 h-9 rounded-full bg-neutral-50 border border-neutral-200 text-text-secondary hover:bg-neutral-100 transition-colors" aria-label="Share on Facebook">
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M16 8C16 3.58172 12.4183 0 8 0C3.58172 0 0 3.58172 0 8C0 11.993 2.92547 15.3027 6.75 15.9028V10.3125H4.71875V8H6.75V6.2375C6.75 4.2325 7.94438 3.125 9.77172 3.125C10.6467 3.125 11.5625 3.28125 11.5625 3.28125V5.25H10.5538C9.56 5.25 9.25 5.86672 9.25 6.5V8H11.4688L11.1141 10.3125H9.25V15.9028C13.0745 15.3027 16 11.993 16 8Z" fill="currentColor"/>
                  </svg>
                </a>
                <a href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(Astro.url.href)}`} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center w-9 h-9 rounded-full bg-neutral-50 border border-neutral-200 text-text-secondary hover:bg-neutral-100 transition-colors" aria-label="Share on LinkedIn">
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M14.8189 0H1.18111C0.867861 0 0.567441 0.124438 0.345939 0.345939C0.124438 0.567441 0 0.867861 0 1.18111V14.8189C0 15.1321 0.124438 15.4326 0.345939 15.6541C0.567441 15.8756 0.867861 16 1.18111 16H14.8189C15.1321 16 15.4326 15.8756 15.6541 15.6541C15.8756 15.4326 16 15.1321 16 14.8189V1.18111C16 0.867861 15.8756 0.567441 15.6541 0.345939C15.4326 0.124438 15.1321 0 14.8189 0ZM4.76889 13.63H2.36333V5.98889H4.76889V13.63ZM3.56445 4.93C3.29158 4.92846 3.02528 4.84613 2.79916 4.69355C2.57304 4.54097 2.39723 4.32503 2.29392 4.07276C2.19061 3.82049 2.16443 3.54328 2.21869 3.27619C2.27294 3.0091 2.40519 2.76416 2.59876 2.57168C2.79233 2.37921 3.03803 2.24838 3.30541 2.19566C3.57279 2.14294 3.84982 2.17072 4.10145 2.27547C4.35308 2.38023 4.56795 2.55728 4.71918 2.78428C4.87041 3.01128 4.95116 3.27806 4.95111 3.55094C4.95445 3.73339 4.92098 3.91464 4.85279 4.08374C4.78461 4.25284 4.68318 4.40641 4.55468 4.53491C4.42618 4.66342 4.27261 4.76484 4.10351 4.83303C3.93441 4.90121 3.75316 4.93469 3.57072 4.93134L3.56445 4.93ZM13.6356 13.6356H11.2311V9.46222C11.2311 8.23111 10.7078 7.85111 10.0333 7.85111C9.31889 7.85111 8.61889 8.39333 8.61889 9.49333V13.6356H6.21333V5.99333H8.52667V7.05333H8.55778C8.79 6.58 9.60111 5.78 10.8444 5.78C12.1867 5.78 13.6367 6.56222 13.6367 8.91333L13.6356 13.6356Z" fill="currentColor"/>
                  </svg>
                </a>
              </div>
            </div>
          </div>
        </div>
      )}

      <!-- Related Posts -->
      {relatedPosts.length > 0 && (
        <div class="max-w-[1280px] mx-auto px-6 lg:px-8 mt-16 pt-16 border-t border-border-primary">
          <div class="flex flex-col gap-3 mb-12">
            <h2 class="font-display text-4xl font-medium leading-[44px] tracking-[-0.72px] text-text-primary">
              Latest posts
            </h2>
            <p class="text-lg font-normal leading-7 text-text-tertiary">
              More insights to help you grow your contracting business.
            </p>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            {relatedPosts.map((related) => (
              <a href={`/blog/${related.id.replace(/\.md$/, "")}`} class="group flex flex-col gap-6">
                <div class="w-full h-[256px] rounded-md overflow-hidden">
                  {related.data.featuredImage ? (
                    <img
                      src={related.data.featuredImage}
                      alt={related.data.title}
                      class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
                      loading="lazy"
                      decoding="async"
                    />
                  ) : (
                    <div class="w-full h-full bg-detail-visual-bg"></div>
                  )}
                </div>
                <div class="flex flex-col gap-3">
                  <div class="flex items-start justify-between gap-4">
                    <h3 class="text-xl font-medium leading-[30px] text-text-primary group-hover:text-brand-500 transition-colors">
                      {related.data.title}
                    </h3>
                    <svg class="w-5 h-5 flex-shrink-0 mt-1 text-text-primary group-hover:text-brand-500 transition-colors" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path d="M5.83333 14.1667L14.1667 5.83333M14.1667 5.83333H5.83333M14.1667 5.83333V14.1667" stroke="currentColor" stroke-width="1.67" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </div>
                  <span class="text-sm leading-5 text-text-tertiary">
                    {related.data.publishedAt.toLocaleDateString("en-US", {
                      day: "numeric",
                      month: "short",
                      year: "numeric",
                    })}{related.data.category && ` · ${related.data.category}`}
                  </span>
                </div>
              </a>
            ))}
          </div>
          <div class="mt-12 text-center">
            <a
              href="/blog"
              class="inline-flex items-center justify-center px-5 py-2.5 rounded-xl bg-white text-text-secondary border border-border-primary shadow-xs hover:bg-neutral-50 font-medium text-base leading-6 transition-all duration-150"
            >
              View all posts
            </a>
          </div>
        </div>
      )}
    </div>
  </article>

  <NewsletterSection />
  <CtaSection />
  <Footer columns={footerColumns} />
</BaseLayout>

<script>
  import { initScrollAnimations } from "@/lib/animations";

  const header = document.getElementById("site-header");

  window.addEventListener("scroll", () => {
    if (header) {
      if (window.scrollY > 40) {
        header.classList.add("header-scrolled");
      } else {
        header.classList.remove("header-scrolled");
      }
    }
  });

  initScrollAnimations();

  // Copy link button
  document.querySelectorAll("[data-copy-link]").forEach((btn) => {
    btn.addEventListener("click", () => {
      navigator.clipboard.writeText(window.location.href);
      const original = btn.textContent;
      btn.textContent = "Copied!";
      setTimeout(() => {
        btn.innerHTML = `<svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M6.66667 8.66668C6.95297 9.04943 7.31826 9.36612 7.73772 9.59529C8.15718 9.82446 8.62098 9.96074 9.09778 9.99489C9.57458 10.029 10.0531 9.96024 10.5009 9.79319C10.9487 9.62613 11.3554 9.36471 11.6933 9.02668L13.6933 7.02668C14.3005 6.39799 14.6365 5.55598 14.6289 4.68199C14.6213 3.808 14.2708 2.97196 13.6527 2.35394C13.0347 1.73591 12.1987 1.38535 11.3247 1.37775C10.4507 1.37016 9.60869 1.70614 8.98 2.31335L7.83333 3.45335" stroke="currentColor" stroke-width="1.33" stroke-linecap="round" stroke-linejoin="round"/><path d="M9.33334 7.33332C9.04704 6.95058 8.68175 6.63388 8.26229 6.40471C7.84283 6.17554 7.37903 6.03926 6.90223 6.00512C6.42543 5.97097 5.94695 6.03976 5.49911 6.20682C5.05128 6.37387 4.6446 6.6353 4.30668 6.97332L2.30668 8.97332C1.69947 9.60201 1.36348 10.444 1.37108 11.318C1.37868 12.192 1.72924 13.0281 2.34726 13.6461C2.96528 14.2641 3.80132 14.6147 4.67531 14.6223C5.54931 14.6299 6.39131 14.2939 7.02 13.6867L8.16 12.5467" stroke="currentColor" stroke-width="1.33" stroke-linecap="round" stroke-linejoin="round"/></svg> Copy link`;
      }, 1500);
    });
  });
</script>
