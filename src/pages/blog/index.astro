---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/sections/Header.astro";
import Footer from "@/components/sections/Footer.astro";
import { navItems, footerColumns } from "@/lib/navigation";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime(),
);

const [featuredPost, ...remainingPosts] = posts;
---

<BaseLayout title="Blog — Handoff">
  <Header navItems={navItems} />

  <section class="relative z-[2] pt-32 pb-2 px-4 bg-brand-800">
    <div class="max-w-[1920px] mx-auto bg-white rounded-3xl py-16 lg:py-24 overflow-hidden">
      <div class="max-w-[1440px] mx-auto px-6 lg:px-8">
        <h1 class="font-display text-4xl lg:text-5xl font-medium leading-tight tracking-[-0.96px] text-text-primary mb-12" data-animate="fade-up">
          Blog
        </h1>

        {posts.length === 0 && (
          <p class="text-lg text-text-tertiary">No posts yet. Check back soon.</p>
        )}

        {/* Featured Post */}
        {featuredPost && (
          <a href={`/blog/${featuredPost.id.replace(/\.md$/, "")}`} class="group flex flex-col lg:flex-row gap-8 mb-16 pb-16 border-b border-border-primary" data-animate="fade-up">
            {featuredPost.data.featuredImage ? (
              <img
                src={featuredPost.data.featuredImage}
                alt={featuredPost.data.title}
                class="w-full lg:w-1/2 aspect-[16/10] object-cover rounded-xl"
                loading="lazy"
                decoding="async"
              />
            ) : (
              <div class="w-full lg:w-1/2 aspect-[16/10] rounded-xl bg-detail-visual-bg"></div>
            )}
            <div class="flex-1 flex flex-col justify-center gap-4">
              {featuredPost.data.category && (
                <span class="text-sm font-semibold text-text-quaternary">
                  {featuredPost.data.category}
                </span>
              )}
              <h2 class="font-display text-2xl lg:text-4xl font-medium leading-tight tracking-[-0.72px] text-text-primary group-hover:text-brand-500 transition-colors">
                {featuredPost.data.title}
              </h2>
              {featuredPost.data.excerpt && (
                <p class="text-lg text-text-tertiary">{featuredPost.data.excerpt}</p>
              )}
              <div class="flex items-center gap-3 mt-2">
                {featuredPost.data.authorAvatar ? (
                  <img
                    src={featuredPost.data.authorAvatar}
                    alt={featuredPost.data.author}
                    class="w-10 h-10 rounded-full object-cover"
                    loading="lazy"
                    decoding="async"
                  />
                ) : (
                  <div class="w-10 h-10 rounded-full bg-brand-100 flex items-center justify-center">
                    <span class="text-brand-700 font-medium">{featuredPost.data.author?.charAt(0) || "H"}</span>
                  </div>
                )}
                <div class="flex flex-col">
                  {featuredPost.data.author && (
                    <span class="text-sm font-medium text-text-primary">{featuredPost.data.author}</span>
                  )}
                  <time class="text-sm text-text-quaternary">
                    {featuredPost.data.publishedAt.toLocaleDateString("en-US", {
                      year: "numeric",
                      month: "long",
                      day: "numeric",
                    })}
                  </time>
                </div>
              </div>
            </div>
          </a>
        )}

        {/* Remaining Posts Grid */}
        {remainingPosts.length > 0 && (
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8" data-animate="stagger">
            {remainingPosts.map((post) => (
              <a href={`/blog/${post.id.replace(/\.md$/, "")}`} class="group flex flex-col gap-4">
                {post.data.featuredImage ? (
                  <img
                    src={post.data.featuredImage}
                    alt={post.data.title}
                    class="w-full aspect-[16/10] object-cover rounded-xl"
                    loading="lazy"
                    decoding="async"
                  />
                ) : (
                  <div class="w-full aspect-[16/10] rounded-xl bg-detail-visual-bg"></div>
                )}
                <div class="flex flex-col gap-2">
                  {post.data.category && (
                    <span class="text-sm font-semibold text-text-quaternary">
                      {post.data.category}
                    </span>
                  )}
                  <h2 class="font-display text-xl font-medium text-text-primary group-hover:text-brand-500 transition-colors">
                    {post.data.title}
                  </h2>
                </div>
                <time class="text-sm text-text-quaternary">
                  {post.data.publishedAt.toLocaleDateString("en-US", {
                    year: "numeric",
                    month: "long",
                    day: "numeric",
                  })}
                </time>
              </a>
            ))}
          </div>
        )}
      </div>
    </div>
  </section>

  <Footer columns={footerColumns} />
</BaseLayout>

<script>
  import { initScrollAnimations } from "@/lib/animations";

  const header = document.getElementById("site-header");

  window.addEventListener("scroll", () => {
    if (header) {
      if (window.scrollY > 40) {
        header.classList.add("header-scrolled");
      } else {
        header.classList.remove("header-scrolled");
      }
    }
  });

  initScrollAnimations();
</script>
