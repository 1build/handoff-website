---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/sections/Header.astro";
import Footer from "@/components/sections/Footer.astro";
import { navItems, footerColumns } from "@/lib/navigation";
import { getPageSeo } from "@/lib/seo-pages";
import { getCanonicalUrl } from "@/lib/seo";

const LEVER_API_URL = "https://api.lever.co/v0/postings/handoff?mode=json";

type JobList = { text: string; content: string; items?: string[] };
type Job = { id: string; title: string; location: string; type: string; dept: string; url: string; description?: string; lists?: JobList[]; additional?: string };

let jobs: Job[] = [];
try {
  const res = await fetch(LEVER_API_URL);
  if (res.ok) {
    const postings = await res.json();
    jobs = (Array.isArray(postings) ? postings : []).map((p: {
      id?: string;
      text?: string;
      categories?: { location?: string; team?: string };
      workplaceType?: string;
      hostedUrl?: string;
      descriptionBody?: string;
      description?: string;
      lists?: { text?: string; content?: string }[];
      additional?: string;
    }) => {
      const url = p.hostedUrl ?? "#";
      const id = p.id ?? (url !== "#" ? new URL(url).pathname.split("/").filter(Boolean).pop() ?? "" : "");
      const lists = (p.lists ?? []).map((l) => {
        const content = l.content ?? "";
        let items = content.split(/\n+/).map((s) => s.trim()).filter(Boolean);
        if (items.length <= 1 && items[0]) items = items[0].split(/\s{2,}/).map((s) => s.trim()).filter(Boolean);
        return { text: l.text ?? "", content, items };
      });
      return {
        id,
        title: p.text ?? "Open position",
        location: p.categories?.location ?? "",
        type: (p.workplaceType === "hybrid" ? "Hybrid" : p.workplaceType === "remote" ? "Remote" : "Onsite") || "Onsite",
        dept: p.categories?.team ?? "",
        url,
        description: p.descriptionBody ?? p.description ?? "",
        lists,
        additional: p.additional ?? "",
      };
    });
  }
} catch (_) {
  jobs = [];
}

// Static build: no request, so no id. Render page with first job as default and let client script apply ?id=
const jobIdParam = Astro.url.searchParams.get("id");
const job = jobIdParam ? jobs.find((j) => j.id === jobIdParam) ?? jobs[0] ?? null : jobs[0] ?? null;
const applyUrl = job?.url && job.url !== "#" ? (job.url.endsWith("/apply") ? job.url : job.url.replace(/\/?$/, "") + "/apply") : "#";

const seo = getPageSeo(Astro.url.pathname);
if (job) {
  seo.title = `${job.title} — Handoff`;
}
const shareBase = getCanonicalUrl("/careers/jobs");
---

<BaseLayout {...seo}>
  <Header navItems={navItems} />

  <!-- Embed jobs for client-side ?id= handling (static build has no query params) -->
  <script define:vars={{ jobs, shareBase }}>
    (function () {
      function run() {
        const params = new URLSearchParams(window.location.search);
        const id = params.get("id");
        if (!id || id.trim() === "") {
          window.location.replace("/careers");
          return;
        }
        const job = jobs.find((j) => j.id === id);
        if (!job) {
          window.location.replace("/careers");
          return;
        }
        const titleEl = document.querySelector("[data-job-title]");
        if (titleEl) titleEl.textContent = job.title;
        document.querySelectorAll("[data-job-location]").forEach((el) => { el.textContent = job.location; });
        document.querySelectorAll("[data-job-type]").forEach((el) => { el.textContent = job.type; });
        document.querySelectorAll("[data-job-dept]").forEach((el) => { el.textContent = job.dept; });
        document.querySelectorAll("[data-job-apply]").forEach((a) => {
          const applyUrl = job.url && job.url !== "#" ? (job.url.endsWith("/apply") ? job.url : job.url.replace(/\/?$/, "") + "/apply") : "#";
          a.setAttribute("href", applyUrl);
        });
        document.title = job.title + " — Handoff";
        // Full job body: description + lists
        const descEl = document.querySelector("[data-job-description]");
        if (descEl && job.description) {
          descEl.innerHTML = job.description.trim().replace(/\n/g, "<br/>");
          descEl.style.display = "";
        } else if (descEl) descEl.style.display = "none";
        const listsEl = document.querySelector("[data-job-lists]");
        if (listsEl && job.lists && job.lists.length > 0) {
          const escape = (s) => String(s).replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;");
          listsEl.innerHTML = job.lists.map((list) => {
            const isHtml = list.content.includes("</li>");
            let listBody;
            if (isHtml) {
              listBody = "<ul class=\"list-disc pl-7 flex flex-col gap-4 text-xl font-medium leading-[30px] text-text-tertiary\">" + list.content.trim() + "</ul>";
            } else {
              let items = list.items && list.items.length > 0 ? list.items : list.content.split(/\n+/).map((s) => s.trim()).filter(Boolean);
              if (items.length <= 1 && items[0]) items = items[0].split(/\s{2,}/).map((s) => s.trim()).filter(Boolean);
              listBody = items.length > 0
                ? "<ul class=\"list-disc pl-7 flex flex-col gap-4 text-xl font-medium leading-[30px] text-text-tertiary\">" + items.map((item) => "<li>" + escape(item) + "</li>").join("") + "</ul>"
                : "<p class=\"text-xl font-medium leading-[30px] text-text-tertiary\">" + escape(list.content.trim()) + "</p>";
            }
            return "<div class=\"max-w-[768px] flex flex-col gap-5\"><h2 class=\"font-display font-medium text-[36px] leading-[44px] tracking-[-0.72px] text-text-primary\">" + escape(list.text) + "</h2>" + listBody + "</div>";
          }).join("");
          listsEl.style.display = "";
        } else if (listsEl) listsEl.style.display = "none";
        // Closing paragraph (additional): CTA + EEO statement
        const additionalEl = document.querySelector("[data-job-additional]");
        if (additionalEl) {
          if (job.additional) {
            additionalEl.innerHTML = job.additional.trim().replace(/\n/g, "<br/>");
            additionalEl.classList.remove("hidden");
          } else {
            additionalEl.innerHTML = "";
            additionalEl.classList.add("hidden");
          }
        }
        // Canonical job share URL: https://handoff.ai/careers/jobs?id=<id>
        const shareUrl = shareBase + "?id=" + encodeURIComponent(id);
        const shareUrlEl = document.querySelector("[data-share-url]");
        if (shareUrlEl) shareUrlEl.setAttribute("data-share-url", shareUrl);
        const twitterEls = document.querySelectorAll("[data-share-twitter]");
        twitterEls.forEach((el) => el.setAttribute("href", "https://twitter.com/intent/tweet?url=" + encodeURIComponent(shareUrl) + "&text=" + encodeURIComponent(job.title + " — Handoff")));
        const facebookEls = document.querySelectorAll("[data-share-facebook]");
        facebookEls.forEach((el) => el.setAttribute("href", "https://www.facebook.com/sharer/sharer.php?u=" + encodeURIComponent(shareUrl)));
        const linkedinEls = document.querySelectorAll("[data-share-linkedin]");
        linkedinEls.forEach((el) => el.setAttribute("href", "https://www.linkedin.com/shareArticle?mini=true&url=" + encodeURIComponent(shareUrl) + "&title=" + encodeURIComponent(job.title + " — Handoff")));
      }
      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", run);
      } else {
        run();
      }
      // Run again after View Transitions swap so job updates when navigating from careers without refresh
      document.addEventListener("astro:page-load", run);
    })();
  </script>

  <!-- Canonical job share URL (updated by script when job id changes) -->
  <span data-share-url={job ? `${shareBase}?id=${job.id}` : ""} aria-hidden="true" class="hidden"></span>

  <main class="pt-20 flex flex-col items-center px-4 pb-4 gap-4">

    <!-- ── Job Post Content Card ─────────────────────────────────── -->
    <div class="w-full max-w-[1920px] bg-bg-primary rounded-[20px] border border-black/[0.04] py-24 flex flex-col gap-20 items-center overflow-hidden">

      <!-- Job Header -->
      <div class="w-full max-w-[1440px] px-8 flex flex-wrap items-center justify-between gap-6">
        <div class="flex flex-col gap-5">
          <h1 class="font-display font-medium text-[48px] leading-[60px] tracking-[-0.96px] text-text-primary" data-job-title>
            {job?.title ?? "Loading…"}
          </h1>
          <div class="flex flex-wrap gap-8 items-center">
            <div class="flex gap-2 items-center">
              <svg class="w-5 h-5 text-text-secondary shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/>
                <circle cx="12" cy="9" r="2.5"/>
              </svg>
              <span class="text-base font-medium leading-6 text-text-secondary" data-job-location>{job?.location ?? ""}</span>
            </div>
            <div class="flex gap-2 items-center">
              <svg class="w-5 h-5 text-text-secondary shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="2" width="18" height="20" rx="2"/>
                <path d="M9 22v-4h6v4M3 9h18"/>
              </svg>
              <span class="text-base font-medium leading-6 text-text-secondary" data-job-type>{job?.type ?? ""}</span>
            </div>
            <div class="flex gap-2 items-center">
              <svg class="w-5 h-5 text-text-secondary shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <line x1="4" y1="9" x2="20" y2="9"/><line x1="4" y1="15" x2="20" y2="15"/>
                <line x1="10" y1="3" x2="8" y2="21"/><line x1="16" y1="3" x2="14" y2="21"/>
              </svg>
              <span class="text-base font-medium leading-6 text-text-secondary" data-job-dept>{job?.dept ?? ""}</span>
            </div>
          </div>
        </div>
        <a
          data-job-apply
          href={applyUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="shrink-0 inline-flex items-center justify-center px-[18px] py-3 bg-bg-brand-solid text-white text-base font-medium leading-6 rounded-xl hover:bg-brand-600 transition-colors duration-150"
          style="box-shadow: 0px 1px 2px rgba(10,13,18,0.05), inset 0px 0px 0px 1px rgba(10,13,18,0.18), inset 0px -2px 0px rgba(10,13,18,0.05);"
        >
          Apply now
        </a>
      </div>

      <!-- Divider -->
      <div class="w-full h-px bg-neutral-200"></div>

      <!-- Why Join Us (2-col with sidebar) -->
      <div class="w-full max-w-[1440px] px-8 flex flex-wrap lg:flex-nowrap gap-12 justify-between items-start">
        <!-- Left: Content -->
        <div class="w-full max-w-[768px] flex flex-col gap-5">
          <h2 class="font-display font-medium text-[36px] leading-[44px] tracking-[-0.72px] text-text-primary">Why join us?</h2>
          <div class="text-xl font-medium leading-[30px] text-text-tertiary space-y-5">
            <p>Handoff is the AI agent that runs a construction company. We help remodelers automate estimating, streamline operations, and win more work — backed by real-time cost data, intuitive design, and workflows that "speak contractor." With over 10,000 monthly active users and $6B in annualized project volume already flowing through our platform, we're becoming the trusted partner for the people who build our homes.</p>
            <p>We are backed by $25M+ raised from Y Combinator, Initialized, and Greycroft. Our team is distributed across hubs in Austin, São Paulo, and Buenos Aires, and we are deeply focused on building intuitive, high-impact solutions that make a real difference for our users.</p>
          </div>
        </div>
        <!-- Right: CTA Card -->
        <div class="shrink-0 w-full lg:w-[437px] bg-bg-secondary rounded-[24px] p-8 flex flex-col gap-6">
          <div class="flex flex-col gap-4">
            <div class="flex flex-col gap-2">
              <p class="font-mono text-sm font-semibold leading-6 tracking-[0.56px] uppercase text-text-on-brand-tertiary">JOIN US</p>
              <h3 class="font-display font-medium text-2xl leading-8 text-text-primary">Come Build With Us</h3>
            </div>
            <p class="text-base font-medium leading-6 text-text-tertiary">
              At Handoff, we move fast, run experiments, and hold a high bar for excellence. If you're excited to solve hard problems and do some of the best work of your life, we'd love to hear from you.
            </p>
          </div>
          <a
            id="apply"
            data-job-apply
            href={applyUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="w-full flex items-center justify-center px-[18px] py-3 bg-bg-brand-solid text-white text-base font-medium leading-6 rounded-xl hover:bg-brand-600 transition-colors duration-150"
            style="box-shadow: 0px 1px 2px rgba(10,13,18,0.05), inset 0px 0px 0px 1px rgba(10,13,18,0.18), inset 0px -2px 0px rgba(10,13,18,0.05);"
          >
            Apply now
          </a>
          <!-- Social share buttons -->
          <div class="flex gap-3 items-center">
            <button
              class="flex flex-1 gap-2 items-center justify-center px-3.5 py-2.5 bg-bg-primary border border-border-primary rounded-xl text-sm font-medium leading-5 text-text-secondary hover:bg-bg-secondary transition-colors duration-150"
              style="box-shadow: 0px 1px 2px rgba(10,13,18,0.05);"
              onclick="navigator.clipboard.writeText(document.querySelector('[data-share-url]')?.getAttribute('data-share-url') || window.location.href)"
            >
              <svg class="w-5 h-5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="8" y="8" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
              </svg>
              Copy link
            </button>
            <a data-share-twitter href="https://twitter.com/intent/tweet" target="_blank" rel="noopener" class="w-10 h-10 flex items-center justify-center bg-bg-primary border border-border-primary rounded-xl hover:bg-bg-secondary transition-colors duration-150" style="box-shadow: 0px 1px 2px rgba(10,13,18,0.05);">
              <svg class="w-[18px] h-[18px] text-text-primary" viewBox="0 0 24 24" fill="currentColor" aria-label="Share on X">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.261 5.635 5.903-5.635zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
              </svg>
            </a>
            <a data-share-facebook href="https://www.facebook.com/sharer/sharer.php" target="_blank" rel="noopener" class="w-10 h-10 flex items-center justify-center bg-bg-primary border border-border-primary rounded-xl hover:bg-bg-secondary transition-colors duration-150" style="box-shadow: 0px 1px 2px rgba(10,13,18,0.05);">
              <svg class="w-[18px] h-[18px] text-text-primary" viewBox="0 0 24 24" fill="currentColor" aria-label="Share on Facebook">
                <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
              </svg>
            </a>
            <a data-share-linkedin href="https://www.linkedin.com/shareArticle" target="_blank" rel="noopener" class="w-10 h-10 flex items-center justify-center bg-bg-primary border border-border-primary rounded-xl hover:bg-bg-secondary transition-colors duration-150" style="box-shadow: 0px 1px 2px rgba(10,13,18,0.05);">
              <svg class="w-[18px] h-[18px] text-text-primary" viewBox="0 0 24 24" fill="currentColor" aria-label="Share on LinkedIn">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
            </a>
          </div>
        </div>
      </div>

      <!-- Job description (from Lever; includes role intro text) -->
      <div class="w-full max-w-[1440px] px-8">
        <div class="max-w-[768px] flex flex-col gap-5">
          <div data-job-description class="text-xl font-medium leading-[30px] text-text-tertiary prose prose-p:my-4" set:html={job?.description ? job.description.trim().replace(/\n/g, "<br/>") : ""} />
        </div>
      </div>

      <!-- What you'll do, About you, What we offer (from Lever lists) -->
      <div data-job-lists class="w-full max-w-[1440px] px-8 flex flex-col gap-16">
        {job?.lists && job.lists.length > 0 ? job.lists.map((list) => {
          const contentIsHtml = list.content.includes("</li>");
          return (
            <div class="max-w-[768px] flex flex-col gap-5">
              <h2 class="font-display font-medium text-[36px] leading-[44px] tracking-[-0.72px] text-text-primary">{list.text}</h2>
              {contentIsHtml ? (
                <ul class="list-disc pl-7 flex flex-col gap-4 text-xl font-medium leading-[30px] text-text-tertiary" set:html={list.content.trim()} />
              ) : (
                <ul class="list-disc pl-7 flex flex-col gap-4 text-xl font-medium leading-[30px] text-text-tertiary">
                  {(list.items && list.items.length > 0 ? list.items : [list.content]).map((item) => <li set:html={item} />)}
                </ul>
              )}
            </div>
          );
        }) : null}
      </div>

      <!-- Closing paragraph (CTA + EEO from Lever additional) -->
      <div class="w-full max-w-[1440px] px-8">
        <div data-job-additional class={`max-w-[768px] text-xl font-medium leading-[30px] text-text-tertiary prose prose-p:my-4 ${job?.additional ? "" : "hidden"}`} set:html={job?.additional ? job.additional.trim().replace(/\n/g, "<br/>") : ""} />
      </div>

      <!-- Share this article -->
      <div class="w-full max-w-[1440px] px-8">
        <div class="max-w-[768px] flex flex-wrap gap-6 items-center justify-between border-t border-neutral-200 pt-6">
          <p class="text-lg font-medium leading-7 text-text-secondary">Share this job</p>
          <div class="flex gap-3 items-center">
            <button
              class="flex gap-2 items-center justify-center px-3.5 py-2.5 bg-bg-primary border border-border-primary rounded-xl text-sm font-medium leading-5 text-text-secondary hover:bg-bg-secondary transition-colors duration-150"
              style="box-shadow: 0px 1px 2px rgba(10,13,18,0.05);"
              onclick="navigator.clipboard.writeText(document.querySelector('[data-share-url]')?.getAttribute('data-share-url') || window.location.href)"
            >
              <svg class="w-5 h-5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="8" y="8" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
              </svg>
              Copy link
            </button>
            <a data-share-twitter href="https://twitter.com/intent/tweet" target="_blank" rel="noopener" class="w-10 h-10 flex items-center justify-center bg-bg-primary border border-border-primary rounded-xl hover:bg-bg-secondary transition-colors duration-150" style="box-shadow: 0px 1px 2px rgba(10,13,18,0.05);">
              <svg class="w-[18px] h-[18px] text-text-primary" viewBox="0 0 24 24" fill="currentColor" aria-label="Share on X">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.261 5.635 5.903-5.635zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
              </svg>
            </a>
            <a data-share-facebook href="https://www.facebook.com/sharer/sharer.php" target="_blank" rel="noopener" class="w-10 h-10 flex items-center justify-center bg-bg-primary border border-border-primary rounded-xl hover:bg-bg-secondary transition-colors duration-150" style="box-shadow: 0px 1px 2px rgba(10,13,18,0.05);">
              <svg class="w-[18px] h-[18px] text-text-primary" viewBox="0 0 24 24" fill="currentColor" aria-label="Share on Facebook">
                <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
              </svg>
            </a>
            <a data-share-linkedin href="https://www.linkedin.com/shareArticle" target="_blank" rel="noopener" class="w-10 h-10 flex items-center justify-center bg-bg-primary border border-border-primary rounded-xl hover:bg-bg-secondary transition-colors duration-150" style="box-shadow: 0px 1px 2px rgba(10,13,18,0.05);">
              <svg class="w-[18px] h-[18px] text-text-primary" viewBox="0 0 24 24" fill="currentColor" aria-label="Share on LinkedIn">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
            </a>
          </div>
        </div>
      </div>

    </div>

    <!-- ── Open Positions Card ────────────────────────────────────── -->
    <div class="w-full max-w-[1920px] bg-bg-primary rounded-[20px] border border-black/[0.04] py-24 flex flex-col gap-20 items-center overflow-hidden">

      <!-- Heading -->
      <div class="w-full max-w-[1440px] px-8">
        <h2 class="font-display font-medium text-[48px] leading-[60px] tracking-[-0.96px] text-text-primary">Open positions</h2>
      </div>

      <!-- Jobs list -->
      <div class="w-full max-w-[1440px] flex flex-col">
        {jobs.map((j) => (
          <a
            href={`/careers/jobs?id=${j.id}`}
            class:list={[
              "flex flex-wrap lg:flex-nowrap gap-6 lg:gap-16 items-center px-8 py-10 border-b border-border-primary hover:bg-bg-secondary transition-colors duration-150",
              j.id === job?.id ? "bg-bg-secondary" : "bg-transparent"
            ]}
          >
            <p class="flex-1 font-display font-medium text-2xl leading-8 text-text-primary">{j.title}</p>
            <div class="flex flex-wrap flex-1 gap-8 items-center">
              <div class="flex gap-2 items-center">
                <svg class="w-5 h-5 text-text-secondary shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/>
                  <circle cx="12" cy="9" r="2.5"/>
                </svg>
                <span class="text-sm font-medium leading-5 text-text-secondary whitespace-nowrap">{j.location}</span>
              </div>
              <div class="flex gap-2 items-center">
                <svg class="w-5 h-5 text-text-secondary shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="3" y="2" width="18" height="20" rx="2"/>
                  <path d="M9 22v-4h6v4M3 9h18"/>
                </svg>
                <span class="text-sm font-medium leading-5 text-text-secondary whitespace-nowrap">{j.type}</span>
              </div>
              <div class="flex gap-2 items-center">
                <svg class="w-5 h-5 text-text-secondary shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="4" y1="9" x2="20" y2="9"/><line x1="4" y1="15" x2="20" y2="15"/>
                  <line x1="10" y1="3" x2="8" y2="21"/><line x1="16" y1="3" x2="14" y2="21"/>
                </svg>
                <span class="text-sm font-medium leading-5 text-text-secondary whitespace-nowrap">{j.dept}</span>
              </div>
            </div>
            <div class="shrink-0">
              <svg class="w-6 h-6 text-text-secondary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M9 18l6-6-6-6"/>
              </svg>
            </div>
          </a>
        ))}
      </div>

    </div>

  </main>

  <Footer columns={footerColumns} />
</BaseLayout>
