<style>
  /* Active TOC link state */
  .toc-link.is-active .toc-label {
    color: var(--color-brand-700);
    font-weight: 500;
  }
  .toc-link.is-active .toc-indicator {
    background-color: var(--color-brand-accent);
  }
  .toc-link:hover .toc-indicator {
    background-color: var(--color-neutral-300);
  }
  .toc-link.is-active:hover .toc-indicator {
    background-color: var(--color-brand-accent);
  }
</style>

<script>
  import { initScrollAnimations } from "@/lib/animations";

  // Header scroll state
  const header = document.getElementById("site-header");
  window.addEventListener("scroll", () => {
    if (header) {
      header.classList.toggle("header-scrolled", window.scrollY > 40);
    }
  }, { passive: true });

  initScrollAnimations();

  // Active TOC link tracking via IntersectionObserver
  const sections = document.querySelectorAll<HTMLElement>(".article-body h2[id], .article-body h3[id]");
  const tocLinks = document.querySelectorAll<HTMLElement>("[data-toc-link]");

  if (sections.length && tocLinks.length) {
    let activeId = "";

    const setActive = (id: string) => {
      if (id === activeId) return;
      activeId = id;
      tocLinks.forEach((link) => {
        const isActive = link.dataset.tocLink === id;
        link.classList.toggle("is-active", isActive);
      });
    };

    const observer = new IntersectionObserver(
      (entries) => {
        const visible = entries
          .filter((e) => e.isIntersecting)
          .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);

        if (visible.length > 0) {
          setActive((visible[0].target as HTMLElement).id);
        }
      },
      {
        rootMargin: "-80px 0px -65% 0px",
        threshold: 0,
      }
    );

    sections.forEach((section) => observer.observe(section));

    window.addEventListener("scroll", () => {
      let current = "";
      sections.forEach((section) => {
        if (section.getBoundingClientRect().top <= 120) {
          current = section.id;
        }
      });
      if (current) setActive(current);
    }, { passive: true });

    if (sections[0]) setActive(sections[0].id);
  }
</script>
