---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/sections/Header.astro";
import Footer from "@/components/sections/Footer.astro";
import { navItems, footerColumns } from "@/lib/navigation";
import card3Image from "@/assets/images/Card 3.png";
---

<BaseLayout
  title="1build — AI for Construction"
  description="1build is a team of engineers, data scientists, and company builders working on AI that can run a construction company."
>
  <Header navItems={navItems} />

  <article class="relative z-[2] pt-32 pb-2 px-4 bg-brand-800">
    <div class="max-w-[1920px] mx-auto bg-white rounded-3xl py-16 lg:py-24">

      <!-- Page Header — 1build brand -->
      <header class="max-w-[1280px] mx-auto px-6 lg:px-8" data-animate="fade-up">
        <div class="flex items-end justify-between">

          <!-- Left: Brand name + login button + description -->
          <div class="flex flex-col gap-4 items-start">
            <!-- Row 1: Brand name + login button -->
            <div class="flex flex-wrap gap-5 items-center">
              <h1 class="font-display text-[40px] font-bold leading-[48px] tracking-[-2.56px] text-[#0f0f0f]">
                1build
              </h1>
              <a
                href="https://app2.1build.com/public/login"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 border border-[rgba(15,15,15,0.1)] rounded-full px-[21px] py-[14px] text-[13px] font-medium uppercase tracking-[1.12px] text-[#0f0f0f] leading-[1.4] whitespace-nowrap hover:bg-[rgba(15,15,15,0.05)] transition-colors duration-200"
              >
                Login to 1build
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <path d="M2.5 11.5L11.5 2.5M11.5 2.5H4.5M11.5 2.5V9.5" stroke="#0f0f0f" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            </div>

            <!-- Row 2: Description paragraphs -->
            <div class="flex flex-col gap-4 items-start max-w-[640px]">
              <p class="text-[20px] font-normal leading-[28px] text-[#6f6f6f]">
                1build is a team of engineers, data scientists, and company builders.
              </p>
              <p class="text-[20px] font-normal leading-[28px] text-[#6f6f6f]">
                We&rsquo;re working on AI that can run a construction company, so contractors can
                focus on what they do best: building beautiful spaces for their clients.
              </p>
            </div>
          </div>

          <!-- Right: Carousel navigation -->
          <div class="flex items-center gap-8 shrink-0 pb-1">
            <button
              id="carousel-prev"
              aria-label="Previous slide"
              class="flex items-center justify-center w-11 h-11 rounded-full border border-[rgba(15,15,15,0.1)] transition-opacity duration-200"
              style="opacity:0.3"
            >
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M10 12L6 8L10 4" stroke="#0f0f0f" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>

            <div class="flex gap-2 items-center" id="carousel-dots">
              <button class="h-1.5 rounded-full transition-all duration-300" style="width:18px;background:#079455" data-index="0" aria-label="Go to slide 1"></button>
              <button class="h-1.5 w-1.5 rounded-full transition-all duration-300" style="background:rgba(15,15,15,0.1)" data-index="1" aria-label="Go to slide 2"></button>
              <button class="h-1.5 w-1.5 rounded-full transition-all duration-300" style="background:rgba(15,15,15,0.1)" data-index="2" aria-label="Go to slide 3"></button>
            </div>

            <button
              id="carousel-next"
              aria-label="Next slide"
              class="flex items-center justify-center w-11 h-11 rounded-full border border-[rgba(15,15,15,0.1)] hover:bg-[rgba(15,15,15,0.04)] transition-colors duration-200"
            >
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M6 12L10 8L6 4" stroke="#0f0f0f" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
          </div>

        </div>
      </header>

      <!-- Divider -->
      <div class="max-w-[1280px] mx-auto px-6 lg:px-8 mt-12">
        <div class="border-t border-border-primary"></div>
      </div>

      <!-- Carousel of product cards -->
      <div class="relative mt-10" data-animate="fade-up">

        <!-- Carousel viewport: overflow hidden, left-padded to match header -->
        <div class="overflow-hidden">
          <div class="pl-6 lg:pl-[max(1.5rem,calc((100%-1280px)/2+2rem))]">
            <div
              id="carousel-track"
              class="flex gap-6"
              style="transition: transform 0.5s cubic-bezier(0.4,0,0.2,1); will-change: transform;"
            >

              <!-- Card 1: Handoff (green) -->
              <div class="shrink-0 w-[800px] h-[420px] rounded-[20px] relative overflow-hidden isolate flex" style="background:#183f2e">
                <!-- Text content -->
                <div class="relative z-10 flex flex-col justify-between p-8 shrink-0 w-[368px]">
                  <span class="text-[20px] font-bold leading-[28px] tracking-[-0.48px] text-white">Handoff</span>
                  <div class="flex flex-col gap-6">
                    <h2 class="text-[28px] font-bold leading-[39.2px] tracking-[-0.56px] text-white m-0">
                      Instantly create<br><span class="whitespace-nowrap">construction estimates</span><br>with AI.
                    </h2>
                    <a
                      href="https://app.handoff.ai/sign-up"
                      target="_blank"
                      rel="noopener noreferrer"
                      class="inline-flex items-center gap-2 bg-white rounded-full pl-6 pr-4 py-2 text-[16px] font-bold text-[#0f0f0f] leading-[24px] w-fit no-underline hover:bg-[rgba(255,255,255,0.9)] transition-colors duration-200"
                    >
                      Start an estimate
                      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                        <path d="M3 13L13 3M13 3H6M13 3V10" stroke="#0f0f0f" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    </a>
                  </div>
                </div>
                <!-- Decorative SVG behind mockup -->
                <div class="absolute z-[1] pointer-events-none" aria-hidden="true" style="left:333px;top:-15px;width:500px;height:540px;">
                  <svg width="500" height="540" viewBox="0 0 500 540" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <mask id="mask0_10186_63807" style="mask-type:alpha" maskUnits="userSpaceOnUse" x="4" y="0" width="492" height="532">
                      <path d="M68.9727 199.684C147.931 137.191 173.197 119.662 197.06 104.617C301.034 39.0671 278.246 74.5113 335.06 78.7255C357.753 80.4087 381.209 88.4711 393.119 110.264C403.43 129.132 376.146 151.862 365.31 162.081C315.018 209.513 254.721 247.031 198.953 286.821C172.383 305.778 144.84 325.134 126.991 353.886C109.148 382.63 97.1998 425.442 140.95 427.951C173.164 429.799 206.014 406.794 231.993 389.252C263.008 368.307 291.343 342.97 322.418 322.131C345.585 306.596 371.441 301.517 397.958 305.831C437.336 312.238 436.857 378.985 421.341 405.807C410.878 423.893 386.492 444.859 384.183 466.94" fill="#7ED6AC"/>
