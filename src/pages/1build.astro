                    </mask>
                    <g mask="url(#mask0_10186_63807)">
                      <path d="M615.86 -110.107L529.565 714.882L-401.063 617.536L-314.768 -207.452L615.86 -110.107Z" fill="#079455" stroke="#079455" stroke-width="0.994036"/>
                    </g>
                  </svg>
                </div>

                <!-- Product screenshot -->
                <div class="absolute right-0 bottom-0 z-[2] pointer-events-none" aria-hidden="true" style="width:420px;height:420px;overflow:hidden;">
                  <img
                    src="https://www.figma.com/api/mcp/asset/e44c119f-9c6d-4b12-ad22-28801bf64b96"
                    alt="Handoff app showing a construction estimate"
                    class="absolute bottom-0 right-0 h-[372px] w-auto max-w-none object-contain object-bottom-right"
                    style="object-position:bottom right;"
                  />
                </div>
              </div>

              <!-- Card 2: 1build Estimating Service (navy) -->
              <div class="shrink-0 w-[800px] h-[420px] rounded-[20px] relative overflow-hidden isolate flex" style="background:#1e2644">
                <!-- Text content -->
                <div class="relative z-10 flex flex-col justify-between p-8 shrink-0 w-[368px]">
                  <span class="text-[20px] font-bold leading-[28px] tracking-[-0.48px] text-white">1build Estimating Service</span>
                  <div class="flex flex-col gap-6">
                    <h2 class="text-[28px] font-bold leading-[39.2px] tracking-[-0.56px] text-white m-0">
                      <span class="whitespace-nowrap">Let our estimators help</span><br>with your bids.
                    </h2>
                    <a
                      href="https://estimating.1build.com/"
                      target="_blank"
                      rel="noopener noreferrer"
                      class="inline-flex items-center gap-2 bg-white rounded-full pl-6 pr-4 py-2 text-[16px] font-bold text-[#0f0f0f] leading-[24px] w-fit no-underline hover:bg-[rgba(255,255,255,0.9)] transition-colors duration-200"
                    >
                      Hire an estimator
                      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                        <path d="M3 13L13 3M13 3H6M13 3V10" stroke="#0f0f0f" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    </a>
                  </div>
                </div>
                <!-- Decorative SVG behind mockup -->
