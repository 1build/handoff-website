---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/sections/Header.astro";
import Footer from "@/components/sections/Footer.astro";
import FaqSection from "@/components/sections/FaqSection.astro";
import ProjectManagementCta from "@/components/sections/ProjectManagementCta.astro";
import DetailRow from "@/components/sections/DetailRow.astro";
import TestimonialCard from "@/components/sections/TestimonialCard.astro";
import StarIcon from "@/components/ui/StarIcon.astro";
import Button from "@/components/ui/Button.astro";
import bgPattern from "@/assets/images/background-pattern.png";
import heroGlow from "@/assets/images/hero-glow-line.svg";
import SupplierLogosCarousel from "@/components/sections/SupplierLogosCarousel.astro";
import projectIcon1 from "@/assets/icons/projectIcon1.svg";
import projectIcon2 from "@/assets/icons/clock-plus.svg";
import projectIcon3 from "@/assets/icons/projectIcon3.svg";
import { navItems, footerColumns } from "@/lib/navigation";
import { getPageSeo } from "@/lib/seo-pages";
import heroImage from "@/assets/images/Heros/Project Management.webp";
import scheduleImage from "@/assets/images/Project Management/Schedule Project Phases and Track@2x.webp";
import projectDashImg from "@/assets/images/Project Management/Project dash@2x.webp";
import aiContractImg from "@/assets/images/Project Management/Ask about your project@2x.webp";
import projectBlocksImg from "@/assets/images/Project Management/Project Blocks@2x.webp";

const faqItems = [
  {
    question: "How does Handoff's trained AI handle change orders?",
    answer: "Change orders are created directly in the platform, tracked automatically, and connected to the original estimate. You can see how changes affect the budget and timeline in real-time.",
  },
  {
    question: "Can my whole team use it?",
    answer: "Yes. You control who sees what through role-based permissions. Crew members see their schedules, project managers see project details, and you see everything.",
  },
  {
    question: "Will this work when I'm running multiple projects?",
    answer: "Yes. Handoff is built to help you scale. The more projects you run, the more valuable the automated coordination becomes. You can manage 3x more projects when you delegate admin work to your AI Teammate.",
  },
  {
    question: 'How does "Crew Scheduling" work?',
    answer: "You set crew availability and project phases. Handoff's trained AI coordinates schedules, sends notifications, and alerts you to conflicts automatically.",
  },
  {
    question: "Can I customize it for how my business works?",
    answer: "You can set up approval rules, authorization levels, and workflows that match how you actually run projects.",
  },
];

const features = [
  {
    eyebrow: "AI-powered contract & documentation",
    title: "No more chasing signed contracts",
    description: "Proposals, invoices, and payments integrate without question. Get signatures faster so you're ready to build.",
    bullets: [
      "Takeoffs, estimates, contracts, schedules, and invoices all connected",
      "Change orders tracked from request to payment",
      "Every project document in one place",
    ],
    image: aiContractImg,
    imageFill: true,
    ctaHref: "/ai-documents",
  },
  {
    eyebrow: "Intelligent crew scheduling",
    title: "Everyone knows where to be and when",
    description: "No more coordinating crews through texts. Have your AI Teammate set up schedules once, so everyone stays in the loop.",
    bullets: [
      "Everyone's schedule in one calendar",
      "Crew schedules and walkthroughs are coordinated automatically",
      "Everyone gets notified when schedules change",
      "Your phone stops buzzing with scheduling questions",
    ],
    image: scheduleImage,
    imageFill: true,
    ctaHref: "https://app.handoff.ai/sign-up/",
  },
  {
    eyebrow: "Real-time project alerts",
    title: "Catch problems before they cost you",
    description: "While your competition is still figuring out their pricing, you're already in the client's inbox.",
    bullets: [
      "Know when approvals are stuck before clients ask",
      "Payment reminders so you stop chasing money",
      "Handle change orders before they cause delays",
      "Spot crew conflicts and timeline risks while you can still fix them",
    ],
    image: projectBlocksImg,
    imageFill: true,
    ctaHref: "/client-management-system",
  },
  {
    eyebrow: "Role-based permissions",
    title: "Keep your business information safe",
    description: "Keep control of your business as your team grows. You decide who can see what, so the right people have access to the right information without oversight.",
    bullets: [
      "Crews see their schedules, not your markup",
      "Project managers see what they need to manage project",
      "Only authorized team members see markup and margin data",
      "Set it once, never worry about information leaks",
    ],
    image: projectDashImg,
    imageFill: true,
    ctaHref: "https://app.handoff.ai/sign-up/",
  },
];

const outcomes = [
  {
    icon: projectIcon1.src,
    title: "Keep project organized",
    description: "Every contract, change order, and document in one place. No more hunting through excel sheets for approvals.",
  },
  {
    icon: projectIcon2.src,
    title: "Cut admin time in half",
    description: "Proposals turn into payments seamlessly. Change orders stay organized without the extra work.",
  },
  {
    icon: projectIcon3.src,
    title: "Scale without the bottleneck",
    description: "Your AI Teammate learns your way of doing things and handles it on every project. Scale up without being in three places at once.",
  },
];
const seo = getPageSeo(Astro.url.pathname);
---

<BaseLayout {...seo}>
  <Header navItems={navItems} />

  <!-- Hero (matches solutions HeroSection pattern) -->
  <section id="hero" class="relative pt-20">
    <!-- Background grid pattern -->
    <div class="absolute top-0 left-1/2 -translate-x-1/2 max-w-full w-[1920px] h-[1440px] pointer-events-none z-0">
      <img src={bgPattern.src} alt="" class="w-full h-full block object-contain object-top" />
    </div>

    <!-- Glow line -->
    <div class="absolute max-w-full -top-[24%] -left-[14%] -right-[14%] -bottom-[24%] pointer-events-none z-[1]">
      <img src={heroGlow.src} alt="" class="w-full h-full block" />
    </div>

    <!-- Content -->
    <div id="hero-container" class="relative z-[1] max-w-[1440px] mx-auto px-4 md:px-8 py-24 flex flex-col lg:flex-row items-center gap-12 lg:gap-16 will-change-[opacity,transform]">
      <div class="flex-1 flex flex-col">
        <p class="font-mono text-sm font-semibold leading-6 tracking-[0.56px] uppercase text-text-on-brand-tertiary mb-3">
          End-to-End Project Management
        </p>
        <h1 class="font-display text-4xl sm:text-[44px] lg:text-[60px] font-medium leading-[1.2] lg:leading-[72px] tracking-[-1.2px] text-white mb-6">
          Run more projects <span class="text-text-highlight">without more admin</span>
        </h1>
        <p class="text-lg lg:text-xl font-medium leading-[30px] text-white max-w-[640px]">
          Spend your time building and growing your business instead of chasing project details. Built for contractors, Handoff's trained AI manages all the documentation, scheduling, and crew coordination in one system, acting like your AI Teammate.
        </p>
        <div class="mt-12">
         
          <a href="https://app.handoff.ai/sign-up/" class="inline-flex w-full md:w-auto items-center justify-center gap-1.5 px-5 py-3 text-base font-medium leading-6 rounded-xl transition-all duration-150 whitespace-nowrap bg-black/40 backdrop-blur-md text-white hover:bg-black/30">

        See how it works
<span class="absolute inset-0 pointer-events-none rounded-[inherit] shadow-[inset_0px_0px_0px_1px_rgba(10,13,18,0.18),inset_0px_-2px_0px_0px_rgba(10,13,18,0.05)]"></span> </a>
        </div>
      </div>

      <!-- Hero visual -->
      <div class="flex-1 relative z-[2] self-end">
        <img
          src={heroImage.src}
          alt="Project management dashboard"
          class="w-full h-auto translate-y-[16%]"
          loading="eager"
          decoding="async"
        />
      </div>
    </div>
  </section>

  <!-- Features overview: cards + testimonial + logos (one white card, like FeaturesSection) -->
  <section id="features" class="relative z-[2] px-4 pb-4 bg-transparent">
    <div class="max-w-[1920px] mx-auto bg-white rounded-3xl border border-black/[0.04] py-16 lg:py-24 overflow-hidden flex flex-col gap-12 lg:gap-20">
      <!-- Section header -->
      <div class="max-w-[1440px] px-6 lg:px-8 mx-auto w-full flex flex-col gap-5">
        <h2 class="font-display text-4xl lg:text-5xl font-medium leading-[44px] lg:leading-[60px] tracking-[-0.96px] text-text-primary max-w-4xl">
          Run projects in one connected system
        </h2>
        <p class="text-xl font-normal leading-[30px] text-text-tertiary">
          Handoff gives you the tools to respond faster, look more professional, and protect your margins on every job.
        </p>
      </div>

      <!-- Outcome cards with icons -->
      <div class="max-w-[1440px] px-6 lg:px-8 mx-auto w-full grid grid-cols-1 lg:grid-cols-3 gap-8" data-animate="stagger">
        {outcomes.map((o) => (
          <div class="bg-bg-secondary rounded-xl p-6 flex flex-col gap-16">
            <div class="w-12 h-12 bg-white rounded-md flex items-center justify-center shadow-3xl">
              <img src={o.icon} alt="" class="w-6 h-6" loading="lazy" decoding="async" />
            </div>
            <div class="flex flex-col gap-4">
              <h3 class="font-display text-2xl font-medium leading-8 text-text-primary">{o.title}</h3>
              <p class="text-lg font-normal leading-7 text-text-tertiary">{o.description}</p>
            </div>
          </div>
        ))}
      </div>

      <!-- Testimonial -->
      <div class="bg-bg-secondary rounded-xl p-4 md:p-8 lg:p-12 flex flex-col gap-8 mx-6 lg:mx-8 lg:-mt-12 max-w-[calc(1440px-64px)] w-[calc(100%-48px)] lg:w-[calc(100%-64px)] self-center" data-animate="fade-up">
        <!-- Stars -->
        <div class="flex items-center gap-4">
          <div class="flex gap-1">
            <StarIcon /><StarIcon /><StarIcon /><StarIcon /><StarIcon />
          </div>
          <span class="text-base font-medium text-text-quaternary">5/5</span>
        </div>

        <!-- Quote -->
        <blockquote class="font-display text-[28px] lg:text-4xl font-medium leading-9 lg:leading-[44px] tracking-[-0.72px] text-text-primary">
          Handoff has <span class="text-brand-accent">streamlined a lot of my workflow</span>. I really appreciate how everything is in one place, making communication and tracking progress much easier.
        </blockquote>

        <!-- Footer -->
        <div class="flex flex-col sm:flex-row items-start sm:items-center gap-6 sm:gap-16">
          <div class="flex flex-col gap-1">
            <p class="text-lg font-semibold leading-7 text-text-primary">— Amanda M.</p>
            <p class="text-base font-normal leading-6 text-text-tertiary">Owner/Project Manager</p>
          </div>
          <a
            href="/reviews"
            class="inline-flex items-center justify-center gap-1.5 px-2 md:px-[18px] py-3 text-base font-medium leading-6 rounded-xl bg-white border border-border-primary text-text-secondary shadow-xs hover:bg-bg-secondary transition-colors duration-150 whitespace-nowrap"
          >
            View more testimonials
          </a>
        </div>
      </div>

      <!-- Supplier logos carousel -->
      <SupplierLogosCarousel />
    </div>
  </section>

  <!-- Detailed feature rows -->
  <section class="relative z-[2] px-4 bg-brand-800">
    <div class="max-w-[1920px] mx-auto bg-white rounded-3xl py-16 lg:py-24 overflow-hidden flex flex-col gap-20 lg:gap-40">
      {features.map((f, i) => (
        <DetailRow
          eyebrow={f.eyebrow}
          title={f.title}
          description={f.description}
          bullets={f.bullets}
          reverse={i % 2 !== 0}
          visualType="desktop"
          visualImages={f.image ? [f.image] : undefined}
          imageFill={f.imageFill}
          placeholder={f.placeholder}
          ctaHref={f.ctaHref}
        />
      ))}
    </div>
  </section>

  <!-- FAQ -->
  <FaqSection items={faqItems} />

  <!-- CTA -->
  <ProjectManagementCta />

  <!-- Footer -->
  <Footer columns={footerColumns} />
</BaseLayout>

<script>
  import { initScrollAnimations } from "@/lib/animations";
  import { initHeroScroll } from "@/lib/heroScroll";
  initScrollAnimations();
  initHeroScroll();
</script>
