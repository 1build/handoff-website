---
import { ViewTransitions } from "astro:transitions";
import SpeedInsights from "@vercel/speed-insights/astro";
import "../styles/global.css";
import {
  getCanonicalUrl,
  getDefaultDescription,
  getDefaultJsonLd,
  resolveImageUrl,
  type PageSeo,
} from "@/lib/seo";

interface Props extends Partial<PageSeo> {
  title: string;
}

const {
  title,
  description = getDefaultDescription(),
  image,
  imageAlt = "Handoff",
  canonicalPath,
  noindex = false,
  jsonLd,
} = Astro.props;

const canonicalUrl = getCanonicalUrl(canonicalPath ?? Astro.url.pathname);
const ogImage = resolveImageUrl(image);
const defaultSchema = getDefaultJsonLd(canonicalUrl);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="Handoff" />
    <meta property="og:locale" content="en_US" />
    {ogImage && <meta property="og:image" content={ogImage} />}
    {ogImage && imageAlt && <meta property="og:image:alt" content={imageAlt} />}
    <!-- Twitter Card -->
    <meta name="twitter:card" content={ogImage ? "summary_large_image" : "summary"} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}
    {ogImage && imageAlt && <meta name="twitter:image:alt" content={imageAlt} />}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400..700&family=Geist:wght@400;500;600;700&family=Geist+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <script type="application/ld+json" set:html={JSON.stringify(defaultSchema)} />
    {jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(Array.isArray(jsonLd) ? { "@context": "https://schema.org", "@graph": jsonLd } : jsonLd)} />
    )}
    <ViewTransitions />
  </head>
  <body class="min-h-screen bg-brand-800 overflow-x-hidden animate-fade-in">
    <slot />
    <SpeedInsights />
  </body>
</html>
