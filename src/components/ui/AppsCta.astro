---
interface Props {
  store: "apple" | "google";
}

const { store } = Astro.props;
const GOOGLE_PLAY_URL = "https://play.google.com/store/apps/details?id=com.onebuild.handoff";
const APP_STORE_URL = "https://apps.apple.com/am/app/handoff-ai-estimating-app/id6470666320";

import googleBadge from "../../assets/icons/badge-google-play.svg?raw";
import appleBadge from "../../assets/icons/badge-app-store.svg?raw";
---

{store === "google" ? (
  <a
    href={GOOGLE_PLAY_URL}
    target="_blank"
    rel="noopener noreferrer"
    class="inline-block"
    aria-label="Get it on Google Play"
    set:html={googleBadge}
  />
) : (
  <a
    href={APP_STORE_URL}
    target="_blank"
    rel="noopener noreferrer"
    class="inline-block"
    aria-label="Download on the App Store"
    set:html={appleBadge}
  />
)}
