---
import Button from "@/components/ui/Button.astro";
---

<div class="bg-bg-tertiary rounded-2xl p-8 my-12">
  <div class="flex flex-col md:flex-row items-start gap-5">
    <div class="flex-1 flex flex-col gap-4">
      <h3 class="font-display text-2xl font-semibold leading-8 text-text-primary">
        Ready to put AI to work for your business?
      </h3>
      <p class="text-base leading-6 text-text-tertiary">
        See how Handoff helps contractors automate estimates, proposals, and follow-ups — so you can focus on building.
      </p>
      <div>
        <Button variant="primary" href="/">Request a demo</Button>
      </div>
    </div>
    <div class="hidden md:block w-[116px] h-[144px] rounded-xl bg-detail-visual-bg flex-shrink-0"></div>
  </div>
</div>
