---
interface Props {
  store: "apple" | "google";
}

const { store } = Astro.props;
---

<div class="flex items-center gap-2 px-3 py-1.5 border border-white rounded-[7px] w-[140px] bg-transparent">
  {store === "apple" ? (
    <svg width="18" height="22" viewBox="0 0 18 22" fill="none" class="shrink-0">
      <path d="M14.94 11.66C14.96 9.94 15.76 8.82 17.38 8.04C16.48 6.74 15.08 6.02 13.22 5.86C11.46 5.7 9.52 6.88 8.82 6.88C8.08 6.88 6.36 5.92 5.06 5.92C2.36 5.96 0 8.08 0 11.88C0 13.04 0.22 14.24 0.66 15.48C1.26 17.12 3.4 21.14 5.62 21.06C6.84 21.04 7.7 20.18 9.24 20.18C10.74 20.18 11.54 21.06 12.9 21.06C15.14 21.02 17.06 17.38 17.62 15.72C14.78 14.38 14.94 11.74 14.94 11.66ZM12.34 4.14C13.64 2.6 13.52 1.2 13.48 0.72C12.32 0.78 10.98 1.5 10.2 2.4C9.34 3.38 8.82 4.58 8.94 5.84C10.2 5.94 11.34 5.3 12.34 4.14Z" fill="white" />
    </svg>
    <div class="flex flex-col">
      <span class="text-[8px] text-white leading-[1.2]">Download on the</span>
      <span class="text-sm font-semibold text-white leading-[1.3]">App Store</span>
    </div>
  ) : (
    <svg width="24" height="26" viewBox="0 0 24 26" fill="none" xmlns="http://www.w3.org/2000/svg">
<path fill-rule="evenodd" clip-rule="evenodd" d="M16.6973 17.3389L2.54102 25.3848C1.9062 25.7448 1.32406 25.8046 0.87793 25.6133L12.9238 13.5655L16.6973 17.3389ZM12.2168 12.8584L0.183594 24.8936C0.0656134 24.6264 0 24.2987 0 23.917V1.80178C0 1.4206 0.0655179 1.09269 0.183594 0.82522L12.2168 12.8584ZM22.042 11.416C23.439 12.21 23.439 13.5097 22.042 14.3047L17.5996 16.8272L13.6309 12.8584L17.5977 8.89065L22.042 11.416ZM0.878906 0.106469C1.32496 -0.084604 1.90655 -0.0245826 2.54102 0.335962L16.6963 8.37795L12.9238 12.1514L0.878906 0.106469Z" fill="white"/>
</svg>

    <div class="flex flex-col">
      <span class="text-[8px] text-white leading-[1.2]">GET IT ON</span>
      <span class="text-sm font-semibold text-white leading-[1.3]">Google Play</span>
    </div>
  )}
</div>
