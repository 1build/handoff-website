---
import Logo from "@/components/ui/Logo.astro";
import AppBadge from "@/components/ui/AppBadge.astro";
import { footerColumns as localFooterColumns } from "@/lib/navigation";

interface Props {
  columns?: { title: string; lightTitle?: boolean; links: { label: string; href: string; badge?: string }[] }[];
}

const { columns } = Astro.props;
const footerColumns = columns?.length ? columns : localFooterColumns;
---

<footer class="relative z-[2] pt-16 pb-12 bg-brand-800">
  <div class="max-w-[1440px] mx-auto px-4 md:px-8 flex flex-col gap-12">
    <!-- Columns -->
    <div class="flex flex-wrap gap-y-8 lg:gap-y-12 gap-x-8 justify-between" data-animate="fade-up">
      {footerColumns.map((col) => (
        <div class="min-w-24 flex flex-col gap-4 w-[calc(50%-20px)] sm:w-auto">
          <h4 class="text-sm font-semibold leading-5 text-text-on-brand-secondary">
            {col.title}
          </h4>
          <ul class="flex flex-col gap-3">
            {col.links.map((link) => (
              <li class="flex items-center gap-2">
                <a
                  href={link.href}
                  target={link.href.startsWith("http") ? "_blank" : undefined}
                  rel={link.href.startsWith("http") ? "noopener noreferrer" : undefined}
                  class="text-base font-medium leading-6 text-text-on-brand-tertiary hover:text-brand-accent transition-colors duration-150"
                >
                  {link.label}
                </a>
                {link.badge && (
                  <span class="text-xs font-medium leading-4 px-1.5 py-0.5 rounded bg-white/10 text-white border border-white/10">
                    {link.badge}
                  </span>
                )}
              </li>
            ))}
          </ul>
        </div>
      ))}
      <!-- App + Roadmap column -->
      <div class="flex flex-col gap-16 min-w-[45%] md:min-w-[136px] shrink-0">
        <!-- Get the app -->
        <div class="flex flex-col gap-4">
          <h4 class="text-sm font-semibold leading-5 text-white">
            Get the app:
          </h4>
          <div class="flex flex-col gap-4">
            <AppBadge store="apple" />
            <AppBadge store="google" />
          </div>
        </div>
        <!-- See what's ahead -->
        <div class="flex flex-col gap-4">
          <h4 class="text-sm font-semibold leading-5 text-white">
            See what's ahead:
          </h4>
          <div class="flex flex-col gap-3">
            <a
              href="https://handoff.featurebase.app/roadmap"
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm font-medium leading-5 px-3.5 py-2.5 rounded-xl bg-white/10 text-white hover:bg-white/20 transition-colors duration-150 text-center whitespace-nowrap"
            >
              Public roadmap
            </a>
            <a
              href="https://handoff.featurebase.app/"
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm font-medium leading-5 px-3.5 py-2.5 rounded-xl bg-white/10 text-white hover:bg-white/20 transition-colors duration-150 text-center whitespace-nowrap"
            >
              Request features
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Bottom -->
    <div class="flex items-center justify-between flex-wrap gap-6 pt-8 border-t border-border-brand-alt">
      <a href="/" class="flex items-center h-8" aria-label="Handoff home">
        <Logo />
      </a>
      <div class="flex flex-col sm:flex-row sm:items-center gap-1 sm:gap-3">
        <p class="text-base font-normal leading-6 text-text-on-brand-secondary">
          © 2026 Handoff. All rights reserved.
        </p>
        <a href="/official-information-about-handoff" class="text-base font-normal leading-6 text-text-on-brand-secondary hover:text-brand-accent transition-colors duration-150">
          Hey AI, learn about us
        </a>
      </div>
    </div>
  </div>
</footer>
