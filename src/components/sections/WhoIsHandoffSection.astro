---

<section class="px-4 pt-4">
  <div
    class="relative z-[2] py-10 md:py-16 lg:py-24 bg-white rounded-3xl"
    data-animate="fade-up"
  >
    <div class="max-w-[1440px] mx-auto px-4 sm:px-6 md:px-8">
      <!-- Section heading -->
      <div class="text-center max-w-[768px] mx-auto mb-12 md:mb-16">
        <h2
          class="font-display text-3xl sm:text-4xl md:text-[2.25rem] font-semibold leading-tight tracking-[-0.02em] text-text-primary"
        >
          Built and Trained for Residential Construction
        </h2>
      </div>

      <!-- Cards grid -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {
          cards.map((card) => (
            <article class="flex flex-col gap-16 bg-bg-secondary rounded-xl p-6 min-h-[376px]">
              <!-- Icon badge -->
              <div class="bg-white rounded-lg p-3 w-fit shadow-[0px_32px_64px_-12px_rgba(10,13,18,0.14),0px_5px_5px_-2.5px_rgba(10,13,18,0.04)]">
                <Fragment set:html={card.icon} />
              </div>

              <!-- Text content -->
              <div class="flex flex-col gap-4">
                <p class="font-display font-medium text-2xl leading-8 text-text-primary">
                  {card.label}
                </p>
                <p class="font-body text-lg leading-7 text-text-tertiary">
                  {card.description}
                </p>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </div>
</section>
