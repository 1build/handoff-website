---
const features = [
  {
    title: "Remodelers",
    description: "Growth your business without adding overhead",
  },
  {
    title: "Remodelers",
    description: "Growth your business without adding overhead",
  },
];
---
<section class="px-4 pt-4">
<div class="relative z-[2] py-10 md:py-16 lg:py-20 bg-white rounded-3xl" data-animate="fade-up">
  <div class="max-w-[1440px] mx-auto px-4 sm:px-6 md:px-8">
    <div class="text-center max-w-[720px] mx-auto mb-8 md:mb-12">
      <h2 class="font-display text-3xl sm:text-4xl md:text-[2.5rem] font-semibold leading-tight tracking-[-0.02em] text-text-primary mb-4">
        Who is Handoff for?
      </h2>
      <p class="text-base md:text-lg leading-relaxed text-text-secondary">
        If you are an owner of a residential construction business, Handoff is for you. Supercharge your growth and let us handle your operations on autopilot.
      </p>
    </div>

     <div class="grid grid-cols-1 md:grid-cols-2 gap-5 md:gap-8">
      {features.map((feature, i) => (
        <article class="flex flex-col rounded-2xl border border-[#E9EAEB] bg-[#F4F6F4] overflow-hidden">
          <div class="h-[260px] overflow-hidden">
            
          </div>
          <div class="p-4 sm:py-6 bg-[#F4F6F4]">
            <div class="flex items-end justify-between gap-4">
              <div>
                <p class="text-sm font-semibold text-text-quaternary capitalize mb-1">
                  {feature.title}
                </p>
                <p class="text-base md:text-lg text-text-primary leading-relaxed">
                  {feature.description}
                </p>
              </div>
              <button
                type="button"
                class="hidden sm:inline-flex items-center justify-center w-12 h-12 rounded-full border border-[#E9EAEB] bg-transparent text-neutral-700 hover:bg-white transition-colors"
                aria-hidden="true"
                tabIndex={-1}
              >
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
<path d="M9 18L15 12L9 6" stroke="#414651" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
</svg>

              </button>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
  </div>
</section>
