---
import testimonialMatt from "@/assets/images/testimonial-matt-avatar.png";
import g2Logo from "@/assets/images/g2-logo.png";
import appStoreLogo from "@/assets/images/app-store-icon.png";
import capterraLogo from "@/assets/images/capterra-logo.png";

const testimonials = [
  {
    name: "Matt",
    company: "Equi-linc",
    location: "Brownsburg, IN",
    quote: "Handoff AI is a game changer in helping us develop our long term sales & operations plan… AI is the way of the future and this hits us in a very important part of our business.",
    avatar: testimonialMatt.src,
    initials: "M",
    color: "#2d7a52",
  },
  {
    name: "Todd",
    company: "GoHome LLC",
    location: "Chester, VA",
    quote: "I've been so frustrated with estimating that I was ready to give it up. Handoff is like taking a 1,000-pound weight off my chest. I feel so much better now. I'm so glad I found you guys.",
    avatar: null,
    initials: "T",
    color: "#3b7dd8",
  },
  {
    name: "Chris",
    company: "Two Crackers and a Nailgun",
    location: "Miami, FL",
    quote: "I have already told someone about the software. I feel as more updates are added it is going to be an unstoppable competitive software in the construction industry.",
    avatar: null,
    initials: "C",
    color: "#7c3aed",
  },
  {
    name: "Heath",
    company: "Mayfield Construction",
    location: "Bowie, TX",
    quote: "I am very surprised at how close to my numbers the AI is. I really like the app.",
    avatar: null,
    initials: "H",
    color: "#c2410c",
  },
  {
    name: "Glenn",
    company: "Glenn and Sons Remodel",
    location: "Denver, CO",
    quote: "I'm very impressed. We won a $10,000 job with Handoff in our first month!",
    avatar: null,
    initials: "G",
    color: "#0f766e",
  },
];

function StarIcon() {
  return `<svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M8 1l2.245 4.549 5.02.73-3.633 3.541.858 5.001L8 12.435 3.51 14.82l.858-5L1.735 6.278l5.02-.73L8 1z" fill="#F59E0B"/></svg>`;
}

function MapPinIcon() {
  return `<svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M10 10.833a2.083 2.083 0 1 0 0-4.166 2.083 2.083 0 0 0 0 4.166Z" stroke="#6f6f6f" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/><path d="M10 17.5s5.833-4.167 5.833-8.75a5.833 5.833 0 0 0-11.666 0C4.167 13.333 10 17.5 10 17.5Z" stroke="#6f6f6f" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/></svg>`;
}

function GooglePlayIcon() {
  return `<svg width="22" height="24" viewBox="0 0 22 24" fill="none"><path d="M.65 1.08A1.62 1.62 0 000 2.4v19.2c0 .52.25.99.65 1.32L.78 23l11.1-11.1v-.2L.78 1z" fill="#4285F4"/><path d="M15.57 15.7l-3.7-3.7v-.2l3.7-3.7.08.05 4.38 2.49c1.25.71 1.25 1.88 0 2.59l-4.38 2.49-.08.02z" fill="#FBBC04"/><path d="M15.65 15.64L11.88 11.9.65 22.92c.41.44 1.1.5 1.87.05l13.13-7.33z" fill="#EA4335"/><path d="M15.65 8.13L2.52.8C1.75.35 1.06.41.65.85l11.23 11.02 3.77-3.74z" fill="#34A853"/></svg>`;
}

const ratings = [
  {
    name: "G2",
    score: "4.8",
    logoSrc: g2Logo.src,
    logoHeight: "h-7",
    showName: false,
  },
  {
    name: "App Store",
    score: "4.7",
    logoSrc: appStoreLogo.src,
    logoHeight: "h-7",
    showName: true,
  },
  {
    name: "Google Play",
    score: "4.7",
    logoSrc: null,
    logoHeight: "",
    showName: true,
  },
  {
    name: "Capterra",
    score: "4.5",
    logoSrc: capterraLogo.src,
    logoHeight: "h-6",
    showName: false,
  },
];
---

<section class="relative z-[2] px-4 pt-0 pb-2">
  <div class="max-w-[1920px] mx-auto bg-white rounded-3xl border border-black/[0.04] overflow-hidden">
    <div class="max-w-[1280px] mx-auto px-8 pt-12 pb-0">
      <!-- Ratings row -->
      <div class="flex flex-wrap items-center justify-between gap-6 mb-10">
        {ratings.map((r) => (
          <div class="flex items-center gap-4">
            <div class="flex items-center gap-2.5">
              {r.logoSrc ? (
                <img src={r.logoSrc} alt={r.name} class={`${r.logoHeight} w-auto`} />
              ) : (
                <Fragment set:html={GooglePlayIcon()} />
              )}
              {r.showName && (
                <span class="text-base font-medium text-text-secondary">{r.name}</span>
              )}
            </div>
            <div class="flex items-center gap-3">
              <div class="flex items-center gap-1">
                <Fragment set:html={StarIcon()} />
                <Fragment set:html={StarIcon()} />
                <Fragment set:html={StarIcon()} />
                <Fragment set:html={StarIcon()} />
                <Fragment set:html={StarIcon()} />
              </div>
              <span class="text-sm text-text-quaternary">
                <strong class="font-semibold">{r.score}</strong>/5
              </span>
            </div>
          </div>
        ))}
      </div>

    </div>

    <!-- Testimonial carousel — full width, outside the max-w container -->
    <div class="testimonial-carousel relative pb-12">
      <!-- Fade masks -->
      <div class="pointer-events-none absolute inset-y-0 left-0 z-10 w-16 bg-gradient-to-r from-white to-transparent"></div>
      <div class="pointer-events-none absolute inset-y-0 right-0 z-10 w-16 bg-gradient-to-l from-white to-transparent"></div>

      <div class="testimonial-track flex gap-5 px-8">
        {/* Render cards twice for seamless loop */}
        {[...testimonials, ...testimonials].map((t) => (
          <div class="bg-white rounded-[20px] border border-[rgba(15,15,15,0.1)] p-5 flex flex-col justify-between shrink-0 w-[344px] h-[236px]">
            <div class="flex flex-col gap-4">
              <div class="flex items-center gap-3">
                {t.avatar ? (
                  <img
                    src={t.avatar}
                    alt={t.name}
                    class="w-[44px] h-[44px] rounded-full object-cover"
                    loading="lazy"
                  />
                ) : (
                  <div
                    class="w-[44px] h-[44px] rounded-full flex items-center justify-center text-white font-semibold text-lg shrink-0"
                    style={`background-color: ${t.color}`}
                  >
                    {t.initials}
                  </div>
                )}
                <div class="flex flex-col gap-0.5">
                  <p class="text-base font-bold text-text-primary leading-6 font-display">{t.name}</p>
                  <p class="text-xs text-text-quaternary leading-4">{t.company}</p>
                </div>
              </div>
              <p class="text-sm font-normal leading-5 text-text-primary">{t.quote}</p>
            </div>
            <div class="flex items-center gap-1">
              <Fragment set:html={MapPinIcon()} />
              <span class="text-sm text-text-quaternary leading-5">{t.location}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  /* 5 cards × (344px + 20px gap) = 1820px per set */
  @keyframes carousel-scroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-1820px); }
  }

  .testimonial-track {
    animation: carousel-scroll 30s linear infinite;
  }

  .testimonial-carousel:hover .testimonial-track {
    animation-play-state: paused;
  }
</style>
