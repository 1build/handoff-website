---
import DetailRowClientManagement from "./DetailRowClientManagement.astro";

const rows = [
  {
    eyebrow: "Proof of Work Attachments",
    title: "Build trust with every invoice",
    description: "Attach photos, videos, or PDFs to show what's been completed at each milestone. Clients see progress and pay with confidence.",
    reverse: false,
    visualType: "desktop" as const,
    placeholder: "Screenshot of proof of work attachments",
  },
  {
    eyebrow: "Milestone Payments",
    title: "Get paid as you go",
    description: "Break your project into stages and collect payments for each completed phase.\n\nNo waiting until the end to get paid.",
    reverse: true,
    visualType: "phones" as const,
    placeholder: "Screenshot of milestone payment flow",
  },
  {
    eyebrow: "Transparent Billing",
    title: "Keep clients informed and confident",
    description: "Each invoice clearly lists completed work and costs. Clients know exactly what they're paying for, which means faster approvals and fewer disputes.",
    reverse: false,
    visualType: "isometric" as const,
    placeholder: "Screenshot of transparent billing view",
  },
  {
    eyebrow: "Built for Real Projects",
    title: "Works for every type of contractor",
    description: "Remodelers, design-build firms, and specialty trades all use Milestone Invoicing to stay organized, transparent, and paid on time.",
    reverse: true,
    visualType: "desktop" as const,
    placeholder: "Screenshot of contractor invoicing dashboard",
  },
];
---

<section class="relative z-[2] px-4 pb-4 bg-brand-800">
  <div class="max-w-[1920px] mx-auto bg-white rounded-3xl py-16 lg:py-24 overflow-hidden flex flex-col gap-20 lg:gap-40">
    {rows.map((r) => (
      <DetailRowClientManagement
        eyebrow={r.eyebrow}
        title={r.title}
        description={r.description}
        reverse={r.reverse}
        visualType={r.visualType}
        placeholder={r.placeholder}
      />
    ))}
  </div>
</section>
