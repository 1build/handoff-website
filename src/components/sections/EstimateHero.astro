---
import bgPattern from "@/assets/images/background-pattern.png";
import heroGlow from "@/assets/images/hero-glow-line.svg";
import estimatesImg from "@/assets/images/Heros/Estimates.webp";

---

<section class="relative overflow-hidden pt-20">
  <!-- Background grid pattern -->
  <div class="absolute top-0 -right-[50%] max-w-full pointer-events-none z-[-2]">
    <img src={bgPattern.src} alt="" class="w-full h-full block object-contain object-top" />
  </div>

  <!-- Glow line -->
  <div class="absolute -top-[24%] -left-[14%] -right-[14%] max-w-full -bottom-[24%] pointer-events-none z-[-1]">
    <img src={heroGlow.src} alt="" class="w-full h-full block" />
  </div>

  <!-- Content -->
  <div class="relative z-0 max-w-[1440px] mx-auto px-4 md:px-8 pt-20 pb-0 flex flex-col items-center text-center">
    <!-- Eyebrow -->
    <p class="font-mono text-sm font-semibold leading-6 tracking-[0.56px] uppercase text-text-on-brand-tertiary mb-6" data-animate="fade-up">
      Estimating AI
    </p>

    <!-- Heading -->
    <h1 class="font-display text-5xl sm:text-6xl lg:text-[72px] font-medium leading-[1.1] lg:leading-[90px] tracking-[-1.44px] text-white mb-6 max-w-[900px]" data-animate="fade-up">
      Create accurate AI-powered estimates <span class="text-text-highlight">in seconds</span>
    </h1>

    <!-- Description -->
    <div class="max-w-[700px] flex flex-col gap-4 mb-10" data-animate="fade-up">
      <p class="text-xl font-normal leading-[30px] text-white">
        Type a quick scope. Upload a photo or floor plan.
      </p>
      <p class="text-xl font-normal leading-[30px] text-white">
        Handoff reads your files, analyzes the job, and builds a clean, professional estimate using real-time local pricing, no spreadsheets needed.
      </p>
    </div>

    <!-- CTA -->
    <div class="mb-16 w-full" data-animate="fade-up">
      
      <a href="https://app.handoff.ai/sign-up/" class="inline-flex w-full md:w-auto items-center justify-center gap-1.5 px-5 py-3 text-base font-medium leading-6 rounded-xl transition-all duration-150 whitespace-nowrap bg-black/40 backdrop-blur-md text-white hover:bg-black/30">
      Start an estimate <span class="absolute inset-0 pointer-events-none rounded-[inherit] shadow-[inset_0px_0px_0px_1px_rgba(10,13,18,0.18),inset_0px_-2px_0px_0px_rgba(10,13,18,0.05)]"></span> </a>
    </div>

    <!-- Product mockup -->
    <div class="w-full max-w-[1216px]">
      <img
        src={estimatesImg.src}
        alt="Handoff estimating interface"
        class="w-full h-auto block"
        loading="eager"
      />
    </div>
  </div>

</section>
