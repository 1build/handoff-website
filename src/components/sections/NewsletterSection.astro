---

---

<section class="relative z-[2] px-4 bg-brand-800">
  <div class="max-w-[1920px] mx-auto bg-bg-secondary rounded-3xl py-24 overflow-hidden">
    <div class="max-w-[1280px] mx-auto px-8 text-center">
      <div class="max-w-[640px] mx-auto flex flex-col gap-6">
        <h2 class="font-display text-4xl font-medium leading-[44px] tracking-[-0.72px] text-text-primary">
          Stay ahead of the curve
        </h2>
        <p class="text-xl font-normal leading-[30px] text-text-secondary">
          Get weekly insights on AI, marketing, and growth strategies for contractors — delivered straight to your inbox.
        </p>
      </div>
      <form class="mt-10 max-w-[480px] mx-auto flex gap-3" onsubmit="return false;">
        <input
          type="email"
          placeholder="Enter your email"
          class="flex-1 px-4 py-3 rounded-xl border border-border-primary bg-white text-base text-text-primary placeholder:text-text-quaternary focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent"
        />
        <button
          type="submit"
          class="inline-flex items-center justify-center px-5 py-3 rounded-xl bg-brand-700 text-white font-medium text-base leading-6 shadow-[0px_1px_2px_0px_rgba(10,13,18,0.05),inset_0px_0px_0px_1px_rgba(10,13,18,0.18),inset_0px_-2px_0px_0px_rgba(10,13,18,0.05)] hover:bg-[#1a4a34] transition-all duration-150 cursor-pointer whitespace-nowrap"
        >
          Subscribe
        </button>
      </form>
    </div>
  </div>
</section>
