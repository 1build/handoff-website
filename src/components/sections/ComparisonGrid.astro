---
import comp1 from "@/assets/images/comone.png";
import comp2 from "@/assets/images/comtwo.png";
import comp3 from "@/assets/images/comthree.png";
import comp4 from "@/assets/images/comfour.png";
import comp5 from "@/assets/images/comfive.png";
import comp6 from "@/assets/images/comsix.png";
import comp7 from "@/assets/images/comseven.png";
import comp8 from "@/assets/images/comeight.png";
import comp9 from "@/assets/images/comnine.png";
import comp10 from "@/assets/images/comten.png";
import comp11 from "@/assets/images/comeleven.png";

const competitors = [
  {
    name: "JobThread",
    slug: "handoff-vs-jobtread",
    logo: comp1,
    logoAlt: "JobThread logo",
  },
  {
    name: "Contractor Foreman",
    slug: "handoff-vs-contractor-foreman",
    logo: comp2,
    logoAlt: "Contractor Foreman logo",
  },
  {
    name: "Markate",
    slug: "handoff-vs-markate",
    logo: comp3,
    logoAlt: "Markate logo",
  },
  {
    name: "SimplyWise",
    slug: "handoff-vs-simplywise",
    logo: comp4,
    logoAlt: "SimplyWise logo",
  },
  {
    name: "Xactimate",
    slug: "handoff-vs-xactimate",
    logo: comp5,
    logoAlt: "Xactimate logo",
  },
  {
    name: "Houzz Pro",
    slug: "handoff-vs-houzz-pro",
    logo: comp6,
    logoAlt: "Houzz Pro logo",
  },
  {
    name: "Housecall Pro",
    slug: "handoff-vs-housecall-pro",
    logo: comp7,
    logoAlt: "Housecall Pro logo",
  },
  {
    name: "Jobber",
    slug: "handoff-vs-jobber",
    logo: comp8,
    logoAlt: "Jobber logo",
  },
  {
    name: "Joist",
    slug: "handoff-vs-joist",
    logo: comp9,
    logoAlt: "Joist logo",
  },
  {
    name: "Homewyse",
    slug: "handoff-vs-homewyse",
    logo: comp10,
    logoAlt: "Homewyse logo",
  },
  {
    name: "ChatGPT",
    slug: "handoff-vs-chatgpt",
    logo: comp11,
    logoAlt: "ChatGPT logo",
  },
];
---

<section id="compare" class="py-6 px-4">
  <div
    class="bg-white border border-black/[0.04] rounded-[20px] max-w-[1920px] mx-auto py-24 flex flex-col gap-20 items-center overflow-hidden"
  >
    <!-- Heading -->
    <div class="max-w-[1280px] w-full px-8 flex flex-col items-center gap-0">
      <div class="flex flex-col items-center text-center gap-3 max-w-[768px] w-full" data-animate="fade-up">
        <p class="font-mono text-sm font-semibold leading-6 tracking-[0.56px] uppercase text-text-on-brand-tertiary">
          Compare with market
        </p>
        <h2
          class="font-display text-5xl font-medium leading-[60px] tracking-[-0.96px] text-text-primary w-full"
          style="font-variation-settings: 'opsz' 14, 'wdth' 100"
        >
          See how Handoff compares
        </h2>
      </div>
    </div>

    <!-- Cards grid -->
    <div class="w-full max-w-[1440px] px-8 flex flex-col gap-8">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8" data-animate="stagger">
        {
          competitors.map((competitor) => (
            <a
              href={`/comparison/${competitor.slug}`}
              class="group bg-bg-secondary border border-border-secondary rounded-[20px] flex flex-col items-start overflow-hidden lg:min-w-[320px] hover:border-border-primary transition-colors duration-200"
            >
              <!-- Logo image area -->
              <div class="p-2 w-full shrink-0">
                <div class="bg-white rounded-xl h-[180px] flex items-center justify-center overflow-hidden p-2 w-full">
                  <img
                    src={competitor.logo.src}
                    alt={competitor.logoAlt}
                    class="max-h-[80px] max-w-[200px] w-auto h-auto object-contain mix-blend-darken"
                  />
                </div>
              </div>

              <!-- Card content -->
              <div class="flex items-center gap-6 pt-3 pb-6 px-6 w-full">
                <div class="flex flex-col gap-2 flex-1 min-w-0">
                  <p class="font-body font-medium text-base leading-6 text-text-tertiary">Handoff vs.</p>
                  <p class="font-display font-semibold text-2xl leading-8 text-text-primary">{competitor.name}</p>
                </div>
                <!-- Arrow button -->
                <div class="border border-border-secondary rounded-full size-14 flex items-center justify-center shrink-0 group-hover:border-border-primary group-hover:bg-bg-secondary transition-colors duration-200">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="text-text-secondary"
                    aria-hidden="true"
                  >
                    <path d="m9 18 6-6-6-6" />
                  </svg>
                </div>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </div>
</section>
