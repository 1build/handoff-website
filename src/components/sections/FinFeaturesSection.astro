---
import StarIcon from "@/components/ui/StarIcon.astro";
import Button from "@/components/ui/Button.astro";
import featurePayment from "@/assets/icons/feature-payment.svg";
import featureStandard from "@/assets/icons/feature-standard.svg";
import featureComplete from "@/assets/icons/credit-card-check.svg";
import SupplierLogosCarousel from "./SupplierLogosCarousel.astro";

const sectionTitle = "Connected financial workflows mean faster payments";
const sectionSubtitle = "From first quote to final payment, Handoff keeps your money moving so you can stay focused on the job.";

const cards = [
  {
    icon: featurePayment.src,
    title: "Faster payment cycles",
    desc: "Money comes in as work gets done, not just at the end. Invoices go out automatically when milestones are hit, speeding up cash flow.",
  },
  {
    icon: featureStandard.src,
    title: "Standardized pricing",
    desc: "Consistent markup on every estimate means no more pricing inconsistencies. Every job protects your margins automatically.",
  },
  {
    icon: featureComplete.src,
    title: "Complete financial visibility",
    desc: "Track every dollar from estimate to payment with real-time profitability data. Make decisions based on facts, not guesswork.",
  },
];

const testimonialName = "Andrew B.";
const testimonialRole = "Chief Operating Officer";
const testimonialSource = "G2 review";
const testimonialRating = 5;
const testimonialQuote = "Required product for every toolbox! Handoff has helped us accelerate our business lifecycle and allows our human experts to do what they do best!";
const highlightText = "accelerate our business";

const parts = highlightText && testimonialQuote.includes(highlightText)
  ? [
      testimonialQuote.substring(0, testimonialQuote.indexOf(highlightText)),
      highlightText,
      testimonialQuote.substring(testimonialQuote.indexOf(highlightText) + highlightText.length),
    ]
  : [testimonialQuote];
---

<section id="features" class="relative z-[2] px-4 py-8 bg-transparent transition-colors duration-300">
  <div class="max-w-[1920px] mx-auto bg-white rounded-3xl border border-black/[0.04] py-16 lg:py-24 overflow-hidden flex flex-col gap-12 lg:gap-20">
    <!-- Header -->
    <div class="max-w-[1440px] px-6 lg:px-8 mx-auto w-full flex flex-col gap-5">
      <h2 class="font-display text-4xl lg:text-5xl font-medium leading-[44px] lg:leading-[60px] tracking-[-0.96px] text-text-primary">
        {sectionTitle}
      </h2>
      <p class="text-xl font-normal leading-[30px] text-text-tertiary">
        {sectionSubtitle}
      </p>
    </div>

    <!-- Grid -->
    <div class="max-w-[1440px] px-6 lg:px-8 mx-auto w-full grid grid-cols-1 lg:grid-cols-3 gap-8">
      {cards.map((f) => (
        <div class="bg-bg-secondary rounded-xl p-6 flex flex-col gap-16">
          <div class="w-12 h-12 bg-white rounded-md flex items-center justify-center shadow-3xl">
            <img src={f.icon} alt="" class="w-6 h-6" loading="lazy" decoding="async" />
          </div>
          <div class="flex flex-col gap-4">
            <h3 class="font-display text-2xl font-medium leading-8 text-text-primary">{f.title}</h3>
            <p class="text-lg font-normal leading-7 text-text-tertiary">{f.desc}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- Testimonial -->
    <div class="bg-bg-secondary rounded-xl p-4 md:p-8 lg:p-12 flex flex-col gap-8 mx-6 lg:mx-8 -mt-12 max-w-[calc(1440px-64px)] w-[calc(100%-48px)] lg:w-[calc(100%-64px)] self-center" data-animate="fade-up">
      <!-- Header -->
      <div class="flex items-center gap-4">
        <div class="flex gap-1">
          {Array.from({ length: testimonialRating }).map(() => <StarIcon />)}
        </div>
        <span class="text-base font-medium text-text-quaternary">{testimonialRating}/5</span>
      </div>

      <!-- Quote -->
      <blockquote class="font-display text-[28px] lg:text-4xl font-medium leading-9 lg:leading-[44px] tracking-[-0.72px] text-text-primary">
        {parts.length === 3 ? (
          <Fragment>
            {parts[0]}<span class="text-brand-accent">{parts[1]}</span>{parts[2]}
          </Fragment>
        ) : (
          testimonialQuote
        )}
      </blockquote>

      <!-- Footer -->
      <div class="flex flex-col sm:flex-row items-start sm:items-center gap-6 sm:gap-16">
        <div class="flex flex-col gap-1">
          <p class="text-lg font-semibold leading-7 text-text-primary">— {testimonialName}</p>
          <p class="text-base font-normal leading-6 text-text-tertiary">{testimonialRole} • {testimonialSource}</p>
        </div>
        <Button variant="secondary-outline">View more testimonials</Button>
      </div>
    </div>
    <SupplierLogosCarousel />
  </div>
</section>
