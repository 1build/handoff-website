---
import modernMockup from "@/assets/images/Modern-screen-mockup.png";
---

<section class="px-4 pt-4">
<div class="relative z-[2] overflow-hidden py-10 md:py-16 lg:py-20 bg-gradient-to-b from-[#BAC7BE] to-[#F4F6F4] rounded-3xl" data-animate="fade-up">
  <div
    class="max-w-[1280px] mx-auto px-4 sm:px-6 md:px-8"
  >
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-14 items-center">
      <div class="space-y-6 text-left">
        <div class="space-y-4">
          <h2 class="font-display text-3xl md:text-5xl text-text-primary font-semibold leading-tight tracking-[-0.02em]">
            Your next phase needs better systems
          </h2>
          
        </div>

        <ul class="space-y-5 text-base md:text-[18px] text-[#414651]">
          <li class="flex items-start gap-2">
            <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
<g clip-path="url(#clip0_9757_392)">
<path d="M8.75004 14.0002L12.25 17.5002L19.25 10.5002M25.6667 14.0002C25.6667 20.4435 20.4434 25.6668 14 25.6668C7.55672 25.6668 2.33337 20.4435 2.33337 14.0002C2.33337 7.55684 7.55672 2.3335 14 2.3335C20.4434 2.3335 25.6667 7.55684 25.6667 14.0002Z" stroke="#335645" stroke-width="2.33333" stroke-linecap="round" stroke-linejoin="round"/>
</g>
<defs>
<clipPath id="clip0_9757_392">
<path d="M0 14C0 6.26801 6.26801 0 14 0C21.732 0 28 6.26801 28 14C28 21.732 21.732 28 14 28C6.26801 28 0 21.732 0 14Z" fill="white"/>
</clipPath>
</defs>
</svg>

            <span>30-day free trial</span>
          </li>
          <li class="flex items-start gap-2">
            <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
<g clip-path="url(#clip0_9757_392)">
<path d="M8.75004 14.0002L12.25 17.5002L19.25 10.5002M25.6667 14.0002C25.6667 20.4435 20.4434 25.6668 14 25.6668C7.55672 25.6668 2.33337 20.4435 2.33337 14.0002C2.33337 7.55684 7.55672 2.3335 14 2.3335C20.4434 2.3335 25.6667 7.55684 25.6667 14.0002Z" stroke="#335645" stroke-width="2.33333" stroke-linecap="round" stroke-linejoin="round"/>
</g>
<defs>
<clipPath id="clip0_9757_392">
<path d="M0 14C0 6.26801 6.26801 0 14 0C21.732 0 28 6.26801 28 14C28 21.732 21.732 28 14 28C6.26801 28 0 21.732 0 14Z" fill="white"/>
</clipPath>
</defs>
</svg>

            <span>Personalized onboarding for your team</span>
          </li>
          <li class="flex items-start gap-2">
           <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
<g clip-path="url(#clip0_9757_392)">
<path d="M8.75004 14.0002L12.25 17.5002L19.25 10.5002M25.6667 14.0002C25.6667 20.4435 20.4434 25.6668 14 25.6668C7.55672 25.6668 2.33337 20.4435 2.33337 14.0002C2.33337 7.55684 7.55672 2.3335 14 2.3335C20.4434 2.3335 25.6667 7.55684 25.6667 14.0002Z" stroke="#335645" stroke-width="2.33333" stroke-linecap="round" stroke-linejoin="round"/>
</g>
<defs>
<clipPath id="clip0_9757_392">
<path d="M0 14C0 6.26801 6.26801 0 14 0C21.732 0 28 6.26801 28 14C28 21.732 21.732 28 14 28C6.26801 28 0 21.732 0 14Z" fill="white"/>
</clipPath>
</defs>
</svg>

            <span>Access to the full platform</span>
          </li>
        </ul>

        <div class="flex flex-col sm:flex-row gap-3 pt-2">
          <a
            href="#"
            class="inline-flex items-center justify-center px-5 py-3 text-base font-medium text-white rounded-xl bg-brand-700 border border-brand-600 hover:bg-brand-800 transition-colors duration-150"
          >
            Get started
          </a>
          <a
            href="#"
            class="inline-flex items-center justify-center px-5 py-3 rounded-xl text-base font-medium border border-border-primary bg-white text-text-primary hover:bg-neutral-50 transition-colors"
          >
            Book a demo
          </a>
        </div>
      </div>

      <div class="w-full rounded-2xl">
        <img
            src={modernMockup.src}
            alt="Handoff modern estimate and project view"
            class="w-full h-auto block rounded-2xl"
            loading="lazy"
            decoding="async"
          />
      </div>
    </div>
  </div>
    </div>
</section>

