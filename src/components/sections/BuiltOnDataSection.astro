---
import builtBg from "@/assets/images/built-bg.png";
import builtLogo from "@/assets/images/built-logo.png";
import connectoricon from "@/assets/images/built-icon.png";
import connectoricon2 from "@/assets/images/built-icon2.png";
import bgPattern from "@/assets/images/background-pattern-built.png";
import heroGlow from "@/assets/images/hero-glow-line.svg";

const primaryFeatures = [
  {
    title: "Project history",
    description: "100,000+ completed estimates from real residential projects",
    icon: "project",
  },
  {
    title: "Real-time pricing",
    description: "60M+ SKUs tracked across major construction suppliers",
    icon: "pricing",
  },
  {
    title: "Supplier",
    description: "Manufacturer-backed pricing data from Home Depot, Lowe's, and more",
    icon: "manufacturer",
  },
  {
    title: "Regional intelligence",
    description: "Local cost intelligence — priced by ZIP code, not national averages",
    icon: "regional",
  },
];

const secondaryItems = [
  { label: "Estimates", icon: "estimates" },
  { label: "Invoice & Payments", icon: "invoice" },
  { label: "Proposals", icon: "proposals" },
  { label: "Photos & Files", icon: "photos" },
  { label: "Catalogs", icon: "catalogs" },
  { label: "Scheduling", icon: "job" },
  { label: "Integrations", icon: "integrations" },
  { label: "Takeoffs", icon: "takeoffs" },
  { label: "Scopes & Documents", icon: "scopes" },
  { label: "CRM", icon: "crm" },
];
---

<section class="relative z-[2] px-4 py-12 md:py-20" data-animate="fade-up">
  
  <div class="absolute -bottom-1/2 right-0  pointer-events-none z-[0]">
    <img src={bgPattern.src} alt="" class="w-full h-full block object-contain object-top" />
  </div>

  <div class="absolute -top-[24%] -left-[14%] -right-[14%] -bottom-[24%] pointer-events-none z-[0]">
    <img src={heroGlow.src} alt="" class="w-full h-full block" />
  </div>
  <div class="relative z-[1] max-w-[1440px] mx-auto px-4 sm:px-6 md:px-8">
    <!-- Header: badge + title + subtitle -->
    <div class="text-center max-w-[600px] mx-auto mb-8 md:mb-12">
      
      <a href="/ai-agent" class="inline-flex items-center gap-2 rounded-full backdrop-blur-[19px] bg-[#244232] pl-3 pr-3 py-1 mb-8 transition-opacity hover:opacity-80">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
<path d="M6.43072 1.26416C6.79182 -0.413202 9.16299 -0.424991 9.53882 1.25057L9.59674 1.50882C10.1693 4.06167 12.1897 6.00393 14.7079 6.44942C16.4307 6.75418 16.4307 9.24587 14.7079 9.55063C12.1897 9.99612 10.1693 11.9384 9.59674 14.4912L9.53882 14.7495C9.16299 16.425 6.79182 16.4132 6.43072 14.7359L6.38302 14.5142C5.83117 11.9509 3.81254 9.99339 1.28903 9.54698C-0.429677 9.24292 -0.429677 6.75712 1.28903 6.45307C3.81254 6.00665 5.83117 4.04918 6.38302 1.48577L6.43072 1.26416Z" fill="url(#paint0_linear_9646_15072)"/>
<defs>
<linearGradient id="paint0_linear_9646_15072" x1="4.11111" y1="4.1111" x2="15.7778" y2="15.7778" gradientUnits="userSpaceOnUse">
<stop stop-color="#009C51"/>
<stop offset="1" stop-color="#61C293"/>
</linearGradient>
</defs>
</svg>

<span class="flex text-xs font-medium text-[#ABEFC6]">The AI agent for contractors</a>
      <h2 class="font-display text-3xl sm:text-4xl md:text-[2.5rem] lg:text-[2.75rem] font-semibold leading-[1.2] tracking-[-0.02em] text-white mb-4">
        Trained on Real Construction. <span class="text-[#47CD89]">Not Generic AI Guesswork.</span>
      </h2>
      <p class="text-base md:text-lg text-white/90 leading-relaxed font-normal">
        Most AI tools are built for everyone — which means they're built for no one. Handoff is different. Your AI Teammate is trained on real residential construction projects, real contractor pricing, and real job site conditions. When it estimates a bathroom remodel in Phoenix, it's not guessing. It knows.
      </p>
    </div>

    <div class="relative z-[99]">
   
      <div class="grid grid-cols-2 md:grid-cols-4 gap-3 md:gap-5 mb-0">
        {primaryFeatures.map((f) => (
          <div class="p-3 md:p-8 md:px-6 rounded-[20px] backdrop-blur-[3px] border border-white/[0.16] text-center flex flex-col gap-4 h-full" style="background-color: rgba(0,0,0,0.16);">
            <div class="flex justify-center">
