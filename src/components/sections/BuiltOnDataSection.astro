      </div>
<div class="flex justify-center max-w-[900px] mx-auto">
      <img src={connectoricon.src} alt="" class="w-full block" />
</div>
      <div class="flex justify-center">
        <img src={builtLogo.src} alt="Handoff" class="w-35 h-35 object-contain" />
      </div>
    </div>
<div class="relative overflow-visible" style="width: 2px; margin: 0 auto;">
      <img src={connectoricon2.src} alt="" class="w-full block" />
      <div class="connector-orb"></div>
</div>
