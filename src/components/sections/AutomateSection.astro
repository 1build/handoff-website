---
import SupplierLogosCarousel from "./SupplierLogosCarousel.astro";

const features = [
  {
    title: "Reclaim your time",
    description: "Regain valuable time with our efficient AI estimator. Let it crunch the numbers for you.",
    icon: "clock-plus",
  },
  {
    title: "Estimate anywhere, anytime",
    description: "Provide the client with an accurate estimate without leaving their house.",
    icon: "file-check",
  },
  {
    title: "Bid with expertise",
    description: "Handoff ensures accuracy, eliminating worries about bidding.",
    icon: "scale",
  },
];
---

<section class="px-4 pt-4">
  <div
    class="bg-white border border-black/[0.04] rounded-3xl overflow-hidden py-24 flex flex-col gap-20 items-center"
    data-animate="fade-up"
  >
    <!-- Heading -->
    <div class="w-full max-w-[1440px] px-8">
      <h2 class="font-display text-5xl font-medium leading-tight tracking-[-0.02em] text-text-primary max-w-2xl">
        Automate your contracting<br />business with AI
      </h2>
    </div>

    <!-- Feature cards -->
    <div class="w-full max-w-[1440px] px-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {features.map((feature) => (
          <div class="bg-bg-secondary rounded-xl p-6 flex flex-col gap-16 justify-between min-h-[264px]">
            <!-- Icon -->
            <div class="bg-white rounded-md p-3 inline-flex items-center shadow-[0px_32px_64px_-12px_rgba(10,13,18,0.14),0px_5px_5px_-2.5px_rgba(10,13,18,0.04)] w-fit">
              {feature.icon === "clock-plus" && (
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <path d="M12 6V12L16 14M22 12C22 17.5228 17.5228 22 12 22C6.47715 22 2 17.5228 2 12C2 6.47715 6.47715 2 12 2C17.5228 2 22 6.47715 22 12Z" stroke="#181D27" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  <path d="M19 3V7M17 5H21" stroke="#181D27" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              )}
              {feature.icon === "file-check" && (
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <path d="M9 12L11 14L15 10M14 3H8.8C7.11984 3 6.27976 3 5.63803 3.32698C5.07354 3.6146 4.6146 4.07354 4.32698 4.63803C4 5.27976 4 6.11984 4 7.8V16.2C4 17.8802 4 18.7202 4.32698 19.362C4.6146 19.9265 5.07354 20.3854 5.63803 20.673C6.27976 21 7.11984 21 8.8 21H15.2C16.8802 21 17.7202 21 18.362 20.673C18.9265 20.3854 19.3854 19.9265 19.673 19.362C20 18.7202 20 17.8802 20 16.2V9M14 3L20 9M14 3V7.4C14 7.96005 14 8.24008 14.109 8.45399C14.2049 8.64215 14.3578 8.79513 14.546 8.89101C14.7599 9 15.0399 9 15.6 9H20" stroke="#181D27" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              )}
              {feature.icon === "scale" && (
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <path d="M12 3V21M12 3L8 7M12 3L16 7M5 10L2 17H8L5 10ZM19 10L16 17H22L19 10ZM3 21H21" stroke="#181D27" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              )}
            </div>

            <!-- Text -->
            <div class="flex flex-col gap-4">
              <p class="font-display text-2xl font-medium leading-8 text-text-primary">
                {feature.title}
              </p>
              <p class="text-lg text-text-tertiary leading-7">
                {feature.description}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Supplier logos -->
    <div class="w-full">
      <SupplierLogosCarousel />
    </div>
  </div>
</section>
