---
import bgPattern from "@/assets/images/background-pattern.png";
import heroGlow from "@/assets/images/hero-glow-line.svg";
---

<section class="relative overflow-hidden pt-20">
  <!-- Background grid pattern -->
  <div class="absolute top-0 -right-[50%] max-w-full pointer-events-none z-0">
    <img src={bgPattern.src} alt="" class="w-full h-full block object-contain object-top" />
  </div>

  <!-- Glow line -->
  <div class="absolute -top-[24%] -left-[14%] -right-[14%] max-w-full -bottom-[24%] pointer-events-none z-[1]">
    <img src={heroGlow.src} alt="" class="w-full h-full block" />
  </div>

  <!-- Content -->
  <div class="relative z-[2] max-w-[1280px] mx-auto px-8 pt-24 flex flex-col items-center text-center">
    <!-- Subtitle label -->
    <p class="font-mono text-sm font-semibold leading-6 tracking-[0.56px] uppercase text-text-on-brand-tertiary mb-3">
      Instructions &amp; Templates
    </p>

    <!-- Heading -->
    <h1 class="font-display text-5xl sm:text-6xl lg:text-[72px] font-medium leading-[1.1] lg:leading-[90px] tracking-[-1.44px] text-white mb-6 max-w-[1024px]">
      Train an <span class="text-text-highlight">AI Teammate</span> to run your construction business
    </h1>

    <!-- Description -->
    <p class="text-xl font-medium leading-[30px] text-white max-w-[768px] mb-12">
      Stop double-checking every estimate your team sends. Built for contractors, Handoff's trained AI applies your markup rules, templates, and real pricing, so every output looks like your business, every time.
    </p>

    <!-- CTA Button -->
    <div class="flex justify-center mb-16 w-full">
      <a href="https://app.handoff.ai/sign-up/" class="inline-flex w-full md:w-auto items-center justify-center gap-1.5 px-5 py-3 text-base font-medium leading-6 rounded-xl transition-all duration-150 whitespace-nowrap bg-black/40 backdrop-blur-md text-white hover:bg-black/30">
        See how it works
      </a>
    </div>

    <!-- Placeholder content area -->
    <div class="w-full max-w-[1440px] h-[461px] rounded-3xl bg-white/12">
    </div>
  </div>
</section>
