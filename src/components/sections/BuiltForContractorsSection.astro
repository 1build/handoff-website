---
import placeholderImg from "@/assets/images/placeholder-img.png";
import Builtimg from "@/assets/images/built-img.png";
import Builtimg1 from "@/assets/images/built-img1.png";
import Builtimg2 from "@/assets/images/built-img2.png";

const heroBullets = [
  { title: "Share team inboxes", desc: "Whether you have a team of 2 or 200, our shared team inboxes" },
  { title: "Share team inboxes", desc: "Whether you have a team of 2 or 200, our shared team inboxes" },
  { title: "Share team inboxes", desc: "Whether you have a team of 2 or 200, our shared team inboxes" },
  { title: "Share team inboxes", desc: "Whether you have a team of 2 or 200, our shared team inboxes" },
];

type FeatureTile = {
  title: string;
  description: string;
  learnMoreHref?: string;
  imageSrc?: string;
};

const featureTiles: FeatureTile[] = [
  {
    title: "Build your custom catalogs",
    description: "Add your own rates for labor, materials, and specialty items. Reuse them across every estimate. The AI pulls from your catalogs first, then fills gaps with supplier pricing.",
    learnMoreHref: "#",
    imageSrc: Builtimg1.src,
  },
  {
    title: "Train AI with your presets",
    description: "Add your rates for labor, materials, and specialty items. The AI uses your catalogs first, then fills gaps with live supplier pricing and our AI-trained cost data.",
    learnMoreHref: "#",
    imageSrc: Builtimg2.src,
  },
  {
    title: "Train AI with your presets",
    description: "Add your rates for labor, materials, and specialty items. The AI uses your catalogs first, then fills gaps with live supplier pricing and our AI-trained cost data.",
    learnMoreHref: "#",
    imageSrc: Builtimg2.src,
  },
  {
    title: "Train AI with your presets",
    description: "Add your rates for labor, materials, and specialty items. The AI uses your catalogs first, then fills gaps with live supplier pricing and our AI-trained cost data.",
    learnMoreHref: "#",
    imageSrc: Builtimg2.src,
  },
  {
    title: "Train AI with your presets",
    description: "Add your rates for labor, materials, and specialty items. The AI uses your catalogs first, then fills gaps with live supplier pricing and our AI-trained cost data.",
    learnMoreHref: "#",
    imageSrc: Builtimg2.src,
  },
  {
    title: "Train AI with your presets",
    description: "Add your rates for labor, materials, and specialty items. The AI uses your catalogs first, then fills gaps with live supplier pricing and our AI-trained cost data.",
    learnMoreHref: "#",
    imageSrc: Builtimg2.src,
  },
];

function chunk<T>(arr: T[], size: number): T[][] {
  const out: T[][] = [];
  for (let i = 0; i < arr.length; i += size) out.push(arr.slice(i, i + size));
  return out;
}

const featureRows = chunk(featureTiles, 2);
---
<section class="px-4">
<div class="relative z-[2] overflow-hidden py-10 md:py-16 lg:py-20 bg-white rounded-3xl" data-animate="fade-up">
  <div class="max-w-[1440px] mx-auto px-4 sm:px-6 md:px-8">
    <!-- Hero: Built for the way contractors actually work -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-start mb-16 lg:mb-24">
      <div class="order-2 lg:order-1">
        <p class="text-sm font-medium tracking-wide uppercase text-neutral-500 mb-3">Everything you need</p>
        <h2 class="font-display text-3xl sm:text-4xl lg:text-[2.75rem] font-semibold leading-tight tracking-[-0.02em] text-text-primary mb-5">
          Built for the way contractors actually work
        </h2>
        <p class="text-base lg:text-lg leading-relaxed text-text-secondary mb-12">
          Talk while driving to the next site. Upload plans from your phone. Get pricing from the suppliers you already use. Handoff fits into your day instead of adding more steps to it.
        </p>
        <ul class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {heroBullets.map((b) => (
            <li class="flex gap-3">
              <span class="shrink-0 mt-0.5">
                <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
<path fill-rule="evenodd" clip-rule="evenodd" d="M2.5 8.3335C2.5 4.19136 5.85786 0.833496 10 0.833496C14.1421 0.833496 17.5 4.19136 17.5 8.3335C17.5 10.4386 16.5443 12.2837 15.2436 13.9727C14.1566 15.384 12.7653 16.7633 11.3755 18.141L11.3746 18.142C11.1121 18.4022 10.8496 18.6624 10.5893 18.9228C10.2638 19.2482 9.73618 19.2482 9.41074 18.9228C9.15022 18.6622 8.887 18.4013 8.6243 18.1409C7.23455 16.7632 5.84337 15.384 4.75643 13.9727C3.45569 12.2837 2.5 10.4386 2.5 8.3335ZM12.5 8.3335C12.5 9.71421 11.3807 10.8335 10 10.8335C8.61929 10.8335 7.5 9.71421 7.5 8.3335C7.5 6.95278 8.61929 5.8335 10 5.8335C11.3807 5.8335 12.5 6.95278 12.5 8.3335Z" fill="black"/>
</svg>

              </span>
              <div class="flex flex-col gap-3">
                <span class="font-semibold text-text-primary">{b.title}</span>
                <span class="text-text-secondary">{b.desc}</span>
              </div>
            </li>
          ))}
        </ul>
      </div>
      <div class="order-1 lg:order-2 flex justify-center lg:justify-end">
        <div class="relative w-full max-w-[560px] ">
          <img
              src={Builtimg.src}
              alt=""
              class="w-full h-full object-cover rounded-xl"
              loading="lazy"
              decoding="async"
            />
        </div>
      </div>
    </div>

    <!-- Feature grid -->
    <div class="space-y-16 lg:space-y-24">
      {featureRows.map((row) => (
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-start">
          {row.map((tile) => (
            <div class="flex flex-col gap-4">
              <h3 class="font-display text-2xl font-semibold leading-tight text-text-primary">
                {tile.title}
              </h3>
              <p class="text-base lg:text-lg text-text-tertiary">
                {tile.description}
              </p>
              <a href={tile.learnMoreHref ?? "#"} class="inline-flex items-center gap-3 text-brand-600 font-semibold hover:text-brand-700 transition-colors">
                Learn more
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M0.833496 6.66683H12.5002M12.5002 6.66683L6.66683 0.833496M12.5002 6.66683L6.66683 12.5002" stroke="#4E6D5D" stroke-width="1.66667" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
              <div class="mt-3 min-h-[250px] max-h-[250px] md:min-h-[350px] md:max-h-[350px] relative w-full aspect-video rounded-2xl overflow-hidden bg-brand-600 flex items-center justify-center">
                  <img
                    src={tile.imageSrc ?? placeholderImg.src}
                    alt=""
                    class="w-full h-full object-cover rounded-2xl"
                    loading="lazy"
                    decoding="async"
                  />
                </div>
            </div>
          ))}
        </div>
      ))}
    </div>
  </div>
   </div>
</section>
