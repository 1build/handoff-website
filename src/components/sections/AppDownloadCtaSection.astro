---
import modernMockup from "@/assets/images/phonemockup.png";
import AppsCta from "@/components/ui/AppsCta.astro";
---

<section class="px-4">
<div class="max-w-[1920px] mx-auto relative z-[2] overflow-hidden py-10 md:py-16 lg:py-20 bg-gradient-to-b from-[#BAC7BE] to-[#F4F6F4] rounded-3xl" data-animate="fade-up">
  <div class="max-w-[1280px] mx-auto px-4 sm:px-6 md:px-8">
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-center">
      <div class="space-y-6 text-left xl:pt-[70px] xl:pb-[165px]">
        <div class="space-y-4">
          <h2 class="font-display text-3xl md:text-5xl text-text-primary font-semibold leading-tight tracking-[-0.02em]">
            Run your contracting business with AI
          </h2>
          
        </div>

        <p class="text-lg font-normal leading-7 text-text-tertiary">andoff is a complete toolkit to help you scale your contracting business with artificial intelligence. <p>
                <p class="text-lg font-normal leading-7 text-text-tertiary">Use our AI to create estimates, send proposals, issue invoices, manage your clients in a CRM and a lot more.<p>
        <div class="flex flex-col sm:flex-row gap-3 pt-2">
          <AppsCta store="apple" />
          <AppsCta store="google" />
        </div>
      </div>

      <div class="w-full flex justify-center lg:justify-end">
        <div class="w-full max-w-[640px] rounded-[28px] overflow-hidden shadow-[0_32px_80px_rgba(10,13,18,0.45)] border border-white/40 bg-black/10">
          <img
            src={modernMockup.src}
            alt="Handoff modern estimate and project view"
            class="w-full h-auto block xl:absolute xl:max-w-[750px] bottom-[10%] right-0 "
            loading="lazy"
            decoding="async"
          />
        </div>
      </div>
    </div>
  </div>
</div>
</section>

