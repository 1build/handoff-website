---
import platform1Img from "@/assets/images/platform1.png";

const platformImages = [platform1Img, platform1Img, platform1Img, platform1Img, platform1Img, platform1Img];

const features = [
  {
    title: "Estimate from anything",
    description: "AI generates accurate estimates from photos, plans, or voice notes",
  },
  {
    title: "Scope that writes itself",
    description: "Turn estimates into professional scope documents automatically",
  },
  {
    title: "learns how you work",
    description: "Pricing, preferences, and labor rates improve with every project",
  },
  {
    title: "Built-in supplier pricing",
    description: "Real costs from Lowe's and Home Depot, updated automatically",
  },
  {
    title: "Scope and materials",
    description: "Material lists and labor requirements generated together",
  },
  {
    title: "Proposals that close",
    description: "Send professional proposals clients can sign and approve",
  },
];
---

<section class="relative z-[2] border-t border-[#E9EAEB]"  data-animate="fade-up">
  <div class="max-w-[1440px] mx-auto px-4 sm:px-6 md:px-8 py-12 md:py-20">
    <!-- Header: mobile = stacked; desktop = title+subtitle left, CTA right -->
    <div class="flex flex-col gap-4 mb-8 md:mb-10 md:flex-row md:items-end md:justify-between md:gap-8">
      <div class="flex flex-col gap-2">
        <h2 class="font-display text-2xl sm:text-3xl md:text-4xl font-semibold leading-tight tracking-[-0.02em] text-text-primary">
          Everything you need, in one platform
        </h2>
        <p class="text-base text-text-tertiary leading-relaxed max-w-[560px]">
          One platform. No tool-stitching, no workarounds, no re-keying.
        </p>
      </div>
      <a
        href="#"
        class="inline-flex items-center justify-center shrink-0 w-full md:w-auto px-5 py-3 text-base font-medium text-white rounded-xl bg-brand-700 border border-brand-600 hover:bg-brand-800 transition-colors duration-150"
      >
        See the full list
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-5 md:gap-8">
      {features.map((feature, i) => (
        <article class="flex flex-col rounded-2xl bg-white border border-[#E9EAEB] overflow-hidden">
          <div class="h-[260px] overflow-hidden">
            <img
              src={platformImages[i].src}
              alt=""
              class="w-full h-full object-cover max-h-[260px]"
              loading="lazy"
              decoding="async"
            />
          </div>
          <div class="p-4 sm:py-6 bg-[#F4F6F4]">
            <div class="flex items-end justify-between gap-4">
              <div>
                <p class="text-sm font-semibold text-text-quaternary uppercase mb-1">
                  {feature.title}
                </p>
                <p class="text-base md:text-lg text-text-primary leading-relaxed">
                  {feature.description}
                </p>
              </div>
              <button
                type="button"
                class="hidden sm:inline-flex items-center justify-center w-12 h-12 rounded-full border border-[#E9EAEB] bg-transparent text-neutral-700 hover:bg-white transition-colors"
                aria-hidden="true"
                tabIndex={-1}
              >
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
<path d="M9 18L15 12L9 6" stroke="#414651" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
</svg>

              </button>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
