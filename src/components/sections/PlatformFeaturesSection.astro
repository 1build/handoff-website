---
import platform1Img from "@/assets/images/platform1.png";

const platformImages = [platform1Img, platform1Img, platform1Img, platform1Img, platform1Img];

const features = [
  {
    title: "Lock In Your Process",
    description: "Your AI Teammate runs every estimate through your rates, markup rules, and approval steps. New hire? They estimate like a 10-year veteran on day one. No guesswork. No margin leaks.",
  },
  {
    title: "Coordinate Without the Chaos",
    description: "Walkthroughs, project phases, and crew schedules in one place. Less phone tag. Fewer delays. More jobs done and billed.",
  },
  {
    title: "Stay One Step Ahead",
    description: "Real-time alerts when approvals stall, change orders come in, or a project needs attention. You never have to micromanage what your AI Teammate is already watching.",
  },
  {
    title: "Go from First Contact to Signed Proposal in Under 24 Hours",
    description: "Your AI Teammate handles the estimate while you're still on the drive home. Your crew starts while your competition is still writing up the bid.",
  },
  {
    title: "Grow Without Losing Control",
    description: "Role-based permissions keep your markup, approvals, and workflows locked as your team grows. Bigger business, same margins, less chaos.",
  },
];
---

<section class="relative z-[2] border-t border-[#E9EAEB]"  data-animate="fade-up">
  <div class="max-w-[1440px] mx-auto px-4 sm:px-6 md:px-8 py-12 md:py-20">
    <!-- Header: mobile = stacked; desktop = title+subtitle left, CTA right -->
    <div class="flex flex-col gap-4 mb-8 md:mb-10 md:flex-row md:items-end md:justify-between md:gap-8">
      <div class="flex flex-col gap-2">
        <h2 class="font-display text-2xl sm:text-3xl md:text-4xl font-semibold leading-tight tracking-[-0.02em] text-text-primary">
          The Contractors Winning Right Now All Have<br />One Thing in Common.
        </h2>
        <p class="text-base text-text-tertiary leading-relaxed max-w-[560px]">
          It's not that they work harder. They move faster. First to bid. First to win. First payment collected. Handoff is that edge.
        </p>
      </div>
      <a
        href="/instant-ai-estimates"
        class="inline-flex items-center justify-center shrink-0 w-full md:w-auto px-5 py-3 text-base font-medium text-white rounded-xl bg-brand-700 border border-brand-600 hover:bg-brand-800 transition-colors duration-150"
      >
        Learn more
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-5 md:gap-8">
      {features.map((feature, i) => (
        <article class="flex flex-col rounded-2xl bg-white border border-[#E9EAEB] overflow-hidden">
          <div class="h-[260px] overflow-hidden">
            <img
              src={platformImages[i].src}
              alt=""
              class="w-full h-full object-cover max-h-[260px]"
              loading="lazy"
              decoding="async"
            />
          </div>
          <div class="p-4 sm:py-6 bg-[#F4F6F4] flex-1">
            <div class="flex items-start justify-between gap-4">
              <div>
                <p class="text-sm font-semibold text-text-quaternary uppercase mb-1">
                  {feature.title}
                </p>
                <p class="text-base md:text-lg text-text-primary leading-relaxed">
                  {feature.description}
                </p>
              </div>
              <button
                type="button"
                class="flex-shrink-0 self-end inline-flex items-center justify-center w-14 h-14 rounded-full border border-neutral-200 bg-transparent text-neutral-700 hover:bg-neutral-50 transition-colors"
              >
                <svg
                  width="24"
                  height="24"
                  viewBox="0 0 24 24"
                  fill="none"
                  xmlns="http://www.w3.org/2000/svg"
                >
                  <path
                    d="M9 18L15 12L9 6"
                    stroke="#414651"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
              </button>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
