---
const locations = [
  "Albuquerque, FL",
  "Orlando, FL",
  "Oregon City, OR",
  "Orange, CA",
  "Orlinda, CA",
  "Oroville, CA",
  "Austin, TX",
  "Phoenix, AZ",
  "Denver, CO",
  "Dallas, TX",
  "Chicago, IL",
  "Seattle, WA",
] as const;

const categories = [
  "All",
  "Concrete & Masonry",
  "Doors & Windows",
  "Electrical",
  "HVAC",
  "Interior Finishes",
  "Plumbing",
  "Roofing",
  "Siding",
  "Site work & Landscaping",
];
---

<section class="pt-24 pb-12">
  <div class="bg-brand-800">
  <div class="max-w-[768px] mx-auto px-4 sm:px-6 text-center">
    <h1
      class="font-display text-4xl sm:text-[44px] font-bold leading-[1.2] tracking-tight text-white"
      data-animate="fade-up"
    >
      Construction costs for contractors
    </h1>
    <p class="mt-4 text-base text-white/70 leading-relaxed max-w-xl mx-auto" data-animate="fade-up">
      Get accurate, up-to-date construction cost estimates for any project.
    </p>
    <p class="mt-2 text-sm text-white/50 leading-relaxed max-w-2xl mx-auto" data-animate="fade-up">
      Search our free online construction estimating database below to find accurate construction
      cost estimates for different types of projects in your local area.
    </p>

    <!-- Search bar -->
    <div
      class="mt-6 flex flex-col md:flex-row items-stretch bg-white rounded-2xl shadow-xs overflow-visible"
      data-animate="fade-up"
    >
      <div class="flex flex-1 items-center gap-2.5 px-4 py-3 min-w-0">
        <svg
          class="w-4 h-4 text-neutral-400 shrink-0"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
          aria-hidden="true"
        >
          <circle cx="11" cy="11" r="8"></circle>
          <path d="m21 21-4.35-4.35"></path>
        </svg>
        <input
          id="calc-search"
          type="text"
          placeholder="Find a service"
          class="flex-1 text-sm text-text-primary placeholder:text-text-quaternary bg-transparent outline-none min-w-0 py-0.5"
          autocomplete="off"
        />
      </div>
      <div class="relative shrink-0" id="location-dropdown-wrap">
        <button
          type="button"
          id="location-dropdown-trigger"
          class="flex items-start border-l border-l-[#D5D7DA] min-w-[200px] flex-col gap-1.5 px-4 py-3 border-l border-transparent transition-colors shrink-0"
          aria-label="Change location"
          aria-expanded="false"
          aria-haspopup="listbox"
        >
          <span class="text-sm text-text-quaternary hidden sm:flex items-center gap-1">Location <svg class="h-4 w-4" viewBox="0 0 16 16" fill="none">
                <circle cx="8" cy="8" r="6.5" stroke="currentColor"></circle>
                <path
                  d="M8 7v4"
                  stroke="currentColor"
                  stroke-linecap="round"></path>
                <circle cx="8" cy="5.5" r=".5" fill="currentColor"></circle>
              </svg></span>
          <span class="flex items-center flex-row w-full justify-between">
          <span id="location-display" class="text-lg font-medium text-text-primary">Albuquerque, FL</span>
          <svg
            class="w-4 h-4 text-neutral-400"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
            aria-hidden="true"
          >
            <path d="M6 9l6 6 6-6"></path>
          </svg>
          </span>
        </button>
        <div
          id="location-dropdown-panel"
          class="absolute right-0 top-full mt-1 w-[220px] max-h-[280px] overflow-y-auto bg-white border border-border-primary rounded-xl shadow-lg py-2 z-50 hidden"
          role="listbox"
          aria-label="Select location"
        >
          {locations.map((loc, idx) => (
            <button
              type="button"
              class:list={[
                "location-option w-full text-left px-4 py-2 text-sm hover:bg-neutral-50",
                idx === 0 ? "text-text-primary font-medium" : "text-text-secondary",
              ]}
              data-location={loc}
              role="option"
            >
              {loc}
            </button>
          ))}
        </div>
      </div>
    </div>

    <!-- Filter pills -->
    <div class="mt-4 flex flex-wrap gap-2 justify-center" data-animate="fade-up">
      {
        categories.map((cat, i) => (
          <button
            class:list={[
              "calc-filter-pill text-sm font-medium px-3 py-1.5 rounded-full border transition-colors duration-150",
              i === 0
                ? "bg-brand-accent border-transparent text-white"
                : "bg-[#0B2314A3] border-white/12 text-white/70 hover:border-white/40 hover:text-white hover:bg-white/10",
            ]}
            data-category={cat}
            aria-pressed={i === 0 ? "true" : "false"}
          >
            {cat}
          </button>
        ))
      }
    </div>
  </div>
  </div>
</section>

<script>
  function initFilters() {
    // Guard: Astro view transitions (and other events) can trigger init multiple times.
    // If we attach duplicate listeners, dropdown toggle can open+close instantly.
    if (document.body.dataset.costCalcHeroInit === "1") return;
    document.body.dataset.costCalcHeroInit = "1";

    const pills = document.querySelectorAll<HTMLButtonElement>(".calc-filter-pill");
    const searchInput = document.getElementById("calc-search") as HTMLInputElement | null;

    pills.forEach((pill) => {
      pill.addEventListener("click", () => {
        pills.forEach((p) => {
          p.classList.remove("bg-brand-accent", "border-transparent", "text-white");
          p.classList.add("bg-white/5", "border-white/20", "text-white/70");
          p.setAttribute("aria-pressed", "false");
        });
        pill.classList.add("bg-brand-accent", "border-transparent", "text-white");
        pill.classList.remove("bg-white/5", "border-white/20", "text-white/70");
        pill.setAttribute("aria-pressed", "true");

        document.dispatchEvent(
          new CustomEvent("calc:filter", {
            detail: { category: pill.dataset.category },
          })
        );
      });
    });

    searchInput?.addEventListener("input", () => {
      document.dispatchEvent(
        new CustomEvent("calc:search", {
          detail: { query: searchInput.value },
        })
      );
    });

    // Location dropdown
    const trigger = document.getElementById("location-dropdown-trigger");
    const panel = document.getElementById("location-dropdown-panel");
    const display = document.getElementById("location-display");
    const options = document.querySelectorAll<HTMLButtonElement>(".location-option");

    trigger?.addEventListener("click", (e) => {
      e.stopPropagation();
      if (!panel) return;
      panel.classList.toggle("hidden");
      const open = !panel.classList.contains("hidden");
      trigger.setAttribute("aria-expanded", String(open));
    });

    options.forEach((btn) => {
      btn.addEventListener("click", (e) => {
        e.stopPropagation();
        const loc = btn.dataset.location ?? "";
        if (display) display.textContent = loc;
        if (panel) panel.classList.add("hidden");
        trigger?.setAttribute("aria-expanded", "false");

        // Only filter if a location exists (defensive)
        document.dispatchEvent(new CustomEvent("calc:location", { detail: { location: loc } }));
      });
    });

    document.addEventListener("click", () => {
      if (!panel || !trigger) return;
      if (panel.classList.contains("hidden")) return;
      panel.classList.add("hidden");
      trigger.setAttribute("aria-expanded", "false");
    });
    panel?.addEventListener("click", (e) => e.stopPropagation());
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initFilters);
  } else {
    initFilters();
  }
  document.addEventListener("astro:page-load", initFilters);
</script>
