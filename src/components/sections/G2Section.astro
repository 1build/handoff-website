---
import g2Img from "@/assets/images/g2-img.png";
import g2Logo from "@/assets/images/g2-logo.png";
import badgeImg from "@/assets/images/badge-img.svg";

const badges = [
  {
    label: "Momentum Leader",
    season: "Winter 2024",
  },
  {
    label: "Best Usability",
    season: "Winter 2024",
  },
  {
    label: "Fastest Implementation",
    season: "Winter 2024",
  },
  {
    label: "Best Relationship",
    season: "Winter 2024",
  },
];
---

<section class="px-4 pt-4">
  <div class="relative z-[2] overflow-hidden py-10 md:py-16 lg:py-20 bg-[#F4F6F4] rounded-3xl" data-animate="fade-up">
  <div
    class="max-w-[1440px] mx-auto px-4 sm:px-6 md:px-8"
  >

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-14 items-center">
      <div class="space-y-6">
        <div class="flex items-center gap-2 text-sm text-text-secondary">
          <div class="flex items-center gap-1">
            <img src={g2Logo.src} alt="{r.name}" class="w-6" />
            <div class="flex items-center gap-0.5 text-[#FDB022]">
              <span aria-hidden="true">★</span>
              <span aria-hidden="true">★</span>
              <span aria-hidden="true">★</span>
              <span aria-hidden="true">★</span>
              <span aria-hidden="true">★</span>
            </div>
          </div>
          <span class="text-text-quaternary">4.7/5</span>
        </div>

        <div class="space-y-3">
          <h2 class="font-display text-3xl md:text-5xl font-semibold leading-tight tracking-[-0.02em] text-text-primary">
            The fastest-growing AI for residential remodeling
          </h2>
          <p class="text-base md:text-lg text-text-tertiary">
           <span class="font-semibold">More than 5000 contractors</span> switched to Handoff because it handles the work, and they keep coming back because it actually scales their operation.</p>
        </div>

        <div class="flex flex-col sm:flex-row gap-3">
          <a
            href="https://app.handoff.ai/sign-up/"
            class="inline-flex items-center justify-center px-5 py-3 text-base font-medium text-white rounded-xl bg-brand-700 border border-brand-600 hover:bg-brand-800 transition-colors duration-150"
          >
            Start free trial
          </a>
          <a
            href="#"
            class="inline-flex items-center justify-center px-5 py-3 rounded-xl text-base font-medium border border-border-primary bg-white text-text-primary hover:bg-neutral-50 transition-colors"
          >
            Talk with a specialist
          </a>
        </div>

       <img
                    src={badgeImg.src}
                    alt=""
                    class="w-auto object-cover mt-6"
                    loading="lazy"
                  />
      </div>

      <div class="w-full">
        <img
                    src={g2Img.src}
                    alt=""
                    class="w-full h-full object-cover rounded-3xl"
                    loading="lazy"
                  />
      </div>
    </div>
  </div>
  </div>
</section>

