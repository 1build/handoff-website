---
import Button from "@/components/ui/Button.astro";
import bgPattern from "@/assets/images/background-pattern.png";
import heroGlow from "@/assets/images/hero-glow-line.svg";
import heroDashboard from "@/assets/images/hero-dashboard.png";
import StatsStrip from "@/components/sections/StatsStrip.astro";

const stats = [
  { value: "+$5,250", label: "more earned per week" },
  { value: "+14 hrs", label: "saved per week" },
  { value: "+40%", label: "more deals closed" },
  { value: "+$85k", label: "more annual profit" },
];

---

<section class="relative overflow-hidden pt-20">
  <!-- Background grid pattern -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[1920px] h-[1440px] pointer-events-none z-0">
    <img src={bgPattern.src} alt="" class="w-full h-full block object-contain object-top" />
  </div>

  <!-- Glow line -->
  <div class="absolute -top-[24%] -left-[14%] -right-[14%] -bottom-[24%] pointer-events-none z-[1]">
    <img src={heroGlow.src} alt="" class="w-full h-full block" />
  </div>

  <!-- Content -->
  <div class="relative z-[2] max-w-[1280px] mx-auto px-8 pt-20 pb-12 flex flex-col items-center text-center">
    <!-- Badge pill -->
    <a href="#" class="inline-flex items-center gap-2 rounded-full backdrop-blur-[19px] bg-[#244232] pl-1 pr-2 py-0.5 mb-8 transition-opacity hover:opacity-80">
      <span class="inline-flex items-center rounded-full bg-[#079455] px-2 py-0.5 text-xs font-medium text-white">
        NEW
      </span>
      <span class="flex text-xs font-medium text-[#ABEFC6]">AI site walkthrough <span class="hidden md:flex">to replace photo-only tools</span></span>
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" class="shrink-0">
        <path d="M5 12H19M19 12L12 5M19 12L12 19" stroke="#ABEFC6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    </a>

    <!-- Heading -->
    <h1 class="font-display text-5xl sm:text-6xl lg:text-[72px] font-medium leading-[1.1] lg:leading-[90px] tracking-[-1.44px] text-white mb-6 max-w-[960px]">
      Run your entire contracting business <span class="text-text-highlight">with AI</span>
    </h1>

    <!-- Description -->
    <div class="text-xl font-normal leading-[30px] text-white max-w-[640px] mb-10">
      <p class="mb-5">Manage every project from first contact to completion in one connected system — powered by AI built for contractors.</p>
      <p>Handoff automates intake, estimating, project management, scheduling, invoicing, and client communication, so you can focus on building, not managing tools.</p>
    </div>

    <!-- CTA Buttons -->
    <div class="flex flex-col md:flex-row w-full justify-center items-center gap-3 mb-16">
  
      <a href="/" class="relative w-full md:w-auto inline-flex items-center justify-center gap-1.5 px-5 py-3 text-base font-medium leading-6 rounded-xl transition-all duration-150 whitespace-nowrap bg-brand-accent text-white shadow-[0px_1px_2px_0px_rgba(10,13,18,0.05)] hover:bg-brand-500">
        Start free trial
        <span class="absolute inset-0 pointer-events-none rounded-[inherit] shadow-[inset_0px_0px_0px_1px_rgba(10,13,18,0.18),inset_0px_-2px_0px_0px_rgba(10,13,18,0.05)]"></span>
      </a>
      <a href="/" class="inline-flex items-center justify-center gap-1.5 px-5 py-3 text-base font-medium leading-6 rounded-xl transition-all duration-150 whitespace-nowrap bg-black/40 backdrop-blur-md text-white hover:bg-black/30">
        Book a demo
        <span class="absolute inset-0 pointer-events-none rounded-[inherit] shadow-[inset_0px_0px_0px_1px_rgba(10,13,18,0.18),inset_0px_-2px_0px_0px_rgba(10,13,18,0.05)]"></span>
      </a>
     
    </div>

    <!-- Dashboard mockup -->
    <div class="w-full max-w-[1216px] px-0">
      <img
              src={heroDashboard.src}
              alt="Handoff dashboard"
              class="w-full h-auto block"
              loading="eager"
            />
    </div>
  </div>
 <StatsStrip />
</section>
