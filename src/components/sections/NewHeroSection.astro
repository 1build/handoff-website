---
import Button from "@/components/ui/Button.astro";
import bgPattern from "@/assets/images/background-pattern.png";
import heroGlow from "@/assets/images/hero-glow-line.svg";
import heroHomepage from "@/assets/images/Heros/Homepage.webp";
import StatsStrip from "@/components/sections/StatsStrip.astro";

interface Props { headingLevel?: 1 | 2 }
const { headingLevel = 1 } = Astro.props;
const HeadingTag = headingLevel === 2 ? "h2" : "h1";

const stats = [
  { value: "+$5,250", label: "more earned per week" },
  { value: "+14 hrs", label: "saved per week" },
  { value: "+40%", label: "more deals closed" },
  { value: "+$85k", label: "more annual profit" },
];

---

<section class="relative pt-20 [overflow-x:clip]">
  <!-- Background grid pattern -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[1920px] h-[1440px] pointer-events-none z-0">
    <img src={bgPattern.src} alt="" class="w-full h-full block object-contain object-top" />
  </div>

  <!-- Glow line -->
  <div class="absolute top-0 -left-[14%] -right-[14%] -bottom-[24%] pointer-events-none z-[1]">
    <img src={heroGlow.src} alt="" class="w-full h-full block" />
  </div>

  <!-- Content -->
  <div class="relative z-[2] max-w-[1440px] mx-auto px-4 md:px-8 pt-20 pb-12 flex flex-col items-center text-center">
    <!-- Heading -->
    <HeadingTag class="font-display text-4xl sm:text-[44px] lg:text-[60px] xl:text-[72px] font-medium leading-[1.2] lg:leading-[90px] tracking-[-1.44px] text-white mb-6 max-w-[960px]">
      Meet the <span class="text-text-highlight">AI Teammate</span> Built for Residential Construction
    </HeadingTag>

    <!-- Description -->
    <div class="text-xl font-normal leading-[30px] text-white max-w-[640px] mb-10">
      <p>Handoff estimates every job, runs every project end to end, and handles the admin with AI — so more of what you bill turns into profit.</p>
    </div>

    <!-- CTA Buttons -->
    <div class="flex flex-col md:flex-row w-full justify-center items-center gap-3 mb-16">
  
      <a href="https://app.handoff.ai/sign-up/" class="relative w-full md:w-auto inline-flex items-center justify-center gap-1.5 px-5 py-3 text-base font-medium leading-6 rounded-xl transition-all duration-150 whitespace-nowrap bg-brand-accent text-white shadow-[0px_1px_2px_0px_rgba(10,13,18,0.05)] hover:bg-brand-500">
        Start a Free Trial
        <span class="absolute inset-0 pointer-events-none rounded-[inherit] shadow-[inset_0px_0px_0px_1px_rgba(10,13,18,0.18),inset_0px_-2px_0px_0px_rgba(10,13,18,0.05)]"></span>
      </a>
     
    </div>

    <div class="w-full max-w-[1200px] mx-auto">
      <img src={heroHomepage.src} alt="Handoff dashboard" class="w-full h-auto rounded-[24px]" loading="eager" decoding="async" fetchpriority="high" />
    </div>
  </div>
 <StatsStrip />
 
</section>
