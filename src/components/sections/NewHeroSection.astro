---
import Button from "@/components/ui/Button.astro";
import bgPattern from "@/assets/images/background-pattern-dots.png";
import heroGlow from "@/assets/images/hero-glow-line.svg";
import heroDashboard from "@/assets/images/hero-dashboard.png";
import mobileHero from "@/assets/images/mobile-hero.png";

const stats = [
  { value: "+$5,250", label: "more earned per week" },
  { value: "+14 hrs", label: "saved per week" },
  { value: "+40%", label: "more deals closed" },
  { value: "+$85k", label: "avg annual profit increase" },
];

---

<section class="relative overflow-hidden pt-20 px-4 ">
<div class="bg-[#113120] rounded-3xl">
  <!-- Background grid pattern -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[1920px] h-[1440px] pointer-events-none z-0">
    <img src={bgPattern.src} alt="" class="w-full h-full block object-contain object-top" />
  </div>

  <!-- Glow line -->
  <div class="absolute -top-[24%] -left-[0%] -right-[0%] -bottom-[24%] pointer-events-none z-[1]">
    <img src={heroGlow.src} alt="" class="w-full h-full block" />
  </div>

  <!-- Content -->
  <div class="relative z-[2] max-w-[1280px] mx-auto pt-20 pb-12 flex flex-col items-center text-center">
    <!-- Badge pill -->
    <a href="#" class="inline-flex items-center gap-2 rounded-full backdrop-blur-[19px] bg-[#244232] pl-1 pr-2 py-0.5 mb-8 transition-opacity hover:opacity-80">
      <span class="inline-flex items-center rounded-full bg-[#079455] px-2 py-0.5 text-xs font-medium text-white">
        NEW
      </span>
      <span class="flex text-xs font-medium text-[#ABEFC6]">AI site walkthrough <span class="hidden md:flex">to replace photo-only tools</span></span>
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" class="shrink-0">
        <path d="M5 12H19M19 12L12 5M19 12L12 19" stroke="#ABEFC6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    </a>

    <!-- Heading -->
    <h1 class="font-display text-4xl md:text-[72px] font-medium leading-[1.1] lg:leading-[90px] tracking-[-1.44px] text-white mb-6 max-w-[960px]">
      Run your business <span class="text-text-highlight">with AI</span>
    </h1>

    <!-- Description -->
    <div class="text-lg md:text-xl font-normal leading-[30px] text-white max-w-[640px] mb-10">
      <p class="mb-5">All your jobs. All your documents. One place. Replace admin with AI.</p>
      <p>AI-powered construction management software that handles estimates, scopes and all the rest so you can focus on building.</p>
    </div>

    <!-- CTA Buttons -->
    <div class="flex flex-col md:flex-row w-full justify-center items-center gap-3 mb-16">
  
      <a href="/" class="relative w-full md:w-auto inline-flex items-center justify-center gap-1.5 px-5 py-2.5 text-base font-medium leading-6 rounded-xl transition-all duration-150 whitespace-nowrap bg-brand-accent text-white shadow-[0px_1px_2px_0px_rgba(10,13,18,0.05)] hover:bg-brand-500">
        Start free trial
        <span class="absolute inset-0 pointer-events-none rounded-[inherit] shadow-[inset_0px_0px_0px_1px_rgba(10,13,18,0.18),inset_0px_-2px_0px_0px_rgba(10,13,18,0.05)]"></span>
      </a>
     <a href="/" class="relative w-full md:w-auto inline-flex items-center justify-center gap-1.5 px-5 py-2.5 text-base font-medium leading-6 rounded-xl transition-all duration-150 whitespace-nowrap bg-white text-[#414651] shadow-[0px_1px_2px_0px_rgba(10,13,18,0.05)]">
       Book a demo
        <span class="absolute inset-0 pointer-events-none rounded-[inherit] shadow-[inset_0px_0px_0px_1px_rgba(10,13,18,0.18),inset_0px_-2px_0px_0px_rgba(10,13,18,0.05)]"></span>
      </a>
    </div>

    <!-- Dashboard mockup -->
    <div class="w-full px-0">
                  <img
              src={heroDashboard.src}
              alt="Handoff dashboard"
              class="w-full h-auto hidden md:block"
              loading="eager"
            />
            <img
              src={mobileHero.src}
              alt="Handoff dashboard"
              class="w-full h-auto block md:hidden"
              loading="eager"
            />
            
    </div>
  </div>
  <div class="relative z-[2] max-w-[1280px] mx-auto w-full">
    <div class="flex flex-col md:flex-row items-stretch border-t border-l border-r border-border-brand-alt rounded-t-3xl overflow-hidden">
      <!-- "See results immediately" — full width on mobile, first column on desktop -->
      <div class="bg-black/8 border-b md:border-b-0 md:border-r border-border-brand-alt flex items-center justify-center px-10 py-8">
        <p class="text-xl font-medium leading-[30px] text-white text-center md:text-left">
          See results <br class="hidden md:flex" /> immediately
        </p>
      </div>

      <!-- Stats: 2x2 grid on mobile, single row on desktop -->
      <div class="grid grid-cols-2 md:flex flex-1">
        {stats.map((stat) => (
          <div class="flex-1 bg-black/8 border-r border-b md:border-b-0 border-border-brand-alt even:border-r-0 md:even:border-r flex flex-col gap-1 items-center justify-center px-6 py-8 text-center">
            <p class="font-display text-3xl md:text-2xl lg:text-4xl font-medium leading-tight md:leading-[60px] tracking-[-0.96px] text-white w-full">
              {stat.value}
            </p>
            <p class="text-base md:text-xs lg:text-base font-normal lg:leading-6 text-[#47CD89] w-full">
              {stat.label}
            </p>
          </div>
        ))}
      </div>
    </div>
  </div>
  </div>
</section>
