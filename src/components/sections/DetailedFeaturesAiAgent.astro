---
import DetailRowClientManagement from "./DetailRowClientManagement.astro";

const rows = [
  {
    eyebrow: "Smart AI Assistant",
    title: "Start by asking Handoff AI for help",
    description: "Don't know where to start? Simply open our app and ask Handoff AI assistant what it can do. Handoff will offer to generate invoices, update customer records, create estimates, change orders, and answer your general question.",
    reverse: false,
    visualType: "desktop" as const,
    placeholder: "Screenshot of Handoff AI assistant chat",
  },
  {
    eyebrow: "AI File Analysis",
    title: "Upload and Q&A with your project files",
    description: "Simply upload construction drawings, scopes of work, client notes, photos, videos or any other files relevant to your project. Handoff will analyze your files and provide detailed information about what you've uploaded. Ask away!",
    reverse: true,
    visualType: "phones" as const,
    placeholder: "Screenshot of AI file analysis",
  },
  {
    eyebrow: "Virtual AI Assistant",
    title: "Complete multiple actions in one go",
    description: "Using Handoff AI is like having a virtual assistant available at your finger tips 24/7. Handoff can perform multiple actions without skipping a beat.",
    reverse: false,
    visualType: "isometric" as const,
    placeholder: "Screenshot of Handoff AI performing multiple actions",
  },
];
---

<section class="relative z-[2] px-4 pb-4 bg-brand-800">
  <div class="max-w-[1920px] mx-auto bg-white rounded-3xl py-16 lg:py-24 overflow-hidden flex flex-col gap-20 lg:gap-40">
    {rows.map((r) => (
      <DetailRowClientManagement
        eyebrow={r.eyebrow}
        title={r.title}
        description={r.description}
        reverse={r.reverse}
        visualType={r.visualType}
        placeholder={r.placeholder}
      />
    ))}
  </div>
</section>
