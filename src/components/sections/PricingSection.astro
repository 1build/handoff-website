---
import bgPattern from "@/assets/images/background-pattern-dots.png";
import heroGlow from "@/assets/images/hero-glow-line.svg";

interface Props { headingLevel?: 1 | 2 }
const { headingLevel = 1 } = Astro.props;
const HeadingTag = headingLevel === 2 ? "h2" : "h1";

interface PricingTier {
  name: string;
  badge?: { label: string; color: "green" | "gray" };
  monthlyPrice: string | null;
  annualPrice: string | null;
  priceLabel?: string;
  priceSublabel?: string;
  description: string;
  cta: { label: string; primary: boolean; href: string };
  modal?: boolean;
  featuresLabel?: { prefix: string; highlight: string; suffix: string };
  features: string[];
}

const tiers: PricingTier[] = [
  {
    name: "Flex",
    badge: { label: "7-day free trial", color: "green" },
    monthlyPrice: "$149",
    annualPrice: "$119",
    description: "Estimating takes too long. Get accurate bids out the door the same day you walk the job.",
    cta: { label: "Start free trial", primary: true, href: "https://app.handoff.ai/sign-up/" },
    features: [
      "50 AI usage credits p/mo",
      "1 custom pricing catalog",
      "AI-generated proposals",
      "Voice Transcription To Estimate",
      "Mobile & desktop access",
      "2 users included",
    ],
  },
  {
    name: "Pro",
    badge: { label: "12-month commitment", color: "gray" },
    monthlyPrice: "$299",
    annualPrice: "$239",
    description: "You're running more projects than one person can track. Handoff is built around your workflow, your pricing, and your crew - with hands-on setup to match.",
    cta: { label: "Start free trial", primary: true, href: "https://app.handoff.ai/sign-up/" },
    featuresLabel: { prefix: "All ", highlight: "Flex", suffix: " features plus:" },
    features: [
      "Unlimited AI usage credits",
      "Unlimited custom pricing catalogs",
      "Client financing",
      "AI site walkthroughs",
      "5 users included",
      "Dedicated Success Coach onboarding",
    ],
  },
  {
    name: "Enterprise",
    badge: undefined,
    monthlyPrice: null,
    annualPrice: null,
    priceLabel: "Contact us",
    priceSublabel: "for pricing",
    description: "Multi-location or API-level needs. Let's build something that fits.",
    cta: { label: "Get in touch", primary: false, href: "#" },
    modal: true,
    featuresLabel: { prefix: "", highlight: "Get in touch", suffix: "" },
    features: [
      "API access",
      "Custom integrations",
      "Advanced security",
      "Uptime SLA",
      "Security Compliance",
    ],
  },
];
---

<section id="pricing" class="px-4 pt-2">
  <div class="relative bg-bg-brand-dark overflow-hidden py-24 rounded-3xl">

  <!-- Background grid pattern -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[1920px] h-[1440px] pointer-events-none z-0 opacity-30">
    <img src={bgPattern.src} alt="" class="w-full h-full block object-contain object-top" />
  </div>

  <!-- Glow line -->
  <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[2135px] h-[1268px] pointer-events-none z-0">
    <img src={heroGlow.src} alt="" class="w-full h-full block" />
  </div>

  <!-- Content -->
  <div class="relative z-[1] max-w-[1440px] mx-auto px-6 lg:px-8 flex flex-col items-center">

    <!-- Heading -->
    <div class="flex flex-col items-center text-center pt-8 md:pt-24" data-animate="fade-up">
      <p class="font-mono text-sm font-semibold leading-6 tracking-[0.56px] uppercase text-text-on-brand-tertiary">
        PRICING
      </p>
      <HeadingTag class="font-display text-4xl lg:text-[48px] font-medium leading-[44px] lg:leading-[60px] tracking-[-0.96px] text-white max-w-[800px] mt-3">
        Stop Paying for Five Tools. Handoff Does It All with an AI Teammate.
      </HeadingTag>
      <div class="text-lg lg:text-xl font-normal leading-[28px] lg:leading-[30px] text-text-on-brand-tertiary flex flex-col gap-1 mt-6">
        <p>Start Free for 7 Days. Your First Estimate Is On Us.</p>
      </div>
    </div>

    <!-- Billing Toggle -->
    <div class="flex items-center justify-center gap-3 mt-10 lg:mt-20" data-animate="fade-up">
      <button
        id="billing-toggle"
        role="switch"
        aria-checked="true"
        aria-label="Toggle billing period"
        class="relative w-[44px] h-[24px] rounded-full bg-brand-accent transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-600 focus-visible:ring-offset-2"
      >
        <span class="absolute top-[2px] left-[2px] w-5 h-5 bg-white rounded-full shadow-xs transition-transform translate-x-5 pointer-events-none"></span>
      </button>

      <span id="label-annual" class="text-sm font-medium text-white transition-colors">Annual pricing</span>

      <span class="px-2 py-0.5 bg-[#ABEFC6] border border-green-200 rounded-md text-xs font-medium text-[#113120]">
        Save 20%
      </span>
    </div>

    <!-- Pricing Cards Grid -->
    <div class="rounded-2xl border border-border-primary overflow-hidden shadow-xs grid grid-cols-1 lg:grid-cols-3 mt-8 w-full" data-animate="stagger">
      {tiers.map((tier, i) => (
        <div class:list={[
          "flex flex-col bg-bg-primary",
          i < tiers.length - 1 ? "border-b lg:border-b-0 lg:border-r border-border-primary" : "",
        ]}>
          <!-- Card Header -->
          <div class="flex flex-col h-auto lg:h-[328px] px-5 md:px-8 pt-8 pb-8">
            <!-- Heading and price -->
            <div class="flex flex-col gap-5">
              <!-- Name + Badge -->
              <div class="flex items-center gap-2">
                <h2 class="font-display text-2xl font-medium leading-8 text-text-primary flex-1">{tier.name}</h2>
                {tier.badge && (
                  <span class:list={[
                    "px-2 py-0.5 rounded-md text-sm font-medium border",
                    tier.badge.color === "green"
                      ? "bg-green-50 border-green-200 text-green-700"
                      : "bg-neutral-50 border-neutral-200 text-neutral-700",
                  ]}>
                    {tier.badge.label}
                  </span>
                )}
              </div>

              <!-- Price -->
              <div class="flex flex-col gap-1">
                {tier.priceLabel ? (
                  <div class="flex flex-col gap-1">
                    <p class="font-display text-4xl font-medium leading-[44px] tracking-[-0.72px] text-text-primary">
                      {tier.priceLabel}
                    </p>
                    {tier.priceSublabel && (
                      <p class="text-base font-medium text-text-tertiary">{tier.priceSublabel}</p>
                    )}
                  </div>
                ) : (
                  <>
                    <p class="font-display text-4xl font-medium leading-[44px] tracking-[-0.72px] text-text-primary relative overflow-hidden h-[44px]">
                      <span class="price-annual inline-block transition-all duration-300 ease-out" style="transform:translateY(0);opacity:1">{tier.annualPrice}</span>
                      <span class="price-monthly absolute left-0 top-0 inline-block transition-all duration-300 ease-out" style="transform:translateY(100%);opacity:0">{tier.monthlyPrice}</span>
                    </p>
                    <p class="text-base font-medium text-text-tertiary">
                      per month, <span class="billing-period-label text-brand-accent">billed annually</span>
                    </p>
                  </>
                )}
              </div>
            </div>

            <!-- Description -->
            <p class="text-sm font-medium leading-5 text-text-tertiary mt-auto">{tier.description}</p>

            <!-- CTA Button -->
            {tier.modal ? (
              <button
                id="enterprise-cta"
                type="button"
                class="w-full py-3 px-[18px] rounded-xl text-base font-medium leading-6 text-center transition-colors shadow-xs mt-6 bg-bg-brand-solid text-white hover:bg-brand-800 cursor-pointer"
              >
                {tier.cta.label}
              </button>
            ) : (
              <a
                href={tier.cta.href}
                class:list={[
                  "w-full py-3 px-[18px] rounded-xl text-base font-medium leading-6 text-center transition-colors shadow-xs mt-6",
                  tier.cta.primary
                    ? "bg-bg-brand-solid text-white hover:bg-brand-800"
                    : "bg-bg-primary text-text-secondary border border-border-primary hover:bg-bg-secondary",
                ]}
              >
                {tier.cta.label}
              </a>
            )}
          </div>

          <!-- Card Content / Features -->
          <div class="flex flex-col gap-6 px-5 md:px-8 pt-5 pb-12 flex-1">
            <!-- Features label -->
            <p class="text-base font-semibold leading-6">
              {tier.featuresLabel ? (
                <>
                  <span class="text-text-quaternary">{tier.featuresLabel.prefix}</span>
                  <span class="text-text-primary">{tier.featuresLabel.highlight}</span>
                  <span class="text-text-quaternary">{tier.featuresLabel.suffix}</span>
                </>
              ) : (
                <span class="text-text-quaternary">What you get:</span>
              )}
            </p>

            <!-- Feature list -->
            <ul class="flex flex-col gap-4">
              {tier.features.map((feature) => (
                <li class="flex items-start gap-3">
                  <!-- Check icon -->
                  <span class="shrink-0 w-6 h-6 rounded-full flex items-center justify-center mt-0">
                    <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
<path d="M0 10C0 4.47715 4.47715 0 10 0C15.5228 0 20 4.47715 20 10C20 15.5228 15.5228 20 10 20C4.47715 20 0 15.5228 0 10Z" fill="#009C51" fill-opacity="0.16"/>
<path d="M8.36667 12.1L14.0167 6.45C14.15 6.31667 14.3083 6.25 14.4917 6.25C14.675 6.25 14.8333 6.31667 14.9667 6.45C15.1 6.58333 15.1667 6.74167 15.1667 6.925C15.1667 7.10833 15.1 7.26667 14.9667 7.4L8.83334 13.5333C8.70001 13.6667 8.54445 13.7333 8.36667 13.7333C8.18889 13.7333 8.03334 13.6667 7.90001 13.5333L5.03334 10.6667C4.90001 10.5333 4.83612 10.375 4.84167 10.1917C4.84723 10.0083 4.91667 9.85 5.05001 9.71667C5.18334 9.58333 5.34167 9.51667 5.52501 9.51667C5.70834 9.51667 5.86667 9.58333 6.00001 9.71667L8.36667 12.1Z" fill="#008042"/>
</svg>

                  </span>
                  <span class="text-base font-normal leading-6 text-text-secondary">{feature}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      ))}
    </div>

  </div>
  </div>
</section>

<!-- Enterprise Contact Modal -->
<div
  id="contact-modal"
  class="fixed inset-0 bg-black/60 items-center justify-center z-[9999] hidden"
  aria-modal="true"
  role="dialog"
  aria-labelledby="modal-title"
>
  <div class="bg-bg-primary rounded-2xl shadow-xl w-[90%] max-w-[480px] relative p-8">
    <button
      id="modal-close"
      type="button"
      aria-label="Close modal"
      class="absolute top-3 right-4 text-2xl leading-none text-text-tertiary hover:text-text-primary bg-transparent border-0 cursor-pointer"
    >&times;</button>

    <form id="enterprise-form" novalidate>
      <label class="block mb-1 text-xs font-medium text-text-secondary">Work Email <span class="text-red-500">*</span></label>
      <input
        type="email" name="email" placeholder="you@company.com" required
        class="w-full px-4 py-3 mb-3 border border-border-primary rounded-xl text-sm text-text-primary bg-bg-primary placeholder:text-text-quaternary focus:outline-none focus:ring-2 focus:ring-brand-500"
      />
      <div class="grid grid-cols-2 gap-3 mb-3">
        <div>
          <label class="block mb-1 text-xs font-medium text-text-secondary">First Name <span class="text-red-500">*</span></label>
          <input
            type="text" name="firstName" placeholder="Jane" required
            class="w-full px-4 py-3 border border-border-primary rounded-xl text-sm text-text-primary bg-bg-primary placeholder:text-text-quaternary focus:outline-none focus:ring-2 focus:ring-brand-500"
          />
        </div>
        <div>
          <label class="block mb-1 text-xs font-medium text-text-secondary">Last Name <span class="text-red-500">*</span></label>
          <input
            type="text" name="lastName" placeholder="Smith" required
            class="w-full px-4 py-3 border border-border-primary rounded-xl text-sm text-text-primary bg-bg-primary placeholder:text-text-quaternary focus:outline-none focus:ring-2 focus:ring-brand-500"
          />
        </div>
      </div>
      <label class="block mb-1 text-xs font-medium text-text-secondary">Company <span class="text-red-500">*</span></label>
      <input
        type="text" name="company" placeholder="Acme Construction" required
        class="w-full px-4 py-3 mb-3 border border-border-primary rounded-xl text-sm text-text-primary bg-bg-primary placeholder:text-text-quaternary focus:outline-none focus:ring-2 focus:ring-brand-500"
      />
      <label class="block mb-1 text-xs font-medium text-text-secondary">Phone</label>
      <input
        type="tel" name="phone" placeholder="(555) 000-0000"
        class="w-full px-4 py-3 mb-3 border border-border-primary rounded-xl text-sm text-text-primary bg-bg-primary placeholder:text-text-quaternary focus:outline-none focus:ring-2 focus:ring-brand-500"
      />
      <label class="block mb-1 text-xs font-medium text-text-secondary">How can we help?</label>
      <textarea
        name="message" placeholder="Tell us about your needs..." rows="3"
        class="w-full px-4 py-3 mb-4 border border-border-primary rounded-xl text-sm text-text-primary bg-bg-primary placeholder:text-text-quaternary focus:outline-none focus:ring-2 focus:ring-brand-500 resize-none"
      ></textarea>
      <button
        type="submit"
        class="w-full py-3 px-[18px] rounded-xl text-base font-medium text-white bg-bg-brand-solid hover:bg-brand-800 transition-colors shadow-xs cursor-pointer"
      >
        Submit
      </button>
    </form>

    <div id="form-success" class="hidden text-center py-4">
      <p class="text-text-primary font-medium">Thanks! Our enterprise team will be in touch shortly.</p>
    </div>
  </div>
</div>

<script>
  let isAnnual = true;

  // --- Element references ---
  const heroToggle = document.getElementById("billing-toggle");
  const compareToggle = document.getElementById("billing-toggle-compare");
  const annualLabel = document.getElementById("label-annual");
  const monthlyLabel = document.getElementById("label-monthly");

  // --- Apply billing state to all UI ---
  function applyBillingState() {
    // Hero toggle (PricingSection)
    if (heroToggle) {
      const thumb = heroToggle.querySelector("span");
      heroToggle.setAttribute("aria-checked", String(isAnnual));
      thumb?.classList.toggle("translate-x-5", isAnnual);
      thumb?.classList.toggle("translate-x-0", !isAnnual);
      heroToggle.classList.toggle("bg-brand-accent", isAnnual);
      heroToggle.classList.toggle("bg-neutral-300", !isAnnual);
    }

    // Compare table toggle
    if (compareToggle) {
      const thumb = compareToggle.querySelector("span");
      compareToggle.setAttribute("aria-checked", String(isAnnual));
      thumb?.classList.toggle("translate-x-5", isAnnual);
      thumb?.classList.toggle("translate-x-0", !isAnnual);
      compareToggle.classList.toggle("bg-brand-accent", isAnnual);
      compareToggle.classList.toggle("bg-neutral-300", !isAnnual);
    }

    // Animated prices (PricingSection cards)
    const pricesAnnual = document.querySelectorAll(".price-annual");
    const pricesMonthly = document.querySelectorAll(".price-monthly");
    const entering = isAnnual ? pricesAnnual : pricesMonthly;
    const leaving = isAnnual ? pricesMonthly : pricesAnnual;
    leaving.forEach((el) => {
      (el as HTMLElement).style.transform = "translateY(-100%)";
      (el as HTMLElement).style.opacity = "0";
    });
    entering.forEach((el) => {
      (el as HTMLElement).style.transform = "translateY(0)";
      (el as HTMLElement).style.opacity = "1";
    });

    // Compare table prices (same slide animation)
    const comparePricesAnnual = document.querySelectorAll(".compare-price-annual");
    const comparePricesMonthly = document.querySelectorAll(".compare-price-monthly");
    const compareEntering = isAnnual ? comparePricesAnnual : comparePricesMonthly;
    const compareLeaving = isAnnual ? comparePricesMonthly : comparePricesAnnual;
    compareLeaving.forEach((el) => {
      (el as HTMLElement).style.transform = "translateY(-100%)";
      (el as HTMLElement).style.opacity = "0";
    });
    compareEntering.forEach((el) => {
      (el as HTMLElement).style.transform = "translateY(0)";
      (el as HTMLElement).style.opacity = "1";
    });

    // Label emphasis (hero section)
    annualLabel?.classList.toggle("text-white", isAnnual);
    annualLabel?.classList.toggle("text-text-on-brand-tertiary", !isAnnual);
    monthlyLabel?.classList.toggle("text-white", !isAnnual);
    monthlyLabel?.classList.toggle("text-text-on-brand-tertiary", isAnnual);

    // Billing period labels (all)
    document.querySelectorAll(".billing-period-label").forEach((el) => {
      el.textContent = isAnnual ? "billed annually" : "billed monthly";
      el.classList.toggle("text-brand-accent", isAnnual);
      el.classList.toggle("text-text-tertiary", !isAnnual);
    });
  }

  function toggleBilling() {
    isAnnual = !isAnnual;
    applyBillingState();
  }

  heroToggle?.addEventListener("click", toggleBilling);
  compareToggle?.addEventListener("click", toggleBilling);

  // ─── Enterprise modal ────────────────────────────────────────────────────
  const modal = document.getElementById('contact-modal') as HTMLElement | null;
  const enterpriseCta = document.getElementById('enterprise-cta');
  const modalClose = document.getElementById('modal-close');
  const enterpriseForm = document.getElementById('enterprise-form') as HTMLFormElement | null;
  const formSuccess = document.getElementById('form-success') as HTMLElement | null;

  function openModal() {
    if (!modal) return;
    modal.classList.remove('hidden');
    modal.classList.add('flex');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    if (!modal) return;
    modal.classList.add('hidden');
    modal.classList.remove('flex');
    document.body.style.overflow = '';
  }

  enterpriseCta?.addEventListener('click', openModal);
  modalClose?.addEventListener('click', closeModal);

  modal?.addEventListener('click', (e) => {
    if ((e.target as HTMLElement).id === 'contact-modal') closeModal();
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeModal();
  });

  enterpriseForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.target as HTMLFormElement;
    const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    submitBtn.disabled = true;
    submitBtn.textContent = 'Submitting...';

    const payload = {
      fields: [
        { name: 'email', value: (form.elements.namedItem('email') as HTMLInputElement).value },
        { name: 'firstname', value: (form.elements.namedItem('firstName') as HTMLInputElement).value },
        { name: 'lastname', value: (form.elements.namedItem('lastName') as HTMLInputElement).value },
        { name: 'company', value: (form.elements.namedItem('company') as HTMLInputElement).value },
        { name: 'phone', value: (form.elements.namedItem('phone') as HTMLInputElement).value },
        { name: 'message', value: (form.elements.namedItem('message') as HTMLTextAreaElement).value },
      ].filter(f => f.value),
      context: {
        pageUri: window.location.href,
        pageName: 'Pricing - Enterprise',
      },
    };

    try {
      const response = await fetch(
        'https://api.hsforms.com/submissions/v3/integration/submit/44330500/b0ac6b7e-d6ee-414f-a227-7ec78cddf839',
        {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        }
      );

      if (response.ok) {
        if (enterpriseForm) enterpriseForm.style.display = 'none';
        if (formSuccess) formSuccess.classList.remove('hidden');
        setTimeout(closeModal, 2000);
      } else {
        throw new Error('Submission failed');
      }
    } catch {
      alert('Something went wrong. Please try again.');
      submitBtn.disabled = false;
      submitBtn.textContent = 'Submit';
    }
  });
</script>
