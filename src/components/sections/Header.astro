---
import Logo from "@/components/ui/Logo.astro";
import ChevronDown from "@/components/ui/ChevronDown.astro";
import { navItems as localNavItems, isDropdown } from "@/lib/navigation";
import type { NavItem } from "@/lib/navigation";
import { getAllPosts, urlFor, type SanityPostListItem } from "@/lib/sanity";

const allSanityPosts = await getAllPosts();
const latestPosts: SanityPostListItem[] = allSanityPosts.filter((p) => p.slug).slice(0, 3); // first 3 (most recent)

interface Props {
  navItems?: any[];
}

const { navItems: navItemsProp } = Astro.props;

// Resolve nav items: Sanity data or local fallback
// Sanity nav items come as { label, href?, children?, wide? }
// Local nav items use the NavItem type (NavLink | NavDropdown)
const items = navItemsProp?.length ? navItemsProp : localNavItems;

function hasChildren(item: any): boolean {
  return "items" in item || "children" in item;
}

function getChildren(item: any): any[] {
  return item.items || item.children || [];
}

function isWide(item: any): boolean {
  return !!item.wide;
}

function getFeatures(item: any): any[] {
  return item.features || [];
}

function hasSections(item: any): boolean {
  return Array.isArray(item.sections) && item.sections.length > 0;
}

function getSections(item: any): any[] {
  return item.sections || [];
}

function hasIconItems(item: any): boolean {
  const children = getChildren(item);
  return children.length > 0 && children.some((c: any) => c.iconName || c.description);
}

const solutionIcons: Record<string, string> = {
  "book-closed": `<svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M3.333 16.25A2.083 2.083 0 0 1 5.417 14.167h11.25" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M5.417 1.667h11.25v16.666H5.417A2.083 2.083 0 0 1 3.333 16.25V3.75A2.083 2.083 0 0 1 5.417 1.667Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  "stars-02": `<svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M10 1.667 11.667 7.5H17.5L13.333 10.833l1.667 5.834L10 13.333l-5 3.334 1.667-5.834L2.5 7.5h5.833L10 1.667Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  "play-circle": `<svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M10 18.333A8.333 8.333 0 1 0 10 1.667a8.333 8.333 0 0 0 0 16.666Z" stroke="currentColor" stroke-width="1.5"/><path d="M8.333 7.5 13.333 10l-5 2.5V7.5Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  "file-code": `<svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M11.667 1.667H5A1.667 1.667 0 0 0 3.333 3.333v13.334A1.667 1.667 0 0 0 5 18.333h10A1.667 1.667 0 0 0 16.667 16.667V6.667L11.667 1.667Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M11.667 1.667V6.667h5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M8.333 12.5 6.667 10.833 8.333 9.167M11.667 12.5l1.666-1.667-1.666-1.666" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  "link": `<svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M8.333 10.833a4.167 4.167 0 0 0 6.25.417l2.5-2.5a4.167 4.167 0 0 0-5.893-5.893L9.75 4.292" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M11.667 9.167a4.167 4.167 0 0 0-6.25-.417l-2.5 2.5a4.167 4.167 0 0 0 5.893 5.893l1.433-1.433" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  "pencil-line": `<svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M2.5 17.5l4.167-1.25 9.583-9.583a2.357 2.357 0 1 0-3.333-3.334L3.333 12.917 2.5 17.5Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M11.667 4.583l3.75 3.75" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  "book-open-01": `<svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M10 5v11.667M10 5A4.167 4.167 0 0 0 6.25 3.333H2.5v11.667h3.75A4.167 4.167 0 0 1 10 16.667M10 5A4.167 4.167 0 0 1 13.75 3.333H17.5v11.667h-3.75A4.167 4.167 0 0 0 10 16.667" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  "message-text-circle-02": `<svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M6.667 7.5h6.666M6.667 10.833H10M5.833 14.167l-3.333 3.333V5A1.667 1.667 0 0 1 4.167 3.333h11.666A1.667 1.667 0 0 1 17.5 5v7.5a1.667 1.667 0 0 1-1.667 1.667H5.833Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  "announcement-01": `<svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M15 6.25v7.5M15 6.25A2.083 2.083 0 0 0 12.917 4.167H4.167A1.667 1.667 0 0 0 2.5 5.833v8.334A1.667 1.667 0 0 0 4.167 15.833h8.75A2.083 2.083 0 0 0 15 13.75M15 6.25l2.5-1.25v8.333L15 12.083" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M6.667 15.833V12.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  "graduation-hat-01": `<svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M2.5 7.5L10 4.167l7.5 3.333-7.5 3.333L2.5 7.5Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M5.833 9.167V13.333a8.333 8.333 0 0 0 8.334 0V9.167" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M17.5 7.5v4.167" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  "briefcase-02": `<svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M13.333 5.833V4.167a1.667 1.667 0 0 0-1.666-1.667H8.333a1.667 1.667 0 0 0-1.666 1.667v1.666" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M1.667 9.167A15 15 0 0 0 10 11.25a15 15 0 0 0 8.333-2.083M7.5 10h5M3.333 5.833h13.334a1.667 1.667 0 0 1 1.666 1.667v8.333a1.667 1.667 0 0 1-1.666 1.667H3.333a1.667 1.667 0 0 1-1.666-1.667V7.5a1.667 1.667 0 0 1 1.666-1.667Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  "users-plus": `<svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M13.333 17.5v-1.667A3.333 3.333 0 0 0 10 12.5H4.167a3.333 3.333 0 0 0-3.334 3.333V17.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M7.083 9.167a3.333 3.333 0 1 0 0-6.667 3.333 3.333 0 0 0 0 6.667Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M15.833 6.667v5M18.333 9.167h-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
};
---

<div id="header-wrapper" class="header-wrapper">
<header id="site-header" class="fixed top-0 left-0 right-0 z-100 h-20 flex items-center justify-center bg-[rgba(17,49,32,0.4)] backdrop-blur-[6px] transition-[background,backdrop-filter] duration-300">
  <div class="w-full max-w-[1600px] px-8 flex items-center justify-between relative">
    <!-- Logo -->
    <a href="/" class="flex items-center h-8">
      <Logo />
    </a>

    <!-- Nav (desktop): centered without transform so dropdown fixed positioning is viewport-relative -->
    <nav class="fixed left-0 right-0 top-0 h-20 flex justify-center hidden lg:flex items-center gap-2 z-101 pointer-events-none" aria-label="Main navigation">
      <div class="pointer-events-auto flex items-center gap-2">
      {items.map((item: any) =>
        hasChildren(item) ? (
          <div class="nav-dropdown relative">
            <button class="flex items-center gap-0.5 px-1.5 py-1 text-base font-medium leading-6 text-white/70 rounded-md transition-all duration-150 hover:bg-white/10 hover:text-white" type="button" aria-expanded="false" aria-haspopup="true">
              <span class="px-0.5 text-white">{item.label}</span>
              <ChevronDown />
            </button>
            {hasSections(item) ? (
            <div class="dropdown-panel absolute top-full left-1/2 -translate-x-1/2 w-[960px] bg-white border border-black/[0.08] rounded-2xl shadow-[0px_12px_16px_-4px_rgba(10,13,18,0.08),0px_4px_6px_-2px_rgba(10,13,18,0.03),0px_2px_2px_-1px_rgba(10,13,18,0.04)] flex overflow-hidden">
              <!-- Left + Middle: two section columns -->
              <div class="flex flex-1 gap-12 p-6 min-w-0">
                {getSections(item).map((section: any) => (
                  <div class="flex-1 flex flex-col gap-2 min-w-0">
                    <p class="text-sm font-semibold leading-5 text-[#335645]">{section.label}</p>
                    <div class="flex flex-col gap-2">
                      {section.items.map((link: any) => (
                        <a href={link.href || "/"} class="flex gap-3 items-start p-3 rounded-lg transition-colors hover:bg-[#fafafa]">
                          {link.iconName && solutionIcons[link.iconName] && (
                            <div class="shrink-0 pt-0.5 text-[#079455]" set:html={solutionIcons[link.iconName]} />
                          )}
                          <div class="flex flex-col gap-0.5 min-w-0">
                            <span class="font-medium text-base leading-6 text-[#181d27]">{link.label}</span>
                            {link.description && (
                              <span class="text-sm leading-5 text-[#535862]">{link.description}</span>
                            )}
                          </div>
                        </a>
                      ))}
                    </div>
                  </div>
                ))}
              </div>
              <!-- Right: Latest blog posts -->
              <div class="w-[400px] shrink-0 bg-[#f4f6f4] p-6 flex flex-col gap-4 self-stretch">
                <p class="text-sm font-semibold leading-5 text-[#335645]">Latest blog posts</p>
                <div class="flex flex-col">
                  {latestPosts.map((post) => (
                    <a href={`/blog/${post.slug}`} class="flex gap-3 items-start p-3 rounded-lg transition-colors hover:bg-white/80">
                      {(post.featuredImage || post.thumbnailImage) && (
                        <div class="shrink-0 w-[112px] h-[72px] rounded-md overflow-hidden">
                          <img src={urlFor(post.featuredImage ?? post.thumbnailImage).width(224).height(144).url()} alt="" class="w-full h-full object-cover" loading="lazy" />
                        </div>
                      )}
                      <div class="flex-1 flex flex-col gap-1 min-w-0">
                        <p class="font-semibold text-sm leading-5 text-[#181d27] line-clamp-2">{post.title}</p>
                        <p class="text-xs leading-4 text-[#535862] line-clamp-2">{post.excerpt ?? ""}</p>
                      </div>
                    </a>
                  ))}
                </div>
              </div>
            </div>
          ) : getFeatures(item).length > 0 ? (
            <div class="dropdown-panel dropdown-panel-solutions absolute top-full left-1/2 -translate-x-1/2 bg-white border border-black/[0.08] rounded-2xl shadow-[0px_12px_16px_-4px_rgba(10,13,18,0.08),0px_4px_6px_-2px_rgba(10,13,18,0.03),0px_2px_2px_-1px_rgba(10,13,18,0.04)] overflow-hidden">
              <div class="flex w-full">
                <div class="flex flex-col gap-2 p-6 w-[400px] shrink-0">
                  <p class="text-sm font-semibold leading-5 text-[#335645]">{item.label}</p>
                  <div class="flex flex-col gap-2">
                    {getChildren(item).map((link: any) => (
                      <a href={link.href || "/"} class="solutions-link flex gap-3 items-start p-3 rounded-lg transition-colors hover:bg-[#fafafa]">
                        {link.iconName && solutionIcons[link.iconName] && (
                          <div class="shrink-0 pt-0.5 text-[#079455]" set:html={solutionIcons[link.iconName]} />
                        )}
                        <div class="flex flex-col gap-0.5 min-w-0">
                          <span class="font-medium text-base leading-6 text-[#181d27]">{link.label}</span>
                          {link.description && (
                            <span class="text-sm leading-5 text-[#535862]">{link.description}</span>
                          )}
                        </div>
                      </a>
                    ))}
                  </div>
                </div>
                <div class="solutions-features flex-col gap-2 p-6 w-[300px] shrink-0 bg-[#f4f6f4] self-stretch">
                  <p class="text-sm font-semibold leading-5 text-[#335645]">Features</p>
                  <div class="flex flex-col gap-3">
                    {getFeatures(item).map((feat: any) => (
                      <a href={feat.href || "/"} class="text-base font-medium leading-6 text-[#535862] hover:text-[#181d27] transition-colors px-1">
                        {feat.label}
                      </a>
                    ))}
                  </div>
                </div>
              </div>
            </div>
          ) : hasIconItems(item) ? (
            <div
              class="dropdown-panel absolute top-full left-1/2 -translate-x-1/2 min-w-[420px] bg-white border border-black/[0.08] rounded-xl p-6 flex flex-col gap-2 shadow-[0px_12px_16px_-4px_rgba(10,13,18,0.08),0px_4px_6px_-2px_rgba(10,13,18,0.03),0px_2px_2px_-1px_rgba(10,13,18,0.04)]"
              style={item.label === "Support" ? "min-width:260px" : undefined}
            >
              {getChildren(item).map((link: any) => (
                <a href={link.href || "/"} class="flex gap-3 items-start p-3 rounded-lg transition-colors hover:bg-[#fafafa]">
                  {link.iconName && solutionIcons[link.iconName] && (
                    <div class="shrink-0 pt-0.5 text-[#079455]" set:html={solutionIcons[link.iconName]} />
                  )}
                  <div class="flex flex-col gap-0.5 min-w-0">
                    <span class="font-medium text-base leading-6 text-[#181d27]">{link.label}</span>
                    {link.description && (
                      <span class="text-sm leading-5 text-[#535862]">{link.description}</span>
                    )}
                  </div>
                </a>
              ))}
            </div>
          ) : (
            <div class:list={[
              "dropdown-panel absolute top-full left-1/2 -translate-x-1/2 bg-[rgba(17,49,32,0.95)] backdrop-blur-[16px] border border-white/10 rounded-xl p-2 flex flex-col",
              isWide(item) ? "min-w-[360px]" : "min-w-[240px]"
            ]}>
              {getChildren(item).map((link: any) => (
                <a href={link.href || "/"} class="flex flex-col gap-1 px-3 py-2.5 rounded-md text-white/80 text-sm font-medium leading-5 transition-all duration-150 hover:bg-white/10 hover:text-white">
                  {link.label}
                </a>
              ))}
            </div>
          )}
          </div>
        ) : (
          <a href={item.href || "/"} class="flex items-center gap-0.5 px-1.5 py-1 text-base font-medium leading-6 text-white/70 rounded-md transition-all duration-150 hover:bg-white/10 hover:text-white">
            <span class="px-0.5 text-white">{item.label}</span>
          </a>
        )
      )}
      </div>
    </nav>

    <!-- Actions (desktop) + Mobile menu button -->
    <div class="flex items-center gap-3">
      <div class="hidden lg:flex items-center gap-3">
        <a href="https://app.handoff.ai/login/"
         class="inline-flex items-center justify-center gap-1.5 px-5 py-2.5 text-base font-medium leading-6 rounded-xl transition-all duration-150 whitespace-nowrap bg-white/10 backdrop-blur-md text-white hover:bg-black/30">
          Log in
        </a>
        <a href="https://app.handoff.ai/sign-up/?af_xp=custom&source_caller=ui&pid=handoff_landing&af_js_web=true&shortlink=landing&deep_link_value=%2Festimates&af_ss_ui=true&c=landing_default&af_ss_ver=2_8_1"
         class="relative inline-flex items-center justify-center gap-1.5 px-5 py-2.5 text-base font-medium leading-6 rounded-xl transition-all duration-150 whitespace-nowrap bg-brand-accent text-white shadow-[0px_1px_2px_0px_rgba(10,13,18,0.05)] hover:bg-brand-500">
          Sign up
          <span class="absolute inset-0 pointer-events-none rounded-[inherit] shadow-[inset_0px_0px_0px_1px_rgba(10,13,18,0.18),inset_0px_-2px_0px_0px_rgba(10,13,18,0.05)]"></span>
        </a>
      </div>
      <!-- Mobile menu button -->
      <button id="mobile-menu-toggle" type="button" class="lg:hidden flex items-center justify-center w-10 h-10 rounded-lg text-white hover:bg-white/10 transition-colors" aria-expanded="false" aria-controls="mobile-menu-panel" aria-label="Toggle menu">
        <span id="mobile-menu-icon-open" aria-hidden="true">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
        </span>
        <span id="mobile-menu-icon-close" class="hidden" aria-hidden="true">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
        </span>
      </button>
    </div>
  </div>
</header>

<!-- Mobile menu overlay and panel (z above header so panel is visible when open) -->
<div id="mobile-menu-backdrop" class="mobile-menu-backdrop fixed inset-0 z-[101] bg-black/50 opacity-0 pointer-events-none transition-opacity duration-300 lg:hidden" aria-hidden="true"></div>
<div id="mobile-menu-panel" class="mobile-menu-panel fixed top-0 right-0 h-full w-[min(100%,320px)] max-w-full z-[102] bg-[rgba(17,49,32,0.98)] backdrop-blur-[16px] border-l border-white/10 shadow-3xl flex flex-col translate-x-full transition-transform duration-300 ease-out lg:hidden" role="dialog" aria-modal="true" aria-label="Mobile menu">
  <div class="flex items-center justify-between h-20 px-6 border-b border-white/10 shrink-0">
    <span class="text-white font-medium">Menu</span>
    <button type="button" class="mobile-menu-close flex items-center justify-center w-10 h-10 -mr-2 rounded-lg text-white hover:bg-white/10 transition-colors" aria-label="Close menu">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
    </button>
  </div>
  <nav class="flex-1 overflow-y-auto px-4 py-4" aria-label="Mobile navigation">
    <ul class="flex flex-col gap-1">
      {items.map((item: any) => (
        <li>
          {hasChildren(item) ? (
            <details class="group/details">
              <summary class="flex items-center justify-between gap-2 list-none cursor-pointer px-3 py-2.5 rounded-lg text-white/90 font-medium text-base hover:bg-white/10 focus:bg-white/10 focus:outline-none [&::-webkit-details-marker]:hidden">
                <span>{item.label}</span>
                <ChevronDown class="w-4 h-4 shrink-0 transition-transform group-open/details:rotate-180 text-white/70" />
              </summary>
              <ul class="mt-1 ml-2 pl-2 border-l border-white/20 flex flex-col gap-0.5 pb-2">
                {getChildren(item).map((link: any) => (
                  <li>
                    <a href={link.href || "/"} class="mobile-menu-link block px-3 py-2 rounded-md text-white/80 text-sm font-medium hover:bg-white/10 hover:text-white transition-colors">
                      {link.description ? (
                        <span class="block font-medium text-white">{link.label}</span>
                      ) : (
                        link.label
                      )}
                    </a>
                  </li>
                ))}
                {getFeatures(item).length > 0 && (
                  <>
                    <li class="mt-2 mb-1 px-3 text-xs font-semibold uppercase tracking-[0.08em] text-white/60">
                      Features
                    </li>
                    {getFeatures(item).map((feat: any) => (
                      <li>
                        <a href={feat.href || "/"} class="mobile-menu-link block px-3 py-1.5 rounded-md text-white/80 text-sm font-medium hover:bg-white/10 hover:text-white transition-colors">
                          {feat.label}
                        </a>
                      </li>
                    ))}
                  </>
                )}
              </ul>
            </details>
          ) : (
            <a href={item.href || "/"} class="mobile-menu-link block px-3 py-2.5 rounded-lg text-white/90 font-medium text-base hover:bg-white/10 hover:text-white transition-colors">
              {item.label}
            </a>
          )}
        </li>
      ))}
    </ul>
  </nav>
  <div class="shrink-0 p-4 border-t border-white/10 flex flex-col gap-2">
    <a href="/" class="inline-flex items-center justify-center gap-1.5 px-5 py-2.5 text-base font-medium leading-6 rounded-xl bg-white/10 text-white hover:bg-white/20 transition-colors">Log in</a>
    <a href="/" class="inline-flex items-center justify-center gap-1.5 px-5 py-2.5 text-base font-medium leading-6 rounded-xl bg-brand-accent text-white hover:bg-brand-500 transition-colors">Sign up</a>
  </div>
</div>
</div>

<style>
  .header-wrapper.mobile-menu-open .mobile-menu-backdrop {
    opacity: 1;
    pointer-events: auto;
  }
  /* Override Tailwind translate-x-full when open so panel is visible */
  .header-wrapper.mobile-menu-open .mobile-menu-panel {
    transform: translateX(0) !important;
  }
  .header-wrapper .nav-dropdown .dropdown-panel {
    left: auto !important;
    transform: none !important;
    right: auto !important;
  }
  .dropdown-panel-solutions {
    transition: width 180ms ease-out;
  }
  .dropdown-panel-solutions .solutions-features {
    transition: opacity 180ms ease-out;
  }
</style>

<script>
  function initHeader() {
    const header = document.getElementById("site-header");
    if (!header) return;
    const onScroll = () => {
      if (window.scrollY > 20) {
        header.classList.add("header-scrolled");
      } else {
        header.classList.remove("header-scrolled");
      }
    };
    window.addEventListener("scroll", onScroll, { passive: true });
    onScroll();
  }

  function initSolutionsFeatures() {
    const menus = document.querySelectorAll(".dropdown-panel-solutions");
    menus.forEach((menu) => {
      if (!(menu instanceof HTMLElement)) return;
      const features = menu.querySelector(".solutions-features");
      if (!(features instanceof HTMLElement)) return;
      // Initial state: only solutions column visible
      menu.style.width = "400px";
      features.style.display = "none";
      features.style.opacity = "0";
      const links = menu.querySelectorAll(".solutions-link");
      links.forEach((link) => {
        link.addEventListener("mouseenter", () => {
          menu.style.width = "700px";
          features.style.display = "flex";
          requestAnimationFrame(() => {
            features.style.opacity = "1";
          });
        });
      });
      menu.addEventListener("mouseleave", () => {
        menu.style.width = "400px";
        features.style.opacity = "0";
        setTimeout(() => {
          features.style.display = "none";
        }, 180);
      });
    });
  }

  function initMobileMenu() {
    // Use event delegation so the toggle works regardless of init order and duplicate Headers.
    // Guard so we don't attach listeners twice (e.g. on astro:page-load).
    if (document.body.dataset.mobileMenuInit === "1") return;
    document.body.dataset.mobileMenuInit = "1";

    document.addEventListener("click", (e) => {
      const toggle = e.target instanceof Element && e.target.closest("#mobile-menu-toggle");
      if (!toggle) return;
      const wrapper = toggle.closest(".header-wrapper");
      if (!wrapper) return;

      const panel = wrapper.querySelector(".mobile-menu-panel");
      const backdrop = wrapper.querySelector(".mobile-menu-backdrop");
      const iconOpen = wrapper.querySelector("#mobile-menu-icon-open");
      const iconClose = wrapper.querySelector("#mobile-menu-icon-close");

      if (wrapper.classList.contains("mobile-menu-open")) {
        wrapper.classList.remove("mobile-menu-open");
        panel?.classList.add("translate-x-full");
        toggle.setAttribute("aria-expanded", "false");
        if (iconOpen) iconOpen.classList.remove("hidden");
        if (iconClose) iconClose.classList.add("hidden");
        document.body.style.overflow = "";
      } else {
        wrapper.classList.add("mobile-menu-open");
        panel?.classList.remove("translate-x-full");
        toggle.setAttribute("aria-expanded", "true");
        if (iconOpen) iconOpen.classList.add("hidden");
        if (iconClose) iconClose.classList.remove("hidden");
        document.body.style.overflow = "hidden";
      }
    });

    document.addEventListener("click", (e) => {
      const closeBtn = e.target instanceof Element && e.target.closest(".mobile-menu-close");
      const backdrop = e.target instanceof Element && e.target.closest(".mobile-menu-backdrop");
      if (!closeBtn && !backdrop) return;
      const wrapper = (closeBtn || backdrop)?.closest(".header-wrapper");
      if (!wrapper || !wrapper.classList.contains("mobile-menu-open")) return;

      const panel = wrapper.querySelector(".mobile-menu-panel");
      const toggle = wrapper.querySelector("#mobile-menu-toggle");
      const iconOpen = wrapper.querySelector("#mobile-menu-icon-open");
      const iconClose = wrapper.querySelector("#mobile-menu-icon-close");
      wrapper.classList.remove("mobile-menu-open");
      panel?.classList.add("translate-x-full");
      if (toggle) toggle.setAttribute("aria-expanded", "false");
      if (iconOpen) iconOpen?.classList.remove("hidden");
      if (iconClose) iconClose?.classList.add("hidden");
      document.body.style.overflow = "";
    });

    document.addEventListener("keydown", (e) => {
      if (e.key !== "Escape") return;
      const wrapper = document.querySelector(".header-wrapper.mobile-menu-open");
      if (!wrapper) return;
      const panel = wrapper.querySelector(".mobile-menu-panel");
      const toggle = wrapper.querySelector("#mobile-menu-toggle");
      const iconOpen = wrapper.querySelector("#mobile-menu-icon-open");
      const iconClose = wrapper.querySelector("#mobile-menu-icon-close");
      wrapper.classList.remove("mobile-menu-open");
      panel?.classList.add("translate-x-full");
      if (toggle) toggle.setAttribute("aria-expanded", "false");
      if (iconOpen) iconOpen.classList.remove("hidden");
      if (iconClose) iconClose.classList.add("hidden");
      document.body.style.overflow = "";
    });

    // Close menu when a nav link is clicked (for same-page or SPA-style transitions)
    document.addEventListener("click", (e) => {
      const link = e.target instanceof Element && e.target.closest(".mobile-menu-link");
      if (!link) return;
      const wrapper = document.querySelector(".header-wrapper.mobile-menu-open");
      if (!wrapper) return;
      const panel = wrapper.querySelector(".mobile-menu-panel");
      const toggle = wrapper.querySelector("#mobile-menu-toggle");
      const iconOpen = wrapper.querySelector("#mobile-menu-icon-open");
      const iconClose = wrapper.querySelector("#mobile-menu-icon-close");
      wrapper.classList.remove("mobile-menu-open");
      panel?.classList.add("translate-x-full");
      if (toggle) toggle.setAttribute("aria-expanded", "false");
      if (iconOpen) iconOpen.classList.remove("hidden");
      if (iconClose) iconClose.classList.add("hidden");
      document.body.style.overflow = "";
    });
  }

  function init() {
    initHeader();
    initSolutionsFeatures();
    initMobileMenu();
  }
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", init);
  } else {
    init();
  }
  document.addEventListener("astro:page-load", init);
</script>
