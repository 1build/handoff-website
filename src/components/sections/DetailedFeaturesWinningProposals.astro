---
import DetailRowClientManagement from "./DetailRowClientManagement.astro";

const rows = [
  {
    eyebrow: "AI Generated proposals",
    title: "Winning proposals made in one click",
    description: "Get back time in your day and win more projects with proposals that, literally, write themselves. Handoff automatically converts your estimate into a detailed proposal that will impress your clients.",
    reverse: false,
    visualType: "desktop" as const,
    placeholder: "Screenshot of AI generated proposal",
  },
  {
    eyebrow: "file attachments",
    title: "Share photos, videos, and documents with clients",
    description: "You can easily upload any files you want into Handoff and send them to your clients along with your proposal. Easily share photos of their space, images of selections, or your standard contract language in PDF.",
    reverse: true,
    visualType: "phones" as const,
    placeholder: "Screenshot of file attachments",
  },
  {
    eyebrow: "digital signatures",
    title: "Collect digital signatures and make your contract official",
    description: "Handoff allows you to request digital signatures from your clients to make your proposals and contracts even more official. The client can sign your proposal on any device with ease, providing you with the peace of mind to move forward.",
    reverse: false,
    visualType: "isometric" as const,
    placeholder: "Screenshot of digital signature flow",
  },
];
---

<section class="relative z-[2] px-4 pb-4 bg-brand-800">
  <div class="max-w-[1920px] mx-auto bg-white rounded-3xl py-16 lg:py-24 overflow-hidden flex flex-col gap-20 lg:gap-40">
    {rows.map((r) => (
      <DetailRowClientManagement
        eyebrow={r.eyebrow}
        title={r.title}
        description={r.description}
        reverse={r.reverse}
        visualType={r.visualType}
        placeholder={r.placeholder}
      />
    ))}
  </div>
</section>
