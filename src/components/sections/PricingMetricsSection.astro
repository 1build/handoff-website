---
import bgPattern from "@/assets/images/background-pattern.png";
import checkmarkShield from "@/assets/images/checkmark-shield.png";
import mattAvatar from "@/assets/images/testimonial-matt-avatar.png";

const metrics = [
  { value: "400+", label: "Projects completed" },
  { value: "400+", label: "Projects completed" },
];

const testimonial = {
  quote: "Handoff AI is a game changer in helping us develop our long term sales & operations plan\u2026 AI is the way of the future and this hits us in a very important part of our business.",
  name: "Matt",
  role: "Equi-linc",
};

const notifications = [
  {
    icon: "file-check",
    text: 'Master Bath Remodel proposal <strong>approved</strong> by Sarah Miller',
    time: "Just now",
  },
  {
    icon: "bank-note",
    text: 'Deposit of <strong>$8,500 received</strong> for Kitchen Remodel project',
    time: "2m ago",
  },
  {
    icon: "send",
    text: 'Kitchen Remodel <strong>proposal sent</strong> successfully to Olivia Rhye',
    time: "15m ago",
  },
];
---

<section class="px-4 py-2">
  <div
    class="bg-white rounded-3xl border border-black/[0.04] overflow-hidden py-16 lg:py-24 relative"
    data-animate="fade-up"
  >
    <!-- Background pattern -->
    <div class="absolute top-24 left-1/2 -translate-x-1/2 w-[1920px] h-[1440px] pointer-events-none opacity-50">
      <img src={bgPattern.src} alt="" class="w-full h-full block object-contain object-top" />
    </div>

    <div class="max-w-[1280px] mx-auto px-6 lg:px-8 relative z-10 flex flex-col lg:flex-row items-center gap-16">
      <!-- Left column: Heading + Metrics + Testimonial -->
      <div class="flex-1 flex flex-col gap-16">
        <!-- Heading -->
        <h2 class="font-display text-4xl lg:text-[48px] font-semibold leading-[1.2] lg:leading-[60px] tracking-[-0.96px] text-text-primary max-w-[768px]">
          Built for contractors who want their time back
        </h2>

        <!-- Metrics -->
        <div class="flex flex-wrap gap-6" data-animate="fade-up">
          {metrics.map((metric) => (
            <div class="flex-1 min-w-[240px] flex flex-col gap-3">
              <p class="font-display text-[60px] font-semibold leading-[72px] tracking-[-1.2px] text-[#335645]">
                {metric.value}
              </p>
              <p class="text-lg font-semibold leading-7 text-text-primary">
                {metric.label}
              </p>
            </div>
          ))}
        </div>

        <!-- Testimonial -->
        <div class="border-l-2 border-[#849a8d] pl-10 py-6 flex flex-col gap-6" data-animate="fade-up">
          <p class="text-xl font-medium leading-[30px] text-text-tertiary">
            {testimonial.quote}
          </p>
          <div class="flex items-center gap-3">
            <div class="w-12 h-12 rounded-full border border-[rgba(0,0,0,0.08)] overflow-hidden shrink-0">
              <img src={mattAvatar.src} alt={testimonial.name} class="w-full h-full object-cover" />
            </div>
            <div>
              <p class="text-base font-medium leading-6 text-text-primary flex items-center gap-1">
                {testimonial.name}
                <svg width="16" height="16" viewBox="0 0 20 20" fill="none" class="text-brand-accent shrink-0">
                  <path fill-rule="evenodd" clip-rule="evenodd" d="M10 18a8 8 0 1 0 0-16 8 8 0 0 0 0 16Zm3.857-9.809a.75.75 0 0 0-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 1 0-1.06 1.061l2.5 2.5a.75.75 0 0 0 1.137-.089l4-5.5Z" fill="currentColor"/>
                </svg>
              </p>
              <p class="text-base font-normal leading-6 text-text-tertiary">{testimonial.role}</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Right column: Illustration + Notification cards -->
      <div class="hidden lg:flex flex-col items-end relative w-[582px] h-[546px] shrink-0">
        <!-- Green checkmark shape -->
        <img
          src={checkmarkShield.src}
          alt=""
          class="w-[520px] h-[498px]"
        />

        <!-- Notification stack -->
        <div class="absolute bottom-0 left-[19px] w-[320px] h-[300px]">
          <!-- Top notification: file-check (proposal approved) -->
          <div class="absolute top-0 left-0 w-[320px] bg-white rounded-xl p-4 shadow-[0px_20px_24px_-4px_rgba(10,13,18,0.08),0px_8px_8px_-4px_rgba(10,13,18,0.03),0px_3px_3px_-1.5px_rgba(10,13,18,0.04)] overflow-hidden">
            <div class="flex gap-4 items-start">
              <div class="bg-[rgba(213,222,216,0.3)] rounded-lg p-2 shrink-0">
                <!-- file-check-02 icon (Untitled UI) -->
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" class="text-brand-800">
                  <path d="M20 12.5V6.8c0-1.68 0-2.52-.327-3.162a3 3 0 0 0-1.311-1.311C17.72 2 16.88 2 15.2 2H8.8c-1.68 0-2.52 0-3.162.327a3 3 0 0 0-1.311 1.311C4 4.28 4 5.12 4 6.8v10.4c0 1.68 0 2.52.327 3.162a3 3 0 0 0 1.311 1.311C6.28 22 7.12 22 8.8 22H12m2-11H8m2 4H8m8-8H8m6.5 12 2 2 4.5-4.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
              <div class="flex-1 flex flex-col gap-0.5">
                <p class="text-sm font-medium leading-5 text-text-brand-secondary">
                  Master Bath Remodel proposal <strong class="font-bold">approved</strong> by Sarah Miller
                </p>
                <p class="text-xs font-medium leading-[18px] text-text-quaternary">Just now</p>
              </div>
            </div>
          </div>

          <!-- Middle notification: bank-note (deposit received) -->
          <div class="absolute top-[104px] left-[32px] w-[320px] bg-white rounded-xl p-4 shadow-[0px_20px_24px_-4px_rgba(10,13,18,0.08),0px_8px_8px_-4px_rgba(10,13,18,0.03),0px_3px_3px_-1.5px_rgba(10,13,18,0.04)] overflow-hidden">
            <div class="flex gap-4 items-start">
              <div class="bg-[rgba(213,222,216,0.3)] rounded-lg p-2 shrink-0">
                <!-- bank-note-01 icon (Untitled UI) -->
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" class="text-brand-800">
                  <path d="M6 11v4m12-6v4m-1-9c2.449 0 3.773.375 4.432.665a.708.708 0 0 1 .258.18c.076.072.215.284.25.383.06.165.06.255.06.435V16.41c0 .909 0 1.363-.136 1.597a.872.872 0 0 1-.532.44c-.255.089-.77-.01-1.8-.208-.72-.138-1.576-.24-2.532-.24-3 0-6 2-10 2-2.449 0-3.773-.375-4.432-.665-.088-.04-.132-.059-.258-.18a1.463 1.463 0 0 1-.25-.383C2 18.607 2 18.517 2 18.337V7.59c0-.909 0-1.363.136-1.597a.871.871 0 0 1 .532-.44c.255-.089.77.01 1.8.208C5.188 5.898 6.043 6 7 6c3 0 6-2 10-2Zm-2.5 8a2.5 2.5 0 1 1-5 0 2.5 2.5 0 0 1 5 0Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
              <div class="flex-1 flex flex-col gap-0.5">
                <p class="text-sm font-medium leading-5 text-text-brand-secondary">
                  Deposit of <strong class="font-bold">$8,500 received</strong> for Kitchen Remodel project
                </p>
                <p class="text-xs font-medium leading-[18px] text-text-quaternary">2m ago</p>
              </div>
            </div>
          </div>

          <!-- Bottom notification: send (proposal sent) — fading out -->
          <div class="absolute top-[208px] left-0 w-[320px] bg-gradient-to-b from-white from-[48%] to-transparent rounded-xl p-4 opacity-80 overflow-hidden">
            <div class="flex gap-4 items-start">
              <div class="bg-[rgba(213,222,216,0.3)] rounded-lg p-2 shrink-0">
                <!-- send-01 icon (Untitled UI) -->
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" class="text-brand-800">
                  <path d="M10.5 13.5 21 3M10.627 13.828l2.628 6.758c.232.596.347.893.514.98a.5.5 0 0 0 .462 0c.167-.086.283-.384.515-.979l6.59-16.888c.21-.537.315-.806.258-.977a.5.5 0 0 0-.316-.316c-.172-.057-.44.048-.978.257L3.413 9.253c-.595.233-.893.349-.98.516a.5.5 0 0 0 0 .461c.087.167.385.283.98.514l6.758 2.629c.121.046.182.07.233.106a.5.5 0 0 1 .116.117c.037.05.06.111.107.232Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
              <div class="flex-1 flex flex-col gap-0.5">
                <p class="text-sm font-medium leading-5 text-text-brand-secondary">
                  Kitchen Remodel <strong class="font-bold">proposal sent</strong> successfully to Olivia Rhye
                </p>
                <p class="text-xs font-medium leading-[18px] text-text-quaternary">15m ago</p>
              </div>
            </div>
          </div>

          <!-- Ghost blur card behind bottom -->
          <div class="absolute top-[208px] left-0 w-[320px] h-[92px] bg-[rgba(255,255,255,0.1)] backdrop-blur-[6px] rounded-xl -z-10"></div>
        </div>
      </div>
    </div>
  </div>
</section>
