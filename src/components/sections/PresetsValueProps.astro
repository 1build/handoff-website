---
import SupplierLogosCarousel from "./SupplierLogosCarousel.astro";
---

<section class="px-4">
  <div
    class="max-w-[1920px] mx-auto bg-white border border-black/[0.04] rounded-3xl overflow-hidden py-16 lg:py-24 flex flex-col items-center gap-16 lg:gap-20"
    data-animate="fade-up"
  >
    <!-- Header -->
    <div class="max-w-[1440px] w-full px-6 lg:px-8">
      <div class="max-w-[1024px]">
        <h2 class="font-display text-4xl lg:text-5xl font-medium leading-[1.2] lg:leading-[60px] tracking-[-0.96px] text-text-primary mb-5">
          Every output reflects your business<br />Without you checking It
        </h2>
        <p class="text-lg lg:text-xl text-text-tertiary leading-[30px]">
          Set your rules once. Handoff applies them automatically across every estimate, proposal, and change order.
        </p>
      </div>
    </div>

    <!-- Feature cards + Testimonial -->
    <div class="max-w-[1440px] w-full flex flex-col gap-8">
      <!-- Three feature cards -->
      <div class="px-6 lg:px-8">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <!-- Card 1: Consistent margins -->
          <div class="bg-bg-secondary rounded-xl p-6 flex flex-col gap-16">
            <div class="w-12 h-12 bg-white rounded-lg shadow-3xl flex items-center justify-center">
             <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
<path d="M8 3.6C8 3.03995 8 2.75992 7.89101 2.54601C7.79513 2.35785 7.64215 2.20487 7.45399 2.10899C7.24008 2 6.96005 2 6.4 2H6.16146C5.63433 1.99998 5.17954 1.99997 4.80497 2.03057C4.40963 2.06287 4.01641 2.13419 3.63803 2.32698C3.07354 2.6146 2.6146 3.07354 2.32698 3.63803C2.13419 4.01641 2.06287 4.40963 2.03057 4.80497C1.99997 5.17954 1.99998 5.63429 2 6.16142V17.8385C1.99998 18.3657 1.99997 18.8205 2.03057 19.195C2.06287 19.5904 2.13419 19.9836 2.32698 20.362C2.6146 20.9265 3.07354 21.3854 3.63803 21.673C4.01641 21.8658 4.40963 21.9371 4.80497 21.9694C5.17954 22 5.6343 22 6.16144 22H6.4C6.96005 22 7.24008 22 7.45399 21.891C7.64215 21.7951 7.79514 21.6422 7.89101 21.454C8 21.2401 8 20.9601 8 20.4L8 3.6Z" fill="#4E6D5D"/>
<path fill-rule="evenodd" clip-rule="evenodd" d="M10 20.4C10 20.9601 10 21.2401 10.109 21.454C10.2049 21.6422 10.3578 21.7951 10.546 21.891C10.7599 22 11.0399 22 11.6 22H17.8386C18.3657 22 18.8205 22 19.195 21.9694C19.5904 21.9371 19.9836 21.8658 20.362 21.673C20.9265 21.3854 21.3854 20.9265 21.673 20.362C21.8658 19.9836 21.9371 19.5904 21.9694 19.195C22 18.8205 22 18.3657 22 17.8386V6.16144C22 5.6343 22 5.17954 21.9694 4.80497C21.9371 4.40963 21.8658 4.01641 21.673 3.63803C21.3854 3.07354 20.9265 2.6146 20.362 2.32698C19.9836 2.13419 19.5904 2.06287 19.195 2.03057C18.8205 1.99997 18.3657 1.99998 17.8386 2H11.6C11.0399 2 10.7599 2 10.546 2.10899C10.3578 2.20487 10.2049 2.35785 10.109 2.54601C10 2.75992 10 3.03995 10 3.6L10 20.4ZM12 7C12 6.44772 12.4477 6 13 6H19C19.5523 6 20 6.44772 20 7C20 7.55229 19.5523 8 19 8H13C12.4477 8 12 7.55229 12 7ZM13 10C12.4477 10 12 10.4477 12 11C12 11.5523 12.4477 12 13 12H19C19.5523 12 20 11.5523 20 11C20 10.4477 19.5523 10 19 10H13ZM13 14C12.4477 14 12 14.4477 12 15C12 15.5523 12.4477 16 13 16H19C19.5523 16 20 15.5523 20 15C20 14.4477 19.5523 14 19 14H13Z" fill="#4E6D5D"/>
</svg>

            </div>
            <div class="flex flex-col gap-4">
              <h3 class="font-display text-2xl font-medium leading-8 text-text-primary">
                Consistent margins
              </h3>
              <p class="text-lg text-text-tertiary leading-7">
                Every contract, change order, and document in one place. No more hunting through excel sheets for approvals.
              </p>
            </div>
          </div>

          <!-- Card 2: Cut admin time in half -->
          <div class="bg-bg-secondary rounded-xl p-6 flex flex-col gap-16">
            <div class="w-12 h-12 bg-white rounded-lg shadow-3xl flex items-center justify-center">
              <svg width="23" height="23" viewBox="0 0 23 23" fill="none" xmlns="http://www.w3.org/2000/svg">
<path fill-rule="evenodd" clip-rule="evenodd" d="M0 11C0 4.92487 4.92487 0 11 0C17.0751 0 22 4.92487 22 11C22 11.583 21.9546 12.1555 21.8673 12.714C21.7945 13.1789 21.7581 13.4114 21.6659 13.5191C21.5671 13.6346 21.4996 13.671 21.3488 13.69C21.2081 13.7078 20.8857 13.5612 20.2408 13.2678C19.8627 13.0958 19.4425 13 19 13C17.3431 13 16 14.3431 16 16C14.3431 16 13 17.3431 13 19C13 19.4425 13.0958 19.8627 13.2678 20.2408C13.5612 20.8857 13.7078 21.2081 13.69 21.3488C13.671 21.4996 13.6346 21.5671 13.5191 21.6659C13.4114 21.7581 13.1789 21.7945 12.714 21.8673C12.1555 21.9546 11.583 22 11 22C4.92487 22 0 17.0751 0 11ZM12 5C12 4.44772 11.5523 4 11 4C10.4477 4 10 4.44772 10 5V11C10 11.3788 10.214 11.725 10.5528 11.8944L14.5528 13.8944C15.0468 14.1414 15.6474 13.9412 15.8944 13.4472C16.1414 12.9532 15.9412 12.3526 15.4472 12.1056L12 10.382V5Z" fill="#4E6D5D"/>
<path d="M20 16C20 15.4477 19.5523 15 19 15C18.4477 15 18 15.4477 18 16V18H16C15.4477 18 15 18.4477 15 19C15 19.5523 15.4477 20 16 20H18V22C18 22.5523 18.4477 23 19 23C19.5523 23 20 22.5523 20 22V20H22C22.5523 20 23 19.5523 23 19C23 18.4477 22.5523 18 22 18H20V16Z" fill="#4E6D5D"/>
</svg>

            </div>
            <div class="flex flex-col gap-4">
              <h3 class="font-display text-2xl font-medium leading-8 text-text-primary">
                Cut admin time in half
              </h3>
              <p class="text-lg text-text-tertiary leading-7">
                Proposals turn into payments seamlessly. Change orders stay organized without the extra work.
              </p>
            </div>
          </div>

          <!-- Card 3: Scale without the bottleneck -->
          <div class="bg-bg-secondary rounded-xl p-6 flex flex-col gap-16">
            <div class="w-12 h-12 bg-white rounded-lg shadow-3xl flex items-center justify-center">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
<path d="M5.7587 4.11943e-07H14.2413C15.0463 -1.19578e-05 15.7106 -2.21655e-05 16.2518 0.0441949C16.8139 0.0901201 17.3306 0.188684 17.816 0.435975C18.5686 0.819469 19.1805 1.43139 19.564 2.18404C19.8113 2.66937 19.9099 3.18608 19.9558 3.74818C20 4.28937 20 4.95372 20 5.75868V14.2413C20 15.0463 20 15.7106 19.9558 16.2518C19.9099 16.8139 19.8113 17.3306 19.564 17.816C19.1805 18.5686 18.5686 19.1805 17.816 19.564C17.3306 19.8113 16.8139 19.9099 16.2518 19.9558C15.7106 20 15.0463 20 14.2413 20H14C13.4477 20 13 19.5523 13 19C13 18.4477 13.4477 18 14 18H14.2C15.0566 18 15.6389 17.9992 16.089 17.9624C16.5274 17.9266 16.7516 17.8617 16.908 17.782C17.2843 17.5903 17.5903 17.2843 17.782 16.908C17.8617 16.7516 17.9266 16.5274 17.9624 16.089C17.9992 15.6389 18 15.0566 18 14.2V5.8C18 4.94342 17.9992 4.36113 17.9624 3.91104C17.9266 3.47262 17.8617 3.24842 17.782 3.09202C17.5903 2.7157 17.2843 2.40973 16.908 2.21799C16.7516 2.1383 16.5274 2.07337 16.089 2.03755C15.6389 2.00078 15.0566 2 14.2 2H5.8C4.94342 2 4.36113 2.00078 3.91104 2.03755C3.47262 2.07337 3.24842 2.1383 3.09202 2.21799C2.7157 2.40973 2.40974 2.7157 2.21799 3.09202C2.1383 3.24842 2.07337 3.47262 2.03755 3.91104C2.00078 4.36113 2 4.94342 2 5.8V6C2 6.55229 1.55229 7 1 7C0.447717 7 8.02061e-07 6.55229 8.02061e-07 6V5.7587C-1.15677e-05 4.95374 -2.1778e-05 4.28937 0.0441953 3.74818C0.0901205 3.18608 0.188685 2.66937 0.435976 2.18404C0.819469 1.43139 1.43139 0.819469 2.18404 0.435975C2.66938 0.188684 3.18608 0.0901201 3.74818 0.0441949C4.28937 -2.21655e-05 4.95374 -1.19578e-05 5.7587 4.11943e-07Z" fill="#4E6D5D"/>
<path d="M6.83855 9H4.16146C3.63431 8.99998 3.17955 8.99997 2.80497 9.03057C2.40963 9.06287 2.01641 9.13419 1.63803 9.32698C1.07354 9.6146 0.614603 10.0735 0.326983 10.638C0.134189 11.0164 0.062873 11.4096 0.030572 11.805C-3.0987e-05 12.1795 -1.62655e-05 12.6343 8.02061e-07 13.1614V15.8385C-1.62655e-05 16.3657 -3.0987e-05 16.8205 0.030572 17.195C0.062873 17.5904 0.134189 17.9836 0.326983 18.362C0.614603 18.9265 1.07354 19.3854 1.63803 19.673C2.01641 19.8658 2.40963 19.9371 2.80497 19.9694C3.17951 20 3.63423 20 4.16131 20H6.83853C7.36561 20 7.82049 20 8.19503 19.9694C8.59037 19.9371 8.98359 19.8658 9.36197 19.673C9.92646 19.3854 10.3854 18.9265 10.673 18.362C10.8658 17.9836 10.9371 17.5904 10.9694 17.195C11 16.8205 11 16.3657 11 15.8386V13.1615C11 12.6343 11 12.1795 10.9694 11.805C10.9391 11.4337 10.8744 11.0643 10.7069 10.7073L14 7.41421V10C14 10.5523 14.4477 11 15 11C15.5523 11 16 10.5523 16 10V5C16 4.44772 15.5523 4 15 4H10C9.44772 4 9 4.44772 9 5C9 5.55229 9.44772 6 10 6H12.5858L9.29269 9.2931C8.9357 9.12565 8.5663 9.06091 8.19503 9.03057C7.82046 8.99997 7.3657 8.99998 6.83855 9Z" fill="#4E6D5D"/>
</svg>

            </div>
            <div class="flex flex-col gap-4">
              <h3 class="font-display text-2xl font-medium leading-8 text-text-primary">
                Scale without the bottleneck
              </h3>
              <p class="text-lg text-text-tertiary leading-7">
                Your AI Teammate learns your way of doing things and handles it on every project. Scale up without being in three places at once.
              </p>
            </div>
          </div>
        </div>
      </div>

      <!-- Testimonial block -->
      <div class="px-6 lg:px-8">
        <div class="bg-bg-secondary rounded-xl p-8 lg:p-12">
          <div class="flex flex-col gap-8">
            <!-- Stars + rating -->
            <div class="flex items-center gap-4">
              <div class="flex gap-1">
                {Array.from({ length: 5 }).map(() => (
                  <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M10 1L12.39 6.26L18.18 7.27L14.09 11.73L15.18 17.44L10 14.77L4.82 17.44L5.91 11.73L1.82 7.27L7.61 6.26L10 1Z" fill="#F79009" stroke="#F79009" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                ))}
              </div>
              <span class="text-base font-medium text-text-quaternary">5/5</span>
            </div>

            <!-- Quote -->
            <p class="font-display text-2xl lg:text-4xl font-medium leading-[1.2] lg:leading-[44px] tracking-[-0.72px] text-text-primary">
              Handoff has <span class="text-brand-accent">streamlined a lot of my workflow</span>. I really appreciate how everything is in one place, making communication and tracking progress much easier.
            </p>

            <!-- Attribution + CTA -->
            <div class="flex flex-col sm:flex-row items-start sm:items-center gap-6 lg:gap-16">
              <div class="flex flex-col gap-1">
                <p class="text-lg font-semibold text-text-primary">— Amanda M.</p>
                <p class="text-base text-text-tertiary">Owner/Project Manager</p>
              </div>
              <a
                href="/reviews"
                class="inline-flex items-center justify-center gap-1.5 px-6 py-3 text-base font-medium leading-6 rounded-xl border border-border-primary bg-white text-text-secondary shadow-xs hover:bg-neutral-50 transition-colors"
              >
                View more testimonials
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Logo bar -->
    <SupplierLogosCarousel title="Used by thousands of construction businesses like yours:" />
  </div>
</section>
