---
import videoThumbnail from "@/assets/images/See In Action Video Thumbnail.webp";
interface Props {
  videoSrc?: string;
}
const { videoSrc = "https://www.handoff.ai/assets/hndf-delivery-video.webm" } = Astro.props;
---
<section class="px-4">
<div class="max-w-[1920px] mx-auto relative z-[2] py-10 md:py-16 lg:py-20 bg-white rounded-3xl" data-animate="fade-up">
  <div class="max-w-[1440px] mx-auto px-4 sm:px-6 md:px-8">
    <div class="text-center max-w-[720px] mx-auto mb-8 md:mb-12">
      <h2 class="font-display text-3xl sm:text-4xl md:text-[2.5rem] font-semibold leading-tight tracking-[-0.02em] text-text-primary mb-4">
        Contractors Who Have an AI Teammate Don't Work Like the Rest.
      </h2>
      <p class="text-base md:text-lg leading-relaxed text-text-secondary">
        See how residential contractors run their day-to-day with Handoff - not sticky notes, spreadsheets, and memory.
      </p>
    </div>

    {videoSrc ? (
    <div class="relative">
      <div id="video-wrapper" class="relative w-full rounded-3xl overflow-hidden bg-black/5" style="max-height: 400px; cursor: pointer;">
        <video
          id="section-video"
          class="w-full h-full object-cover rounded-3xl"
          controls
          playsinline
          preload="auto"
          poster={videoThumbnail.src}
          style="max-height: 400px; width: 100%;"
        >
          <source src={videoSrc} type="video/webm" />
          Your browser does not support the video tag.
        </video>
      </div>
      <button
        id="video-minimize"
        class="hidden mt-3 mx-auto flex items-center gap-1.5 text-sm text-text-secondary hover:text-text-primary transition-colors"
        style="display: none;"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="4 14 10 14 10 20"></polyline>
          <polyline points="20 10 14 10 14 4"></polyline>
          <line x1="10" y1="14" x2="21" y2="3"></line>
          <line x1="3" y1="21" x2="14" y2="10"></line>
        </svg>
        Minimize
      </button>
    </div>

    <script>
      const wrapper = document.getElementById('video-wrapper');
      const video = document.getElementById('section-video') as HTMLVideoElement;
      const minimizeBtn = document.getElementById('video-minimize') as HTMLButtonElement;
      let expanded = false;

      video?.addEventListener('click', (e) => {
        if (!expanded) {
          e.preventDefault();
          expanded = true;
          wrapper!.style.maxHeight = '';
          wrapper!.style.cursor = 'default';
          wrapper!.classList.add('aspect-video');
          video.style.maxHeight = '';
          minimizeBtn!.style.display = 'flex';
          video.play();
        }
      });

      minimizeBtn?.addEventListener('click', () => {
        expanded = false;
        wrapper!.style.maxHeight = '400px';
        wrapper!.style.cursor = 'pointer';
        wrapper!.classList.remove('aspect-video');
        video.style.maxHeight = '400px';
        minimizeBtn.style.display = 'none';
        video.pause();
      });
    </script>
    ) : (
    <div class="relative w-full rounded-3xl overflow-hidden bg-black/5 aspect-video flex items-center justify-center text-text-tertiary">
      <p>Add a video via the videoSrc prop or place a file at <code class="text-sm">public/video/demo.webm</code></p>
    </div>
    )}
  </div>
</div>
</section>
