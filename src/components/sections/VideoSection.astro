---
import handoffVideo from "@/assets/images/HandoffDeliveryVideo.webm";

interface Props {
  videoSrc?: string;
}
const { videoSrc = (typeof handoffVideo === 'string' ? handoffVideo : handoffVideo?.src ?? '') } = Astro.props;
---
<section class="px-4">
<div class="relative z-[2] py-10 md:py-16 lg:py-20 bg-white rounded-3xl" data-animate="fade-up">
  <div class="max-w-[1440px] mx-auto px-4 sm:px-6 md:px-8">
    <div class="text-center max-w-[720px] mx-auto mb-8 md:mb-12">
      <h2 class="font-display text-3xl sm:text-4xl md:text-[2.5rem] font-semibold leading-tight tracking-[-0.02em] text-text-primary mb-4">
        Modern contractors move faster
      </h2>
      <p class="text-base md:text-lg leading-relaxed text-text-secondary">
        See how top contractors use Handoff to run their day-to-day on connected systems and AI, not sticky notes and memory.
      </p>
    </div>

    <div class="relative w-full rounded-3xl overflow-hidden bg-black/5 aspect-video">
      <video
        class="w-full h-full object-cover rounded-3xl"
        controls
        playsinline
        preload="auto"
      >
        <source src={videoSrc} type="video/webm" />
        Your browser does not support the video tag.
      </video>
    </div>
  </div>
</div>
</section>
