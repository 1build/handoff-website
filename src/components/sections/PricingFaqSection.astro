---
const faqItems = [
  {
    question: "Is there a free trial available?",
    answer: "Yes, you can try us for free for 7 days. We'll provide you with a free, personalized 30-minute training call to share best practices and train the AI to your business so you get the most out of Handoff.",
  },
  {
    question: "Where does your cost data come from?",
    answer: "Our AI is trained on real contractor pricing data from thousands of projects across the country. It also learns from your specific rates, markups, and labor costs as you use Handoff—giving you increasingly accurate estimates the more you use the platform.",
  },
  {
    question: "Does this work for my type of business?",
    answer: "Handoff works for remodelers, general contractors, trade contractors, and handymen. Whether you do kitchens, bathrooms, roofing, electrical, or full-home renovations, you can train the AI on your pricing structure and workflows.",
  },
  {
    question: "Can your AI read my drawings, photos, and other files I upload?",
    answer: "Yes. Handoff's AI can analyze photos, PDF plans, and site walkthrough recordings to automatically identify work items and build estimates from them. The more context you give it, the more accurate the estimate.",
  },
  {
    question: "When will you have a feature I need?",
    answer: "We ship updates every week. You can submit feature requests directly from the app, and our team prioritizes features based on contractor demand. Custom and Enterprise plans include priority feature request access.",
  },
];
---

<section class="max-w-[1920px] mx-auto py-16 lg:py-24">
  <div class="bg-bg-primary">
  <div class="max-w-[1280px] mx-auto px-6 lg:px-8 flex flex-col gap-16">

    <!-- Heading -->
    <div class="flex flex-col gap-5 items-center text-center max-w-[768px] mx-auto" data-animate="fade-up">
      <h2 class="font-display text-4xl font-semibold leading-[44px] tracking-[-0.72px] text-text-primary">
        Frequently asked questions
      </h2>
      <p class="text-xl font-normal leading-[30px] text-text-tertiary">
        Everything you need to know about the product and billing.
      </p>
    </div>

    <!-- FAQ items -->
    <div class="flex flex-col max-w-[768px] mx-auto w-full" data-animate="stagger">
      {faqItems.map((item, i) => (
        <details class="faq-item group border-t border-border-secondary py-6">
          <summary class="flex items-start justify-between gap-4 cursor-pointer list-none [&::-webkit-details-marker]:hidden">
            <span class="text-base font-semibold leading-6 text-text-primary">
              {item.question}
            </span>
            <span class="shrink-0 w-6 h-6 transition-transform duration-200 group-open:rotate-45">
              <svg viewBox="0 0 24 24" fill="none" class="w-full h-full">
                <circle cx="12" cy="12" r="10" stroke="#535862" stroke-width="1.5" />
                <path d="M8 12H16" stroke="#535862" stroke-width="1.5" stroke-linecap="round" />
                <path d="M12 8V16" stroke="#535862" stroke-width="1.5" stroke-linecap="round" />
              </svg>
            </span>
          </summary>
          <div class="grid grid-rows-[0fr] group-open:grid-rows-[1fr] transition-[grid-template-rows] duration-300 ease-in-out">
            <div class="overflow-hidden">
              <p class="text-base font-normal leading-6 text-text-tertiary mt-4 pr-10">
                {item.answer}
              </p>
            </div>
          </div>
        </details>
      ))}
    </div>

  </div>
  </div>
</section>
